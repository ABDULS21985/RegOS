# ============================================================================
#  FC Engine — Deployment Configuration
#  Copy this file to .env and fill in your production values.
# ============================================================================

# ── Domains (must point to your VPS IP via DNS A records) ──────────────────
DOMAIN_ADMIN=admin.regos.app
DOMAIN_PORTAL=portal.regos.app
DOMAIN_API=api.regos.app

# ── Database ───────────────────────────────────────────────────────────────
DB_PASSWORD=YourStrong@Passw0rd         # SQL Server SA password (change this!)
DB_NAME=FcEngine
SQL_PORT=1433

# ── Application ────────────────────────────────────────────────────────────
ADMIN_PASSWORD=Admin@123                # Default admin user password
API_KEY=your-secure-api-key-here        # API authentication key

# ── SSL (Let's Encrypt) ───────────────────────────────────────────────────
SSL_EMAIL=devops@yourcompany.com        # For certificate expiry notices
ENABLE_SSL=true                         # Set false to skip SSL provisioning

# ── Ports (internal — Nginx proxies externally on 80/443) ──────────────────
API_PORT=5100
ADMIN_PORT=5200
PORTAL_PORT=5300

# ── System ─────────────────────────────────────────────────────────────────
APP_USER=fcengine                       # Linux user to run services
APP_DIR=/opt/fcengine                   # Installation directory
LOG_DIR=/var/log/fcengine               # Log directory
BACKUP_DIR=/opt/fcengine/backups        # Database backup directory
BACKUP_RETENTION_DAYS=14                # Days to keep backups

# ── Build Strategy (choose ONE) ───────────────────────────────────────────
# Option A: Build from source on the server (requires .NET SDK)
#SRC_DIR=/opt/fcengine/source            # Path to cloned repo on VPS

# Option B: Deploy pre-built artifacts (built locally, uploaded via scp)
#DEPLOY_ARTIFACTS=/tmp/fcengine-publish  # Path to published output

# ── .NET ───────────────────────────────────────────────────────────────────
DOTNET_VERSION=10.0

# ── Notification Services (optional — defaults work without these) ─────────
#SENDGRID_API_KEY=SG.xxxxx
#AFRICASTALKING_API_KEY=xxxxx
#AFRICASTALKING_USERNAME=sandbox
