@inherits LayoutComponentBase
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.ValueObjects
@inject ITenantBrandingService BrandingService
@inject ITenantContext TenantContext

<TenantThemeProvider />

<div class="fc-login-layout">
    <!-- Left Brand Panel -->
    <aside class="fc-login-brand-panel" aria-hidden="true" style="@BackgroundStyle">
        <!-- Layered background -->
        <div class="fc-brand-bg-layer"></div>
        <div class="fc-brand-bg-accent"></div>
        <div class="fc-brand-bg-grid" aria-hidden="true"></div>

        <!-- Floating orbs (CSS-only animation) -->
        <div class="fc-brand-orbs" aria-hidden="true">
            <div class="fc-brand-orb"></div>
            <div class="fc-brand-orb"></div>
            <div class="fc-brand-orb"></div>
            <div class="fc-brand-orb"></div>
        </div>

        <div class="fc-brand-content">
            <div class="fc-brand-logo-wrapper">
                <img src="@_branding.LogoUrl" alt="" class="fc-brand-logo" width="130" height="108" />
            </div>

            <h1 class="fc-brand-name">@_branding.CompanyName</h1>

            <div class="fc-brand-separator" role="presentation">
                <span class="separator-line"></span>
            </div>

            <p class="fc-brand-tagline">@(_branding.LoginTagline ?? "Financial Returns Collection &amp; Analysis System")</p>

            <!-- Feature highlights -->
            <div class="fc-brand-features">
                <div class="fc-brand-feature">
                    <div class="fc-brand-feature__icon" style="--bf-color:#3B82F6;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                    </div>
                    <div class="fc-brand-feature__text">
                        <div class="fc-brand-feature__title">Return Management</div>
                        <div class="fc-brand-feature__desc">Template authoring, versioning, and field configuration</div>
                    </div>
                </div>
                <div class="fc-brand-feature">
                    <div class="fc-brand-feature__icon" style="--bf-color:#8B5CF6;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                    </div>
                    <div class="fc-brand-feature__text">
                        <div class="fc-brand-feature__title">Validation Engine</div>
                        <div class="fc-brand-feature__desc">Intra-sheet formulas, cross-sheet rules, and business logic</div>
                    </div>
                </div>
                <div class="fc-brand-feature">
                    <div class="fc-brand-feature__icon" style="--bf-color:#22C55E;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    </div>
                    <div class="fc-brand-feature__text">
                        <div class="fc-brand-feature__title">Compliance Assurance</div>
                        <div class="fc-brand-feature__desc">Automated regulatory submission and audit trail</div>
                    </div>
                </div>
                <div class="fc-brand-feature">
                    <div class="fc-brand-feature__icon" style="--bf-color:#F59E0B;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                    </div>
                    <div class="fc-brand-feature__text">
                        <div class="fc-brand-feature__title">Capital Intelligence</div>
                        <div class="fc-brand-feature__desc">RWA optimisation, buffer management, and scenario planning</div>
                    </div>
                </div>
            </div>

            <!-- Trust badges (configurable via Theme & Branding settings) -->
            <div class="fc-brand-trust-badges">
                @if (!string.IsNullOrWhiteSpace(_branding.TrustBadge1))
                {
                    <div class="trust-badge">
                        <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14" aria-hidden="true">
                            <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                        </svg>
                        <span>@_branding.TrustBadge1</span>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(_branding.TrustBadge2))
                {
                    <div class="trust-badge">
                        <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14" aria-hidden="true">
                            <path fill-rule="evenodd" d="M6 2a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V7.414A2 2 0 0015.414 6L12 2.586A2 2 0 0010.586 2H6zm2 10a1 1 0 10-2 0v3a1 1 0 102 0v-3zm2-3a1 1 0 011 1v5a1 1 0 11-2 0v-5a1 1 0 011-1zm4 2a1 1 0 10-2 0v3a1 1 0 102 0v-3z" clip-rule="evenodd"/>
                        </svg>
                        <span>@_branding.TrustBadge2</span>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(_branding.TrustBadge3))
                {
                    <div class="trust-badge">
                        <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14" aria-hidden="true">
                            <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
                        </svg>
                        <span>@_branding.TrustBadge3</span>
                    </div>
                }
            </div>
        </div>

        <div class="fc-brand-panel-footer">
            <span>@(_branding.CopyrightText ?? "Authorized Access Only") &mdash; This system is monitored</span>
        </div>
    </aside>

    <!-- Right Content Panel -->
    <main class="fc-login-content-panel">
        @Body
    </main>
</div>

@code {
    private BrandingConfig _branding = BrandingConfig.WithDefaults();

    private string? BackgroundStyle =>
        string.IsNullOrWhiteSpace(_branding.LoginBackgroundUrl)
            ? null
            : $"background-image: linear-gradient(135deg, rgba(0,0,0,0.45), rgba(0,0,0,0.1)), url('{_branding.LoginBackgroundUrl}'); background-size: cover; background-position: center;";

    protected override async Task OnInitializedAsync()
    {
        if (TenantContext.CurrentTenantId.HasValue)
        {
            _branding = await BrandingService.GetBrandingConfig(TenantContext.CurrentTenantId.Value);
        }
    }
}
