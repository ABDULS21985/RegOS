@* GlobalErrorBanner.razor
   Non-intrusive dismissible banner shown at the top of the main content area when
   GlobalErrorService.ReportError() is called (e.g. failed CSV export, background job error).
   Placed once in MainLayout, just below the impersonation banner.
*@
@inject FC.Engine.Admin.Services.GlobalErrorService ErrorSvc
@implements IDisposable

@if (_message is not null)
{
    <div class="fc-global-error-banner" role="alert" aria-live="assertive">
        <span class="fc-global-error-banner__icon" aria-hidden="true">
            <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" width="16" height="16">
                <path d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495z"
                      stroke="currentColor" stroke-width="1.5"/>
                <line x1="10" y1="8" x2="10" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <circle cx="10" cy="15" r="0.75" fill="currentColor" stroke="none"/>
            </svg>
        </span>
        <span class="fc-global-error-banner__message">@_message</span>
        <button class="fc-global-error-banner__dismiss"
                @onclick="Dismiss"
                aria-label="Dismiss error notification">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" width="14" height="14" aria-hidden="true">
                <line x1="4" y1="4" x2="12" y2="12"/>
                <line x1="12" y1="4" x2="4" y2="12"/>
            </svg>
        </button>
    </div>
}

@code {
    private string? _message;

    protected override void OnInitialized()
        => ErrorSvc.OnError += OnError;

    private void OnError(string message)
    {
        _message = message;
        InvokeAsync(StateHasChanged);
    }

    private void Dismiss() => _message = null;

    public void Dispose() => ErrorSvc.OnError -= OnError;
}
