@* Reusable collapsible accordion panel with smooth animation *@

<div class="ia-accordion @(_expanded ? "ia-accordion-open" : "")">
    <button class="ia-accordion-header"
            @onclick="Toggle"
            aria-expanded="@_expanded"
            aria-controls="@_panelId"
            id="@_headerId">
        <div class="ia-accordion-header-left">
            @if (Icon != null)
            {
                <div class="ia-accordion-icon @BadgeClass" aria-hidden="true">
                    @Icon
                </div>
            }
            <div class="ia-accordion-title-group">
                <span class="ia-accordion-title">@Title</span>
                @if (!string.IsNullOrEmpty(Subtitle))
                {
                    <span class="ia-accordion-subtitle">@Subtitle</span>
                }
            </div>
        </div>
        <div class="ia-accordion-header-right">
            @if (Count.HasValue)
            {
                <span class="ia-accordion-count @CountClass">@Count</span>
            }
            @if (Badge != null)
            {
                @Badge
            }
            <svg class="ia-accordion-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
            </svg>
        </div>
    </button>
    <div class="ia-accordion-body" id="@_panelId" role="region" aria-labelledby="@_headerId">
        <div class="ia-accordion-content">
            @ChildContent
        </div>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public int? Count { get; set; }
    [Parameter] public string Variant { get; set; } = "default";
    [Parameter] public bool InitiallyOpen { get; set; }
    [Parameter] public RenderFragment? Icon { get; set; }
    [Parameter] public RenderFragment? Badge { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool _expanded;
    private string _panelId = $"acc-panel-{Guid.NewGuid():N}"[..16];
    private string _headerId = $"acc-head-{Guid.NewGuid():N}"[..16];

    private string BadgeClass => Variant switch
    {
        "gold" => "ia-accordion-icon-gold",
        "red" or "danger" => "ia-accordion-icon-red",
        "blue" or "info" => "ia-accordion-icon-blue",
        _ => "ia-accordion-icon-green"
    };

    private string CountClass => Variant switch
    {
        "gold" => "ia-accordion-count-gold",
        "red" or "danger" => "ia-accordion-count-red",
        "blue" or "info" => "ia-accordion-count-blue",
        _ => "ia-accordion-count-green"
    };

    protected override void OnInitialized()
    {
        _expanded = InitiallyOpen;
    }

    private void Toggle() => _expanded = !_expanded;
}
