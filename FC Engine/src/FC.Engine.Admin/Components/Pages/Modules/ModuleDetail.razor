@page "/modules/{ModuleCode}"
@attribute [Authorize(Policy = "PlatformAdmin")]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using FC.Engine.Admin.Utilities
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Admin.Services
@inject IModuleService ModuleService
@inject IModuleImportService ModuleImportService
@inject NavigationManager Navigation
@inject ToastService Toast
@inject DialogService Dialog

<PageTitle>Module: @ModuleCode</PageTitle>

<PageHeader Title="@(_module?.ModuleName ?? ModuleCode)"
            Subtitle="@(_module != null ? $"{_module.RegulatorCode} regulatory module with {_module.SheetCount} template sheet(s)." : null)"
            StatusBadge="@(_module != null ? (_module.IsActive ? "Active" : "Inactive") : null)"
            StatusVariant="@(_module?.IsActive == true ? "success" : "neutral")"
            BackUrl="/modules">
    <PrimaryAction>
        @if (!_loading && (_module?.Templates.Count ?? 0) == 0)
        {
            <button class="fc-btn fc-btn--outline" @onclick="OpenImport" type="button">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                Import Definition
            </button>
        }
        else if (!_loading)
        {
            <button class="fc-btn fc-btn--outline" disabled title="Module updates via re-import are not yet supported. Use the versioned update workflow." type="button">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                Import Update
            </button>
        }
        <button class="fc-btn fc-btn--gold" disabled="@_publishing" @onclick="PublishDrafts" type="button">
            @if (_publishing)
            {
                <span class="fc-spinner fc-spinner--sm fc-spinner--white" aria-hidden="true"></span>
            }
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0018 9h-1.26A8 8 0 103 16.3"/></svg>
            Publish Drafts
        </button>
    </PrimaryAction>
    <SecondaryActions>
        @if (!_loading && _module is not null)
        {
            <button class="fc-btn fc-btn--outline fc-btn--sm" @onclick="OpenEditModal" type="button">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" aria-hidden="true"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                Edit
            </button>
            <button class="@($"fc-btn fc-btn--sm {(_module.IsActive ? "fc-btn--danger" : "fc-btn--success")}")"
                    disabled="@_togglingActive" @onclick="ToggleActive" type="button">
                @if (_togglingActive) { <span class="fc-spinner fc-spinner--xs fc-mr-2" aria-hidden="true"></span> }
                @(_module.IsActive ? "Deactivate" : "Activate")
            </button>
        }
    </SecondaryActions>
</PageHeader>

<div class="fc-page">
    <!-- Content -->
    @if (_loading)
    {
        <div class="fc-card fc-card--mb">
            <div class="fc-card__body fc-card-body--flush">
                <table class="fc-table">
                    <thead><tr><th>Version</th><th>Status</th><th>Published</th><th>Deprecated</th></tr></thead>
                    <tbody>
                        @for (var i = 0; i < 3; i++)
                        {
                            <tr>
                                <td><div class="fc-skel fc-skel-text" style="--skel-w:60px"></div></td>
                                <td><div class="fc-skel fc-skel-text" style="--skel-w:60px"></div></td>
                                <td><div class="fc-skel fc-skel-text" style="--skel-w:120px"></div></td>
                                <td><div class="fc-skel fc-skel-text" style="--skel-w:120px"></div></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else if (_module is null)
    {
        <div class="fc-empty">
            <div class="fc-empty-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <h3 class="fc-empty-title">Module not found</h3>
            <p class="fc-empty-text">The module code "@ModuleCode" does not exist in the registry.</p>
        </div>
    }
    else
    {
        <!-- Module Versions -->
        <div class="fc-card fc-card--mb">
            <div class="fc-card__header"><h2 class="fc-card__title">Module Versions</h2></div>
            <div class="fc-card__body fc-card-body--flush">
                @if (_module!.Versions.Count == 0)
                {
                    <div class="fc-table-empty-cell">No module version records yet.</div>
                }
                else
                {
                    <table class="fc-table">
                        <thead><tr><th>Version</th><th>Status</th><th>Published</th><th>Deprecated</th></tr></thead>
                        <tbody>
                            @foreach (var version in _module.Versions)
                            {
                                <tr>
                                    <td><code>@version.VersionCode</code></td>
                                    <td>
                                        <span class="fc-badge @GetVersionBadge(version.Status)">@version.Status</span>
                                    </td>
                                    <td>@(version.PublishedAt?.ToString("dd MMM yyyy HH:mm") ?? "—")</td>
                                    <td>@(version.DeprecatedAt?.ToString("dd MMM yyyy HH:mm") ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <!-- Templates -->
        <div class="fc-card">
            <div class="fc-card__header"><h2 class="fc-card__title">Templates</h2></div>
            <div class="fc-card__body fc-card-body--flush">
                @if (_module.Templates.Count == 0)
                {
                    <div class="fc-table-empty-cell">No templates are linked to this module.</div>
                }
                else
                {
                    <table class="fc-table">
                        <thead>
                            <tr>
                                <th>Return Code</th>
                                <th>Name</th>
                                <th>Latest Version</th>
                                <th>Status</th>
                                <th>Fields</th>
                                <th>Formulas</th>
                                <th>Table</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in _module.Templates)
                            {
                                <tr>
                                    <td><code>@row.ReturnCode</code></td>
                                    <td class="fc-fw-500">@row.Name</td>
                                    <td><span class="fc-badge fc-badge--neutral">v@row.VersionNumber</span></td>
                                    <td><span class="fc-badge @GetTemplateBadge(row.Status)">@row.Status</span></td>
                                    <td><span class="fc-badge fc-badge--neutral">@row.FieldCount</span></td>
                                    <td><span class="fc-badge fc-badge--neutral">@row.FormulaCount</span></td>
                                    <td><code class="fc-code-sm">@row.PhysicalTableName</code></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    }
</div>

@if (_showEditModal && _editForm is not null)
{
    <AppModal Title="Edit Module" OnClose="CloseEditModal">
        <div class="fc-form">
            <FormField Label="Module Name" Required="true">
                <input class="fc-input" @bind="_editForm.ModuleName" />
            </FormField>
            <FormField Label="Description">
                <textarea class="fc-textarea" rows="3" @bind="_editForm.Description"></textarea>
            </FormField>
            <div class="fc-grid fc-grid-3">
                <FormField Label="Default Frequency">
                    <select class="fc-select" @bind="_editForm.DefaultFrequency">
                        <option value="Monthly">Monthly</option>
                        <option value="Quarterly">Quarterly</option>
                        <option value="SemiAnnual">Semi-Annual</option>
                        <option value="Annual">Annual</option>
                    </select>
                </FormField>
                <FormField Label="Deadline Offset (days)">
                    <input class="fc-input" type="number" @bind="_editForm.DeadlineOffsetDays" placeholder="Use default" />
                </FormField>
                <FormField Label="Display Order">
                    <input class="fc-input" type="number" min="0" @bind="_editForm.DisplayOrder" />
                </FormField>
            </div>
            @if (!string.IsNullOrEmpty(_editError))
            {
                <div class="fc-alert fc-alert--error fc-alert--inline fc-mt-2">@_editError</div>
            }
            <FormActions>
                <button class="fc-btn fc-btn--primary" @onclick="SaveEditAsync" disabled="@_savingEdit" type="button">
                    @if (_savingEdit) { <span class="fc-spinner fc-spinner--xs fc-mr-2" aria-hidden="true"></span> }
                    Save Changes
                </button>
                <button class="fc-btn fc-btn--outline" @onclick="CloseEditModal" type="button">Cancel</button>
            </FormActions>
        </div>
    </AppModal>
}

@code {
    [Parameter] public string ModuleCode { get; set; } = string.Empty;
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private bool _publishing;
    private bool _togglingActive;
    private bool _showEditModal;
    private bool _savingEdit;
    private string? _editError;
    private ModuleEditForm? _editForm;
    private ModuleDetailDto? _module;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _module = await ModuleService.GetModuleDetail(ModuleCode);
        _loading = false;
    }

    private void OpenImport() => Navigation.NavigateTo("/modules/import");

    private async Task PublishDrafts()
    {
        var confirmed = await Dialog.Confirm(new ConfirmRequest
        {
            Title = "Publish Module Drafts",
            Message = $"Publish all draft templates for module '{ModuleCode}'? This will create physical database tables.",
            ConfirmText = "Publish",
            IsDestructive = false,
            Icon = "publish"
        });

        if (!confirmed) return;

        _publishing = true;
        try
        {
            var result = await ModuleImportService.PublishModule(ModuleCode, await ResolveCurrentActorAsync());
            if (result.Success)
            {
                Toast.Success($"Module {ModuleCode} published. Tables created: {result.TablesCreated}.", "Publish Complete");
                await OnParametersSetAsync();
            }
            else
            {
                Toast.Error(string.Join("; ", result.Errors), "Publish failed");
            }
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message, "Publish failed");
        }
        finally
        {
            _publishing = false;
        }
    }

    private async Task<string> ResolveCurrentActorAsync()
    {
        var state = AuthState is null ? null : await AuthState;
        return UserIdentityResolver.ResolveActor(state?.User);
    }

    private static string GetVersionBadge(string status) => status switch
    {
        "Published" => "fc-badge--success",
        "Draft" => "fc-badge--warning",
        "Deprecated" => "fc-badge--danger",
        _ => "fc-badge--neutral"
    };

    private static string GetTemplateBadge(string status) => status switch
    {
        "Published" => "fc-badge--success",
        "Draft" => "fc-badge--warning",
        "Deprecated" => "fc-badge--danger",
        _ => "fc-badge--neutral"
    };

    private async Task ToggleActive()
    {
        if (_module is null) return;
        var action = _module.IsActive ? "deactivate" : "activate";
        var confirmed = await Dialog.Confirm(new ConfirmRequest
        {
            Title = $"{(_module.IsActive ? "Deactivate" : "Activate")} Module",
            Message = $"Are you sure you want to {action} module '{_module.ModuleCode}'?",
            ConfirmText = _module.IsActive ? "Deactivate" : "Activate"
        });
        if (!confirmed) return;

        _togglingActive = true;
        try
        {
            await ModuleService.ToggleModuleActive(ModuleCode);
            _module = await ModuleService.GetModuleDetail(ModuleCode);
            Toast.Success($"Module {ModuleCode} {action}d.");
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message);
        }
        finally
        {
            _togglingActive = false;
        }
    }

    private void OpenEditModal()
    {
        if (_module is null) return;
        _editForm = new ModuleEditForm
        {
            ModuleName = _module.ModuleName,
            Description = _module.Description
        };
        _editError = null;
        _showEditModal = true;
    }

    private void CloseEditModal()
    {
        _showEditModal = false;
        _editForm = null;
        _editError = null;
    }

    private async Task SaveEditAsync()
    {
        if (_editForm is null) return;
        if (string.IsNullOrWhiteSpace(_editForm.ModuleName))
        {
            _editError = "Module name is required.";
            return;
        }

        _savingEdit = true;
        _editError = null;
        try
        {
            await ModuleService.UpdateModuleDetails(
                ModuleCode, _editForm.ModuleName.Trim(), _editForm.Description?.Trim(),
                _editForm.DefaultFrequency, _editForm.DeadlineOffsetDays, _editForm.DisplayOrder);
            _module = await ModuleService.GetModuleDetail(ModuleCode);
            CloseEditModal();
            Toast.Success("Module details updated.");
        }
        catch (Exception ex)
        {
            _editError = ex.Message;
        }
        finally
        {
            _savingEdit = false;
        }
    }

    private sealed class ModuleEditForm
    {
        public string ModuleName { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string DefaultFrequency { get; set; } = "Monthly";
        public int? DeadlineOffsetDays { get; set; }
        public int DisplayOrder { get; set; }
    }
}
