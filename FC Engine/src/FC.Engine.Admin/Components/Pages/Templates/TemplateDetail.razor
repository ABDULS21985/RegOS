@page "/templates/{ReturnCode}"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize]
@using FC.Engine.Admin.Utilities
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Enums
@using FC.Engine.Domain.Metadata
@using FC.Engine.Domain.Validation
@using FC.Engine.Application.DTOs
@using FC.Engine.Application.Services
@inject ITemplateMetadataCache Cache
@inject IXsdGenerator XsdGenerator
@inject TemplateService TemplateService
@inject TemplateVersioningService VersioningService
@inject IFormulaRepository FormulaRepo
@inject NavigationManager Nav
@inject ToastService Toast
@inject DialogService Dialog

<PageHeader Title="@(_detail?.Name ?? ReturnCode)"
            Subtitle="@(_detail != null ? $"{_detail.ReturnCode} — {FormatFrequency(_detail.Frequency)} template · {_detail.StructuralCategory} structure" : null)"
            StatusBadge="@_activeVersion?.Status"
            StatusVariant="@(_activeVersion?.Status switch { "Published" => "success", "Review" => "warning", "Draft" => "neutral", _ => "neutral" })"
            BackUrl="/templates">
    <PrimaryAction>
        @if (_activeVersion?.Status == "Draft")
        {
            <AuthorizeView Policy="CanEditTemplates">
                <Authorized>
                    <button class="fc-btn fc-btn--outline fc-btn--sm" @onclick="SubmitForReview">Submit for Review</button>
                </Authorized>
            </AuthorizeView>
        }
        @if (_activeVersion?.Status == "Review")
        {
            <AuthorizeView Policy="CanPublishTemplates">
                <Authorized>
                    <button class="fc-btn fc-btn--outline fc-btn--sm" @onclick="PreviewDdl">Preview DDL</button>
                    <button class="fc-btn fc-btn--primary fc-btn--sm" @onclick="PublishVersion">Publish</button>
                </Authorized>
            </AuthorizeView>
        }
        @if (_activeVersion?.Status == "Published")
        {
            <AuthorizeView Policy="CanEditTemplates">
                <Authorized>
                    <button class="fc-btn fc-btn--primary fc-btn--sm" @onclick="CreateDraftVersion">New Draft</button>
                </Authorized>
            </AuthorizeView>
        }
    </PrimaryAction>
</PageHeader>

<div class="fc-detail-page">

    @if (_loading)
    {
        <div class="fc-skel-detail" role="status" aria-label="Loading template">
            <div class="fc-skel-detail-hero">
                <div class="fc-skel fc-skel-text-xl" style="--skel-w:200px"></div>
                <div class="fc-skel fc-skel-text" style="--skel-w:300px"></div>
                <div class="fc-flex-row--gap3 fc-mt-2">
                    <div class="fc-skel" style="--skel-w:80px;--skel-h:24px"></div>
                    <div class="fc-skel" style="--skel-w:70px;--skel-h:24px"></div>
                    <div class="fc-skel" style="--skel-w:90px;--skel-h:24px"></div>
                </div>
            </div>
            <div class="fc-skel-detail-tabs">
                @for (var i = 0; i < 5; i++)
                {
                    <div class="fc-skel fc-skel-detail-tab" style="--skel-w:@(60 + i * 10)px"></div>
                }
            </div>
            <div class="fc-skel-detail-section">
                @for (var i = 0; i < 4; i++)
                {
                    <div class="fc-skel fc-skel-text" style="--skel-w:@(40 + i * 20)%"></div>
                }
            </div>
        </div>
    }
    else if (_detail == null)
    {
        <div class="fc-alert fc-alert--inline fc-alert--error">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
            Template not found: @ReturnCode
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <AppAlert Variant="AppAlert.AlertVariant.Error" Message="@_errorMessage" Dismissible="true" OnDismiss="() => _errorMessage = null" />
        }

        <!-- KPI Stat Cards -->
        <div class="fc-td-kpi-grid">
            <div class="fc-td-kpi" style="--td-kpi-accent:#006B3F;--td-kpi-bg:rgba(0,107,63,0.08);">
                <div class="fc-td-kpi__icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                </div>
                <div class="fc-td-kpi__body">
                    <div class="fc-td-kpi__value"><code class="fc-tpl-code">@_detail.ReturnCode</code></div>
                    <div class="fc-td-kpi__label">Return Code</div>
                </div>
            </div>
            <div class="fc-td-kpi" style="--td-kpi-accent:#8B5CF6;--td-kpi-bg:rgba(139,92,246,0.08);">
                <div class="fc-td-kpi__icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                </div>
                <div class="fc-td-kpi__body">
                    <div class="fc-td-kpi__value">@(_activeVersion?.FieldCount ?? 0)</div>
                    <div class="fc-td-kpi__label">Fields</div>
                    <div class="fc-td-kpi__sub">@_detail.StructuralCategory structure</div>
                </div>
            </div>
            <div class="fc-td-kpi" style="--td-kpi-accent:#3B82F6;--td-kpi-bg:rgba(59,130,246,0.08);">
                <div class="fc-td-kpi__icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/><line x1="10" y1="3" x2="8" y2="21"/><line x1="16" y1="3" x2="14" y2="21"/></svg>
                </div>
                <div class="fc-td-kpi__body">
                    <div class="fc-td-kpi__value">@(_activeVersion?.FormulaCount ?? 0)</div>
                    <div class="fc-td-kpi__label">Formulas</div>
                    <div class="fc-td-kpi__sub">@_crossSheetRules.Count cross-sheet</div>
                </div>
            </div>
            <div class="fc-td-kpi" style="--td-kpi-accent:@VersionAccentColor();--td-kpi-bg:@VersionBgColor();">
                <div class="fc-td-kpi__icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
                <div class="fc-td-kpi__body">
                    <div class="fc-td-kpi__value">v@(_activeVersion?.VersionNumber ?? 0)</div>
                    <div class="fc-td-kpi__label">@(_activeVersion?.Status ?? "No Version")</div>
                    <div class="fc-td-kpi__sub">@_detail.Versions.Count version(s) total</div>
                </div>
            </div>
            <div class="fc-td-kpi" style="--td-kpi-accent:#F59E0B;--td-kpi-bg:rgba(245,158,11,0.08);">
                <div class="fc-td-kpi__icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>
                </div>
                <div class="fc-td-kpi__body">
                    <div class="fc-td-kpi__value"><code class="fc-tpl-table-name">@_detail.PhysicalTableName</code></div>
                    <div class="fc-td-kpi__label">Physical Table</div>
                    <div class="fc-td-kpi__sub">@FormatFrequency(_detail.Frequency) frequency</div>
                </div>
            </div>
        </div>

        <!-- Tabbed Navigation -->
        <div class="fc-tabs" role="tablist" aria-label="Template sections">
            <button class="fc-tab @(_activeTab == "overview" ? "fc-tab-active" : "")"
                    role="tab" aria-selected="@(_activeTab == "overview")" @onclick='() => _activeTab = "overview"'>
                Overview
            </button>
            <button class="fc-tab @(_activeTab == "fields" ? "fc-tab-active" : "")"
                    role="tab" aria-selected="@(_activeTab == "fields")" @onclick='() => _activeTab = "fields"'>
                Fields
                <span class="fc-tab-badge">@(_activeVersion?.FieldCount ?? 0)</span>
            </button>
            <button class="fc-tab @(_activeTab == "formulas" ? "fc-tab-active" : "")"
                    role="tab" aria-selected="@(_activeTab == "formulas")" @onclick='() => _activeTab = "formulas"'>
                Formulas
                <span class="fc-tab-badge">@(_activeVersion?.FormulaCount ?? 0)</span>
            </button>
            @if (_activeVersion?.ItemCodes.Any() == true)
            {
                <button class="fc-tab @(_activeTab == "itemcodes" ? "fc-tab-active" : "")"
                        role="tab" aria-selected="@(_activeTab == "itemcodes")" @onclick='() => _activeTab = "itemcodes"'>
                    Item Codes
                    <span class="fc-tab-badge">@_activeVersion.ItemCodes.Count</span>
                </button>
            }
            <button class="fc-tab @(_activeTab == "versions" ? "fc-tab-active" : "")"
                    role="tab" aria-selected="@(_activeTab == "versions")" @onclick='() => _activeTab = "versions"'>
                Versions
                <span class="fc-tab-badge">@_detail.Versions.Count</span>
            </button>
            <button class="fc-tab @(_activeTab == "settings" ? "fc-tab-active" : "")"
                    role="tab" aria-selected="@(_activeTab == "settings")" @onclick='() => _activeTab = "settings"'>
                Settings
            </button>
        </div>

        <!-- Tab: Overview -->
        <div class="fc-tab-content @(_activeTab == "overview" ? "fc-tab-content-active" : "")" role="tabpanel">
            <div class="fc-td-overview-grid">
                <section class="rg-premium-panel">
                    <div class="rg-premium-panel__header">
                        <div>
                            <div class="rg-premium-panel__eyebrow">Template identity</div>
                            <h2 class="rg-premium-panel__title">@_detail.Name</h2>
                        </div>
                    </div>
                    <div class="rg-premium-panel__body">
                        <div class="rg-premium-list">
                            <article class="rg-premium-list__item">
                                <div class="rg-premium-list__top">
                                    <div class="rg-premium-list__heading">Return Code</div>
                                    <div class="rg-premium-list__value"><code class="fc-tpl-code">@_detail.ReturnCode</code></div>
                                </div>
                            </article>
                            <article class="rg-premium-list__item">
                                <div class="rg-premium-list__top">
                                    <div class="rg-premium-list__heading">Physical Table</div>
                                    <div class="rg-premium-list__value"><code class="fc-tpl-table-name">@_detail.PhysicalTableName</code></div>
                                </div>
                            </article>
                            <article class="rg-premium-list__item">
                                <div class="rg-premium-list__top">
                                    <div class="rg-premium-list__heading">Frequency</div>
                                    <div class="rg-premium-list__value">@FormatFrequency(_detail.Frequency)</div>
                                </div>
                            </article>
                            <article class="rg-premium-list__item">
                                <div class="rg-premium-list__top">
                                    <div class="rg-premium-list__heading">Structure</div>
                                    <div class="rg-premium-list__value"><span class="fc-badge @CategoryBadge(_detail.StructuralCategory)">@_detail.StructuralCategory</span></div>
                                </div>
                            </article>
                            <article class="rg-premium-list__item">
                                <div class="rg-premium-list__top">
                                    <div class="rg-premium-list__heading">Created</div>
                                    <div class="rg-premium-list__value">@_detail.CreatedAt.ToString("d MMM yyyy")</div>
                                </div>
                            </article>
                        </div>
                    </div>
                </section>

                @if (_activeVersion != null)
                {
                    <section class="rg-premium-panel">
                        <div class="rg-premium-panel__header">
                            <div>
                                <div class="rg-premium-panel__eyebrow">Active version</div>
                                <h2 class="rg-premium-panel__title">Version @_activeVersion.VersionNumber</h2>
                            </div>
                            <span class="fc-detail-status fc-detail-status-@_activeVersion.Status.ToLowerInvariant()">
                                <span class="fc-detail-status-dot" aria-hidden="true"></span>
                                @_activeVersion.Status
                            </span>
                        </div>
                        <div class="rg-premium-panel__body">
                            <div class="fc-td-version-stats">
                                <div class="fc-td-version-stat">
                                    <div class="fc-td-version-stat__value">@_activeVersion.FieldCount</div>
                                    <div class="fc-td-version-stat__label">Fields</div>
                                </div>
                                <div class="fc-td-version-stat">
                                    <div class="fc-td-version-stat__value">@_activeVersion.FormulaCount</div>
                                    <div class="fc-td-version-stat__label">Formulas</div>
                                </div>
                                <div class="fc-td-version-stat">
                                    <div class="fc-td-version-stat__value">@_activeVersion.ItemCodes.Count</div>
                                    <div class="fc-td-version-stat__label">Item Codes</div>
                                </div>
                            </div>

                            @if (_activeVersion.ApprovedBy != null || _activeVersion.PublishedAt.HasValue || _activeVersion.ChangeSummary != null)
                            {
                                <div class="rg-premium-list" style="margin-top:var(--space-4);">
                                    @if (_activeVersion.PublishedAt.HasValue)
                                    {
                                        <article class="rg-premium-list__item">
                                            <div class="rg-premium-list__top">
                                                <div class="rg-premium-list__heading">Published</div>
                                                <div class="rg-premium-list__value">@_activeVersion.PublishedAt.Value.ToString("d MMM yyyy, HH:mm")</div>
                                            </div>
                                        </article>
                                    }
                                    @if (_activeVersion.ApprovedBy != null)
                                    {
                                        <article class="rg-premium-list__item">
                                            <div class="rg-premium-list__top">
                                                <div class="rg-premium-list__heading">Approved by</div>
                                                <div class="rg-premium-list__value">@_activeVersion.ApprovedBy</div>
                                            </div>
                                        </article>
                                    }
                                    @if (_activeVersion.ChangeSummary != null)
                                    {
                                        <article class="rg-premium-list__item">
                                            <div class="rg-premium-list__top">
                                                <div class="rg-premium-list__heading">Change summary</div>
                                            </div>
                                            <div class="rg-premium-list__meta">@_activeVersion.ChangeSummary</div>
                                        </article>
                                    }
                                </div>
                            }
                        </div>
                    </section>
                }
            </div>
        </div>

        <!-- Tab: Fields -->
        <div class="fc-tab-content @(_activeTab == "fields" ? "fc-tab-content-active" : "")" role="tabpanel">
            <div class="fc-section">
                <div class="fc-section-header">
                    <h3>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                        Template Fields (@(_activeVersion?.Fields.Count ?? 0))
                    </h3>
                    @if (_activeVersion?.Status == "Draft")
                    {
                        <AuthorizeView Policy="CanEditTemplates">
                            <Authorized>
                                <button class="fc-btn fc-btn--primary fc-btn--sm" @onclick="ShowAddField">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                    Add Field
                                </button>
                            </Authorized>
                        </AuthorizeView>
                    }
                </div>

                @if (_showAddField && _activeVersion?.Status == "Draft")
                {
                    <div class="fc-detail-add-panel">
                        <h3>@(_editingFieldId.HasValue ? "Edit Field" : "Add New Field")</h3>
                        <div class="fc-detail-add-grid">
                            <div class="fc-detail-float-field">
                                <input class="fc-detail-float-input" placeholder=" " @bind="_newField.FieldName" />
                                <label class="fc-detail-float-label">Field Name</label>
                            </div>
                            <div class="fc-detail-float-field">
                                <input class="fc-detail-float-input" placeholder=" " @bind="_newField.DisplayName" />
                                <label class="fc-detail-float-label">Display Name</label>
                            </div>
                            <div class="fc-detail-float-field">
                                <input class="fc-detail-float-input" placeholder=" " @bind="_newField.XmlElementName" />
                                <label class="fc-detail-float-label">XML Element</label>
                            </div>
                            <div class="fc-detail-float-field">
                                <input class="fc-detail-float-input" placeholder=" " @bind="_newField.LineCode" />
                                <label class="fc-detail-float-label">Line Code</label>
                            </div>
                            <div class="fc-detail-float-field">
                                <select class="fc-detail-float-input" @bind="_newFieldDataType">
                                    @foreach (var dt in Enum.GetValues<FieldDataType>())
                                    {
                                        <option value="@dt">@dt</option>
                                    }
                                </select>
                                <label class="fc-detail-float-label">Data Type</label>
                            </div>
                            <div class="fc-detail-float-field">
                                <input type="number" class="fc-detail-float-input" placeholder=" " @bind="_newField.FieldOrder" />
                                <label class="fc-detail-float-label">Field Order</label>
                            </div>
                            <div class="fc-detail-float-field">
                                <input class="fc-detail-float-input" placeholder=" " @bind="_newField.SectionName" />
                                <label class="fc-detail-float-label">Section (optional)</label>
                            </div>
                            <div class="fc-detail-float-field">
                                <input type="number" class="fc-detail-float-input" placeholder=" " @bind="_newField.SectionOrder" />
                                <label class="fc-detail-float-label">Section Order</label>
                            </div>
                            <div class="fc-detail-float-field">
                                <select class="fc-detail-float-input" @bind="_newFieldRequired">
                                    <option value="false">No</option>
                                    <option value="true">Yes</option>
                                </select>
                                <label class="fc-detail-float-label">Required</label>
                            </div>
                            <div class="fc-detail-float-field">
                                <select class="fc-detail-float-input" @bind="_newFieldIsKeyField">
                                    <option value="false">No</option>
                                    <option value="true">Yes</option>
                                </select>
                                <label class="fc-detail-float-label">Key Field</label>
                            </div>
                            <div class="fc-detail-float-field">
                                <select class="fc-detail-float-input" @bind="_newFieldIsComputed">
                                    <option value="false">No</option>
                                    <option value="true">Yes</option>
                                </select>
                                <label class="fc-detail-float-label">Computed</label>
                            </div>
                        </div>
                        <div class="fc-detail-add-actions">
                            <button class="fc-btn fc-btn--primary fc-btn--sm" @onclick="SaveField">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                                @(_editingFieldId.HasValue ? "Save Field" : "Add Field")
                            </button>
                            <button class="fc-btn fc-btn--outline fc-btn--sm" @onclick="CloseFieldEditor">Cancel</button>
                        </div>
                    </div>
                }

                @if (_activeVersion?.Fields.Any() == true)
                {
                    <div class="fc-overflow-x">
                        <table class="fc-detail-field-table">
                            <thead>
                                <tr>
                                    <th class="fc-th-reorder" aria-label="Reorder"></th>
                                    <th>#</th>
                                    <th>Field Name</th>
                                    <th>Display Name</th>
                                    <th>Line Code</th>
                                    <th>Data Type</th>
                                    <th>SQL Type</th>
                                    <th>Required</th>
                                    <th>Flags</th>
                                    @if (_activeVersion?.Status == "Draft")
                                    {
                                        <AuthorizeView Policy="CanEditTemplates">
                                            <Authorized>
                                                <th>Actions</th>
                                            </Authorized>
                                        </AuthorizeView>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var f in _activeVersion?.Fields ?? Enumerable.Empty<TemplateFieldDto>())
                                {
                                    <tr>
                                        <td class="fc-detail-field-drag" aria-label="Drag to reorder">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="8" y1="6" x2="8" y2="6.01"/><line x1="8" y1="12" x2="8" y2="12.01"/><line x1="8" y1="18" x2="8" y2="18.01"/><line x1="16" y1="6" x2="16" y2="6.01"/><line x1="16" y1="12" x2="16" y2="12.01"/><line x1="16" y1="18" x2="16" y2="18.01"/></svg>
                                        </td>
                                        <td>@f.FieldOrder</td>
                                        <td><code>@f.FieldName</code></td>
                                        <td>@f.DisplayName</td>
                                        <td>@f.LineCode</td>
                                        <td><span class="fc-badge fc-badge--info">@f.DataType</span></td>
                                        <td><code>@f.SqlType</code></td>
                                        <td>
                                            @if (f.IsRequired)
                                            {
                                                <svg viewBox="0 0 24 24" fill="none" stroke="var(--cbn-success)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-label="Required"><polyline points="20 6 9 17 4 12"/></svg>
                                            }
                                        </td>
                                        <td>
                                            <div class="fc-flex-row--gap1">
                                                @if (f.IsKeyField) { <span class="fc-badge fc-badge--success">Key</span> }
                                                @if (f.IsComputed) { <span class="fc-badge fc-badge--review">Computed</span> }
                                            </div>
                                        </td>
                                        @if (_activeVersion?.Status == "Draft")
                                        {
                                            <AuthorizeView Policy="CanEditTemplates">
                                                <Authorized>
                                                    <td>
                                                        <div class="fc-flex-row--gap1">
                                                            <button class="fc-btn fc-btn--ghost fc-btn--xs" @onclick="() => EditField(f)">Edit</button>
                                                            <button class="fc-btn fc-btn--ghost fc-btn--xs" @onclick="() => DeleteField(f)">Delete</button>
                                                        </div>
                                                    </td>
                                                </Authorized>
                                            </AuthorizeView>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="fc-detail-empty">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                        <p class="fc-detail-empty-title">No fields defined</p>
                        <p class="fc-detail-empty-text">Add fields to this template version to define the data structure.</p>
                    </div>
                }
            </div>
        </div>

        <!-- Tab: Formulas -->
        <div class="fc-tab-content @(_activeTab == "formulas" ? "fc-tab-content-active" : "")" role="tabpanel">
            <div class="fc-section">
                <div class="fc-section-header">
                    <h3>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/><line x1="10" y1="3" x2="8" y2="21"/><line x1="16" y1="3" x2="14" y2="21"/></svg>
                        Intra-Sheet Formulas
                    </h3>
                    <a href="/formulas" class="fc-btn fc-btn--outline fc-btn--sm">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                        Manage Formulas
                    </a>
                </div>
                <div class="fc-section-body">
                    @if (_formulas.Any())
                    {
                        <div class="fc-overflow-x">
                            <table class="fc-detail-field-table">
                                <thead>
                                    <tr>
                                        <th>Rule Code</th>
                                        <th>Name</th>
                                        <th>Type</th>
                                        <th>Target</th>
                                        <th>Severity</th>
                                        <th>Active</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var f in _formulas)
                                    {
                                        <tr>
                                            <td><code>@f.RuleCode</code></td>
                                            <td>@f.RuleName</td>
                                            <td><span class="fc-badge @FormulaBadge(f.FormulaType.ToString())">@f.FormulaType</span></td>
                                            <td><code>@f.TargetFieldName</code></td>
                                            <td>
                                                <span class="fc-badge @(f.Severity == ValidationSeverity.Error ? "fc-badge--danger" : f.Severity == ValidationSeverity.Warning ? "fc-badge--warning" : "fc-badge--info")">
                                                    @f.Severity
                                                </span>
                                            </td>
                                            <td>
                                                @if (f.IsActive)
                                                {
                                                    <svg viewBox="0 0 24 24" fill="none" stroke="var(--cbn-success)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-label="Active"><polyline points="20 6 9 17 4 12"/></svg>
                                                }
                                                else
                                                {
                                                    <svg viewBox="0 0 24 24" fill="none" stroke="var(--cbn-gray-400)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-label="Inactive"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="fc-detail-empty">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/><line x1="10" y1="3" x2="8" y2="21"/><line x1="16" y1="3" x2="14" y2="21"/></svg>
                            <p class="fc-detail-empty-title">No formulas</p>
                            <p class="fc-detail-empty-text">Intra-sheet formulas can be configured from the Formulas management page.</p>
                        </div>
                    }
                </div>
            </div>

            @if (_crossSheetRules.Any())
            {
                <div class="fc-section">
                    <div class="fc-section-header">
                        <h3>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                            Cross-Sheet Rules
                        </h3>
                    </div>
                    <div class="fc-section-body">
                        <div class="fc-overflow-x">
                            <table class="fc-detail-field-table">
                                <thead>
                                    <tr>
                                        <th>Rule Code</th>
                                        <th>Name</th>
                                        <th>Severity</th>
                                        <th>Active</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in _crossSheetRules)
                                    {
                                        <tr>
                                            <td><code>@r.RuleCode</code></td>
                                            <td>@r.RuleName</td>
                                            <td>
                                                <span class="fc-badge @(r.Severity == ValidationSeverity.Error ? "fc-badge--danger" : r.Severity == ValidationSeverity.Warning ? "fc-badge--warning" : "fc-badge--info")">
                                                    @r.Severity
                                                </span>
                                            </td>
                                            <td>
                                                @if (r.IsActive)
                                                {
                                                    <svg viewBox="0 0 24 24" fill="none" stroke="var(--cbn-success)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-label="Active"><polyline points="20 6 9 17 4 12"/></svg>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Tab: Item Codes -->
        @if (_activeVersion?.ItemCodes.Any() == true)
        {
            <div class="fc-tab-content @(_activeTab == "itemcodes" ? "fc-tab-content-active" : "")" role="tabpanel">
                <div class="fc-section">
                    <div class="fc-section-header">
                        <h3>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                            Item Codes (@_activeVersion.ItemCodes.Count)
                        </h3>
                    </div>
                    <div class="fc-overflow-x">
                        <table class="fc-detail-field-table">
                            <thead>
                                <tr>
                                    <th>Code</th>
                                    <th>Description</th>
                                    <th>Order</th>
                                    <th>Total Row</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ic in _activeVersion.ItemCodes)
                                {
                                    <tr>
                                        <td><code>@ic.ItemCode</code></td>
                                        <td>@ic.ItemName</td>
                                        <td>@ic.SortOrder</td>
                                        <td>
                                            @if (ic.IsTotalRow)
                                            {
                                                <svg viewBox="0 0 24 24" fill="none" stroke="var(--cbn-success)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-label="Total row"><polyline points="20 6 9 17 4 12"/></svg>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <!-- Tab: Versions -->
        <div class="fc-tab-content @(_activeTab == "versions" ? "fc-tab-content-active" : "")" role="tabpanel">
            <!-- Version Selector -->
            <div class="fc-section">
                <div class="fc-section-header">
                    <h3>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        Version Selector
                    </h3>
                </div>
                <div class="fc-section-body">
                    <div class="fc-flex-row--wrap">
                        @foreach (var v in _detail.Versions.OrderByDescending(v => v.VersionNumber))
                        {
                            <button class="fc-btn @(v.Id == _activeVersion?.Id ? "fc-btn--primary" : "fc-btn--outline") fc-btn--sm"
                                    @onclick="() => SelectVersion(v)">
                                v@(v.VersionNumber)
                                <span class="fc-detail-status fc-detail-status-@v.Status.ToLowerInvariant() fc-badge--xxs">
                                    @v.Status
                                </span>
                            </button>
                        }
                    </div>
                </div>
            </div>

            <!-- DDL Preview -->
            @if (_showDdlPreview && !string.IsNullOrEmpty(_ddlPreview))
            {
                <div class="fc-section">
                    <div class="fc-section-header">
                        <h3>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                            DDL Preview
                        </h3>
                        <button class="fc-btn fc-btn--outline fc-btn--sm" @onclick="() => _showDdlPreview = false">Hide</button>
                    </div>
                    <div class="fc-section-body">
                        <pre class="fc-detail-code-block">@_ddlPreview</pre>
                    </div>
                </div>
            }

            <!-- Version Timeline -->
            <div class="fc-section">
                <div class="fc-section-header">
                    <h3>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 8v4l3 3"/><circle cx="12" cy="12" r="10"/></svg>
                        Version History
                    </h3>
                </div>
                <div class="fc-section-body">
                    <div class="fc-detail-timeline" role="list" aria-label="Version history">
                        @foreach (var v in _detail.Versions.OrderByDescending(v => v.VersionNumber))
                        {
                            <div class="fc-detail-timeline-item" role="listitem">
                                <div class="fc-detail-timeline-dot fc-detail-timeline-dot-@v.Status.ToLowerInvariant()" aria-hidden="true"></div>
                                <div class="fc-detail-timeline-content">
                                    <div class="fc-detail-timeline-header">
                                        <span class="fc-detail-timeline-version">Version @v.VersionNumber</span>
                                        <span class="fc-detail-status fc-detail-status-@v.Status.ToLowerInvariant() fc-badge--xxs">
                                            <span class="fc-detail-status-dot" aria-hidden="true"></span>
                                            @v.Status
                                        </span>
                                    </div>
                                    <div class="fc-detail-timeline-meta">
                                        <span>@v.FieldCount fields</span>
                                        <span>@v.FormulaCount formulas</span>
                                        @if (v.PublishedAt.HasValue)
                                        {
                                            <span>Published @v.PublishedAt.Value.ToString("d MMM yyyy")</span>
                                        }
                                        @if (v.ApprovedBy != null)
                                        {
                                            <span>by @v.ApprovedBy</span>
                                        }
                                    </div>
                                    @if (v.ChangeSummary != null)
                                    {
                                        <p class="fc-detail-timeline-summary">@v.ChangeSummary</p>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Tab: Settings -->
        <div class="fc-tab-content @(_activeTab == "settings" ? "fc-tab-content-active" : "")" role="tabpanel">
            <div class="fc-section">
                <div class="fc-section-header">
                    <h3>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
                        Technical Configuration
                    </h3>
                </div>
                <div class="fc-section-body">
                    <div class="fc-detail-info-grid">
                        <div class="fc-detail-info-item">
                            <span class="fc-detail-info-label">Physical Table</span>
                            <span class="fc-detail-info-value"><code>@_detail.PhysicalTableName</code></span>
                        </div>
                        <div class="fc-detail-info-item">
                            <span class="fc-detail-info-label">XML Root Element</span>
                            <span class="fc-detail-info-value"><code>@_detail.XmlRootElement</code></span>
                        </div>
                        <div class="fc-detail-info-item">
                            <span class="fc-detail-info-label">XML Namespace</span>
                            <span class="fc-detail-info-value"><code>@_detail.XmlNamespace</code></span>
                        </div>
                        <div class="fc-detail-info-item">
                            <span class="fc-detail-info-label">XSD Schema</span>
                            <span class="fc-detail-info-value">
                                <button class="fc-btn fc-btn--outline fc-btn--sm" @onclick="ToggleXsd">
                                    @(_showXsd ? "Hide" : "Show") XSD
                                </button>
                            </span>
                        </div>
                    </div>

                    @if (_showXsd && !string.IsNullOrEmpty(_xsdContent))
                    {
                        <div class="fc-mt-4">
                            <pre class="fc-detail-code-block">@_xsdContent</pre>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string ReturnCode { get; set; } = "";
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private TemplateDetailDto? _detail;
    private TemplateVersionDto? _activeVersion;
    private string? _errorMessage;
    private string _activeTab = "overview";

    // Formulas
    private IReadOnlyList<IntraSheetFormula> _formulas = Array.Empty<IntraSheetFormula>();
    private IReadOnlyList<CrossSheetRule> _crossSheetRules = Array.Empty<CrossSheetRule>();

    // XSD
    private bool _showXsd;
    private string? _xsdContent;

    // DDL
    private bool _showDdlPreview;
    private string? _ddlPreview;

    // Add field
    private bool _showAddField;
    private int? _editingFieldId;
    private AddFieldRequest _newField = new();
    private FieldDataType _newFieldDataType = FieldDataType.Money;
    private string _newFieldRequired = "false";
    private string _newFieldIsKeyField = "false";
    private string _newFieldIsComputed = "false";
    private string _currentUser = string.Empty;

    private string CurrentUser => _currentUser;

    protected override async Task OnInitializedAsync()
    {
        _currentUser = await ResolveCurrentUserAsync();
        await LoadTemplate();
    }

    private async Task LoadTemplate()
    {
        _loading = true;
        CloseFieldEditor();
        _detail = await TemplateService.GetTemplateDetail(ReturnCode);
        if (_detail != null)
        {
            _activeVersion = _detail.Versions
                .OrderByDescending(v => v.Status == "Draft" ? 3 : v.Status == "Review" ? 2 : v.Status == "Published" ? 1 : 0)
                .ThenByDescending(v => v.VersionNumber)
                .FirstOrDefault();

            // Load formulas for the active version
            if (_activeVersion != null)
            {
                try
                {
                    _formulas = await FormulaRepo.GetIntraSheetFormulas(_activeVersion.Id);
                }
                catch { _formulas = Array.Empty<IntraSheetFormula>(); }
            }

            // Load cross-sheet rules for this template
            try
            {
                _crossSheetRules = await FormulaRepo.GetCrossSheetRulesForTemplate(ReturnCode);
            }
            catch { _crossSheetRules = Array.Empty<CrossSheetRule>(); }
        }
        _loading = false;
    }

    private async Task SelectVersion(TemplateVersionDto v)
    {
        _activeVersion = v;
        CloseFieldEditor();
        try { _formulas = await FormulaRepo.GetIntraSheetFormulas(v.Id); }
        catch { _formulas = Array.Empty<IntraSheetFormula>(); }
    }

    private async Task CreateDraftVersion()
    {
        try
        {
            await VersioningService.CreateNewDraftVersion(_detail!.Id, CurrentUser);
            Toast.Success("Draft version created. You can now add/modify fields.", "Version Created");
            await LoadTemplate();
        }
        catch (Exception ex) { SetError(ex.Message); }
    }

    private async Task SubmitForReview()
    {
        try
        {
            await VersioningService.SubmitForReview(_detail!.Id, _activeVersion!.Id, CurrentUser);
            Toast.Info("Version submitted for review.", "Submitted");
            await LoadTemplate();
        }
        catch (Exception ex) { SetError(ex.Message); }
    }

    private async Task PreviewDdl()
    {
        try
        {
            var ddl = await VersioningService.PreviewDdl(_detail!.Id, _activeVersion!.Id);
            _ddlPreview = ddl.ForwardSql;
            _showDdlPreview = true;
            _activeTab = "versions";
        }
        catch (Exception ex) { SetError(ex.Message); }
    }

    private async Task PublishVersion()
    {
        try
        {
            await VersioningService.Publish(_detail!.Id, _activeVersion!.Id, CurrentUser);
            Toast.Success("Version published successfully! Physical table created/updated.", "Published");
            _showDdlPreview = false;
            await LoadTemplate();
        }
        catch (Exception ex) { SetError(ex.Message); }
    }

    private void ShowAddField()
    {
        _showAddField = true;
        _editingFieldId = null;
        _activeTab = "fields";
        _newField = new AddFieldRequest
        {
            FieldOrder = (_activeVersion?.Fields.Count ?? 0) + 1
        };
        _newFieldDataType = FieldDataType.Money;
        _newFieldRequired = "false";
        _newFieldIsKeyField = "false";
        _newFieldIsComputed = "false";
    }

    private void CloseFieldEditor()
    {
        _showAddField = false;
        _editingFieldId = null;
    }

    private void EditField(TemplateFieldDto field)
    {
        _editingFieldId = field.Id;
        _showAddField = true;
        _activeTab = "fields";
        _newField = new AddFieldRequest
        {
            FieldName = field.FieldName,
            DisplayName = field.DisplayName,
            XmlElementName = field.XmlElementName,
            LineCode = field.LineCode,
            SectionName = field.SectionName,
            SectionOrder = field.SectionOrder,
            FieldOrder = field.FieldOrder,
            DataType = Enum.TryParse<FieldDataType>(field.DataType, true, out var parsedDataType) ? parsedDataType : FieldDataType.Text,
            IsRequired = field.IsRequired,
            IsComputed = field.IsComputed,
            IsKeyField = field.IsKeyField,
            DefaultValue = field.DefaultValue,
            MinValue = field.MinValue,
            MaxValue = field.MaxValue,
            MaxLength = field.MaxLength,
            AllowedValues = field.AllowedValues,
            HelpText = field.HelpText,
            ValidationNote = field.ValidationNote,
            RegulatoryReference = field.RegulatoryReference,
            DataClassification = Enum.TryParse<DataClassification>(field.DataClassification, true, out var parsedClassification) ? parsedClassification : DataClassification.Internal
        };
        _newFieldDataType = _newField.DataType;
        _newFieldRequired = _newField.IsRequired ? "true" : "false";
        _newFieldIsKeyField = _newField.IsKeyField ? "true" : "false";
        _newFieldIsComputed = _newField.IsComputed ? "true" : "false";
    }

    private async Task SaveField()
    {
        if (string.IsNullOrWhiteSpace(_newField.FieldName))
        {
            SetError("Field name is required.");
            return;
        }
        if (string.IsNullOrWhiteSpace(_newField.DisplayName))
        {
            SetError("Display name is required.");
            return;
        }

        try
        {
            _newField.DataType = _newFieldDataType;
            _newField.IsRequired = _newFieldRequired == "true";
            _newField.IsKeyField = _newFieldIsKeyField == "true";
            _newField.IsComputed = _newFieldIsComputed == "true";
            if (string.IsNullOrWhiteSpace(_newField.XmlElementName))
                _newField.XmlElementName = _newField.FieldName;

            if (_editingFieldId.HasValue)
            {
                await TemplateService.UpdateFieldInVersion(_detail!.Id, _activeVersion!.Id, _editingFieldId.Value, _newField, CurrentUser);
                Toast.Success($"Field '{_newField.FieldName}' updated successfully.", "Field Updated");
            }
            else
            {
                await TemplateService.AddFieldToVersion(_detail!.Id, _activeVersion!.Id, _newField, CurrentUser);
                Toast.Success($"Field '{_newField.FieldName}' added successfully.", "Field Added");
            }

            CloseFieldEditor();
            await LoadTemplate();
        }
        catch (Exception ex) { SetError(ex.Message); }
    }

    private async Task DeleteField(TemplateFieldDto field)
    {
        var confirmed = await Dialog.Confirm(new ConfirmRequest
        {
            Title = "Delete Field",
            Message = $"Delete field '{field.FieldName}' from this draft version?",
            ConfirmText = "Delete",
            IsDestructive = true,
            Icon = "delete"
        });

        if (!confirmed)
            return;

        try
        {
            await TemplateService.RemoveFieldFromVersion(_detail!.Id, _activeVersion!.Id, field.Id, CurrentUser);
            Toast.Success($"Field '{field.FieldName}' deleted successfully.", "Field Deleted");
            CloseFieldEditor();
            await LoadTemplate();
        }
        catch (Exception ex) { SetError(ex.Message); }
    }

    private async Task ToggleXsd()
    {
        _showXsd = !_showXsd;
        if (_showXsd && _xsdContent == null)
        {
            try { _xsdContent = await XsdGenerator.GenerateSchemaXml(ReturnCode); }
            catch { _xsdContent = "XSD generation not available for this template."; }
        }
    }

    private void SetError(string msg)
    {
        _errorMessage = msg;
    }

    private async Task<string> ResolveCurrentUserAsync()
    {
        var state = AuthState is null ? null : await AuthState;
        return UserIdentityResolver.ResolveActor(state?.User);
    }

    private static string FormatFrequency(string freq) => freq switch
    {
        "SemiAnnual" => "Semi-Annual",
        _ => freq
    };

    private static string CategoryBadge(string cat) => cat.ToLowerInvariant() switch
    {
        "fixedrow" => "fc-badge--purple",
        "multirow" => "fc-badge--teal",
        "itemcoded" => "fc-badge--pink",
        _ => "fc-badge--neutral"
    };

    private string VersionAccentColor() => _activeVersion?.Status switch
    {
        "Published" => "#22C55E",
        "Review" => "#F59E0B",
        "Draft" => "#6B7280",
        _ => "#6B7280"
    };

    private string VersionBgColor() => _activeVersion?.Status switch
    {
        "Published" => "rgba(34,197,94,0.08)",
        "Review" => "rgba(245,158,11,0.08)",
        "Draft" => "rgba(107,114,128,0.08)",
        _ => "rgba(107,114,128,0.08)"
    };

    private static string FormulaBadge(string type) => type.ToLowerInvariant() switch
    {
        "sum" => "fc-badge--success",
        "difference" => "fc-badge--info",
        "equals" => "fc-badge--purple",
        "custom" => "fc-badge--warning",
        "ratio" => "fc-badge--pink",
        "required" => "fc-badge--danger",
