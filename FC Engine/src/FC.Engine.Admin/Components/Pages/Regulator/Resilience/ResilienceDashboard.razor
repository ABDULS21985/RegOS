@page "/regulator/resilience"
@attribute [Authorize(Policy = "RegulatorOnly")]
@inject FC.Engine.Admin.Services.Resilience.ResilienceOrchestratorService ResService
@inject FC.Engine.Admin.Services.ToastService Toast

<PageTitle>Operational Resilience</PageTitle>

<PageHeader Title="Operational Resilience"
            Subtitle="Monitor important business services, incidents, third-party risk, and recovery readiness."
            BackUrl="/regulator">
    <PrimaryAction>
        <button class="fc-btn fc-btn--primary" @onclick="ReloadAsync" disabled="@_loading">Refresh</button>
    </PrimaryAction>
</PageHeader>

<div class="fc-page">
    <SectionErrorBoundary Title="Failed to load resilience data" ExternalError="@_loadException" OnRetry="ReloadAsync">
        @if (_loading)
        {
            <div class="rg-res-kpi-strip">
                @for (var i = 0; i < 4; i++)
                {
                    <div class="rg-res-kpi"><SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Block" Height="88px" /></div>
                }
            </div>
        }
        else if (_data is null)
        {
            <EmptyState Context="data" Heading="No resilience data" Description="Refresh the Intelligence Hub to load operational resilience data." />
        }
        else
        {
            <div class="rg-res-kpi-strip">
                <div class="rg-res-kpi">
                    <div class="rg-res-kpi-value">@_data.GapScore.ToString("F0")</div>
                    <div class="rg-res-kpi-label">Gap Score</div>
                </div>
                <div class="rg-res-kpi">
                    <div class="rg-res-kpi-value">@_data.ImportantServiceCount</div>
                    <div class="rg-res-kpi-label">Business Services</div>
                </div>
                <div class="rg-res-kpi">
                    <div class="rg-res-kpi-value @(_data.OpenIncidentCount > 0 ? "rg-res-kpi-value--red" : "rg-res-kpi-value--green")">@_data.OpenIncidentCount</div>
                    <div class="rg-res-kpi-label">Open Incidents</div>
                </div>
                <div class="rg-res-kpi">
                    <div class="rg-res-kpi-value">@_data.RcaCoveragePercent.ToString("F0")%</div>
                    <div class="rg-res-kpi-label">RCA Coverage</div>
                </div>
            </div>

            <div class="rg-hub-grid">
                <a class="rg-hub-card" href="/regulator/resilience/services" style="--stagger-i:0;">
                    <div class="rg-hub-card-icon rg-hub-icon--blue">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                    </div>
                    <h3 class="rg-hub-card-title">Business Services</h3>
                    <p class="rg-hub-card-desc">Important business services, criticality, and dependencies</p>
                </a>
                <a class="rg-hub-card" href="/regulator/resilience/tolerances" style="--stagger-i:1;">
                    <div class="rg-hub-card-icon rg-hub-icon--amber">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    </div>
                    <h3 class="rg-hub-card-title">Impact Tolerances</h3>
                    <p class="rg-hub-card-desc">Disruption tolerances and recovery targets by service</p>
                </a>
                <a class="rg-hub-card" href="/regulator/resilience/third-party" style="--stagger-i:2;">
                    <div class="rg-hub-card-icon rg-hub-icon--purple">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    </div>
                    <h3 class="rg-hub-card-title">Third-Party Risk</h3>
                    <p class="rg-hub-card-desc">Provider concentration, service criticality, and risk tiers</p>
                </a>
                <a class="rg-hub-card" href="/regulator/resilience/incidents" style="--stagger-i:3;">
                    <div class="rg-hub-card-icon rg-hub-icon--red">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true"><polygon points="7.86 2 16.14 2 22 7.86 22 16.14 16.14 22 7.86 22 2 16.14 2 7.86 7.86 2"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    </div>
                    <h3 class="rg-hub-card-title">Incident Management</h3>
                    <p class="rg-hub-card-desc">Incident timeline, lifecycle, and security alerts</p>
                </a>
                <a class="rg-hub-card" href="/regulator/resilience/testing" style="--stagger-i:4;">
                    <div class="rg-hub-card-icon rg-hub-icon--green">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                    </div>
                    <h3 class="rg-hub-card-title">Testing Schedule</h3>
                    <p class="rg-hub-card-desc">Scenario testing, recovery time tests, and BCP exercises</p>
                </a>
                <a class="rg-hub-card" href="/regulator/resilience/board" style="--stagger-i:5;">
                    <div class="rg-hub-card-icon rg-hub-icon--gold">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                    </div>
                    <h3 class="rg-hub-card-title">Board Oversight</h3>
                    <p class="rg-hub-card-desc">Executive summary, gap analysis, and action tracker</p>
                </a>
            </div>
        }
    </SectionErrorBoundary>
</div>

@code {
    private bool _loading = true;
    private Exception? _loadException;
    private FC.Engine.Admin.Services.Resilience.ResilienceDashboardData? _data;

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _loadException = null;
        try { _data = await ResService.GetDashboardAsync(); }
        catch (Exception ex) { _loadException = ex; }
        finally { _loading = false; }
    }
}
