@page "/regulator"
@attribute [Authorize(Policy = "RegulatorOnly")]

<PageTitle>Regulator Dashboard</PageTitle>

<PageHeader Title="Regulator Portal"
            Subtitle="Review submissions, run sector analytics, monitor early warnings, and manage examinations."
            StatusBadge="Operational" StatusVariant="success" />

<div class="fc-page">
    <div class="rg-hub-grid">
        <a class="rg-hub-card" href="/regulator/inbox" style="--stagger-i:0;">
            <div class="rg-hub-card-icon rg-hub-icon--blue">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true">
                    <polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/>
                    <path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/>
                </svg>
            </div>
            <h3 class="rg-hub-card-title">Submissions Inbox</h3>
            <p class="rg-hub-card-desc">Review and process incoming regulatory filings</p>
        </a>
        <a class="rg-hub-card" href="/regulator/warnings" style="--stagger-i:1;">
            <div class="rg-hub-card-icon rg-hub-icon--amber">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true">
                    <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/>
                    <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
            </div>
            <h3 class="rg-hub-card-title">Early Warnings</h3>
            <p class="rg-hub-card-desc">Monitor early warning flags across institutions</p>
        </a>
        <a class="rg-hub-card" href="/regulator/analytics" style="--stagger-i:2;">
            <div class="rg-hub-card-icon rg-hub-icon--green">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true">
                    <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>
                </svg>
            </div>
            <h3 class="rg-hub-card-title">Sector Analytics</h3>
            <p class="rg-hub-card-desc">CAR distribution, NPL trends, and filing heatmaps</p>
        </a>
        <a class="rg-hub-card" href="/regulator/systemic-risk" style="--stagger-i:3;">
            <div class="rg-hub-card-icon rg-hub-icon--red">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    <line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
            </div>
            <h3 class="rg-hub-card-title">Systemic Risk</h3>
            <p class="rg-hub-card-desc">Risk indices, CAMELS scores, and contagion analysis</p>
        </a>
        <a class="rg-hub-card" href="/regulator/stress-test" style="--stagger-i:4;">
            <div class="rg-hub-card-icon rg-hub-icon--purple">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true">
                    <path d="M9 3h6l1 7-4 2-4-2 1-7z"/><path d="M5 22s1-5 7-5 7 5 7 5"/><path d="M12 12v4"/>
                </svg>
            </div>
            <h3 class="rg-hub-card-title">Stress Testing</h3>
            <p class="rg-hub-card-desc">Run NGFS climate and macro-economic scenarios</p>
        </a>
        <a class="rg-hub-card" href="/regulator/cross-border" style="--stagger-i:5;">
            <div class="rg-hub-card-icon rg-hub-icon--teal">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                </svg>
            </div>
            <h3 class="rg-hub-card-title">Cross-Border</h3>
            <p class="rg-hub-card-desc">Pan-African dashboard and regulatory harmonisation</p>
        </a>
    </div>
</div>
