@page "/regulator/sanctions"
@attribute [Authorize(Policy = "RegulatorOnly")]
@inject FC.Engine.Admin.Services.Sanctions.ScreeningEngineService ScreeningEngine
@inject FC.Engine.Admin.Services.ToastService Toast

<PageTitle>Sanctions & AML</PageTitle>

<PageHeader Title="Sanctions & AML"
            Subtitle="Screen names and transactions, manage alerts, track watchlist sources, and review false positives."
            BackUrl="/regulator">
    <PrimaryAction>
        <button class="fc-btn fc-btn--primary" @onclick="ReloadAsync" disabled="@_loading">Refresh</button>
    </PrimaryAction>
</PageHeader>

<div class="fc-page">
    <SectionErrorBoundary Title="Failed to load sanctions data" ExternalError="@_loadException" OnRetry="ReloadAsync">
        @if (_loading)
        {
            <div class="rg-san-kpi-strip">
                @for (var i = 0; i < 4; i++)
                {
                    <div class="rg-san-kpi"><SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Block" Height="88px" /></div>
                }
            </div>
        }
        else if (_data is null)
        {
            <EmptyState Context="data" Heading="No sanctions data" Description="Refresh the Intelligence Hub to load sanctions watchlist data." />
        }
        else
        {
            <div class="rg-san-kpi-strip">
                <div class="rg-san-kpi">
                    <div class="rg-san-kpi-value">@_data.SourceCount</div>
                    <div class="rg-san-kpi-label">Watchlist Sources</div>
                </div>
                <div class="rg-san-kpi">
                    <div class="rg-san-kpi-value">@_data.EntryCount</div>
                    <div class="rg-san-kpi-label">Watchlist Entries</div>
                </div>
                <div class="rg-san-kpi">
                    <div class="rg-san-kpi-value">@_data.FalsePositiveCount</div>
                    <div class="rg-san-kpi-label">False Positives</div>
                </div>
                <div class="rg-san-kpi">
                    <div class="rg-san-kpi-value">@_data.ReviewAuditCount</div>
                    <div class="rg-san-kpi-label">Review Decisions</div>
                </div>
            </div>

            <div class="rg-hub-grid">
                <a class="rg-hub-card" href="/regulator/sanctions/screening" style="--stagger-i:0;">
                    <div class="rg-hub-card-icon rg-hub-icon--blue">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true">
                            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        </svg>
                    </div>
                    <h3 class="rg-hub-card-title">Screening</h3>
                    <p class="rg-hub-card-desc">Screen individual names or batch lists against watchlists</p>
                </a>
                <a class="rg-hub-card" href="/regulator/sanctions/alerts" style="--stagger-i:1;">
                    <div class="rg-hub-card-icon rg-hub-icon--red">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true">
                            <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                            <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                        </svg>
                    </div>
                    <h3 class="rg-hub-card-title">Alert Management</h3>
                    <p class="rg-hub-card-desc">Review active alerts, escalations, and resolved matches</p>
                </a>
                <a class="rg-hub-card" href="/regulator/sanctions/watchlists" style="--stagger-i:2;">
                    <div class="rg-hub-card-icon rg-hub-icon--green">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
                        </svg>
                    </div>
                    <h3 class="rg-hub-card-title">Watchlist Management</h3>
                    <p class="rg-hub-card-desc">View sources, entry counts, refresh cadence, and status</p>
                </a>
                <a class="rg-hub-card" href="/regulator/sanctions/false-positives" style="--stagger-i:3;">
                    <div class="rg-hub-card-icon rg-hub-icon--amber">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                            <polyline points="9 12 12 15 16 10"/>
                        </svg>
                    </div>
                    <h3 class="rg-hub-card-title">False Positive Library</h3>
                    <p class="rg-hub-card-desc">Reviewed false positive matches with decision audit trail</p>
                </a>
            </div>

            @if (_data.LatestRun is not null)
            {
                <div class="fc-card fc-card--mb" style="margin-top:var(--space-4);">
                    <div class="fc-card__header"><h2 class="fc-card__title">Latest Screening Run</h2></div>
                    <div class="fc-card__body">
                        <div class="rg-san-kpi-strip rg-san-kpi-strip--compact">
                            <div class="rg-san-kpi">
                                <div class="rg-san-kpi-value">@_data.LatestRun.TotalSubjects</div>
                                <div class="rg-san-kpi-label">Subjects Screened</div>
                            </div>
                            <div class="rg-san-kpi">
                                <div class="rg-san-kpi-value @(_data.LatestRun.MatchCount > 0 ? "rg-san-kpi-value--red" : "rg-san-kpi-value--green")">@_data.LatestRun.MatchCount</div>
                                <div class="rg-san-kpi-label">Matches Found</div>
                            </div>
                            <div class="rg-san-kpi">
                                <div class="rg-san-kpi-value">@_data.LatestRun.ThresholdPercent.ToString("F0")%</div>
                                <div class="rg-san-kpi-label">Threshold</div>
                            </div>
                            <div class="rg-san-kpi">
                                <div class="rg-san-kpi-value">@_data.LatestRun.ScreenedAt.ToString("dd MMM HH:mm")</div>
                                <div class="rg-san-kpi-label">Screened At</div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (_data.LatestTransaction is not null)
            {
                <div class="fc-card">
                    <div class="fc-card__header"><h2 class="fc-card__title">Latest Transaction Check</h2></div>
                    <div class="fc-card__body">
                        <div class="rg-san-kpi-strip rg-san-kpi-strip--compact">
                            <div class="rg-san-kpi">
                                <div class="rg-san-kpi-value">@_data.LatestTransaction.TransactionReference</div>
                                <div class="rg-san-kpi-label">Reference</div>
                            </div>
                            <div class="rg-san-kpi">
                                <div class="rg-san-kpi-value">@_data.LatestTransaction.Amount.ToString("N2") @_data.LatestTransaction.Currency</div>
                                <div class="rg-san-kpi-label">Amount</div>
                            </div>
                            <div class="rg-san-kpi">
                                <div class="rg-san-kpi-value">
                                    <span class="fc-badge @ControlBadge(_data.LatestTransaction.ControlDecision)">@_data.LatestTransaction.ControlDecision</span>
                                </div>
                                <div class="rg-san-kpi-label">Decision</div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </SectionErrorBoundary>
</div>

@code {
    private bool _loading = true;
    private Exception? _loadException;
    private FC.Engine.Admin.Services.Sanctions.ScreeningDashboardData? _data;

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _loadException = null;
        try
        {
            _data = await ScreeningEngine.GetDashboardAsync();
        }
        catch (Exception ex) { _loadException = ex; }
        finally { _loading = false; }
    }

    private static string ControlBadge(string decision) => decision switch
    {
        "Block" => "fc-badge--danger",
        "Escalate" => "fc-badge--warning",
        "Clear" => "fc-badge--success",
        _ => "fc-badge--neutral"
    };
}
