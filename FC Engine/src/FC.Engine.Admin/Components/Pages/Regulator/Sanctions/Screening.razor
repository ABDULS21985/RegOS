@page "/regulator/sanctions/screening"
@attribute [Authorize(Policy = "RegulatorOnly")]
@inject FC.Engine.Admin.Services.Sanctions.ScreeningEngineService ScreeningEngine
@inject FC.Engine.Admin.Services.ToastService Toast

<PageTitle>Sanctions Screening</PageTitle>

<PageHeader Title="Sanctions Screening"
            Subtitle="Screen individual names or batch lists against the sanctions watchlist using Jaro-Winkler, Levenshtein, and Soundex matching."
            BackUrl="/regulator/sanctions" />

<div class="fc-page">
    <div class="rg-grid rg-grid-2">
        @* Single Name Screening *@
        <div class="fc-card">
            <div class="fc-card__header"><h2 class="fc-card__title">Single Name Screening</h2></div>
            <div class="fc-card__body">
                <div class="fc-form-row">
                    <label class="fc-form-label">Subject Name</label>
                    <input type="text" class="fc-input" placeholder="Enter name to screen..." @bind="_singleName" />
                </div>
                <div class="fc-form-row" style="max-width:300px;">
                    <label class="fc-form-label">Match Threshold (%)</label>
                    <input type="range" min="60" max="99" step="1" @bind="_threshold" class="fc-input" />
                    <span class="fc-text-muted">@_threshold%</span>
                </div>
                <button class="fc-btn fc-btn--primary" style="width:100%;margin-top:var(--space-2);"
                        @onclick="ScreenSingleAsync"
                        disabled="@(_screening || string.IsNullOrWhiteSpace(_singleName))">
                    @if (_screening) { <span class="fc-spinner fc-spinner--xs"></span> }
                    Screen Name
                </button>
            </div>
        </div>

        @* Batch Screening *@
        <div class="fc-card">
            <div class="fc-card__header"><h2 class="fc-card__title">Batch Screening</h2></div>
            <div class="fc-card__body">
                <div class="fc-form-row">
                    <label class="fc-form-label">Names (one per line)</label>
                    <textarea class="fc-input" rows="6" placeholder="Enter one name per line..." @bind="_batchNames"></textarea>
                </div>
                <div class="fc-form-row" style="max-width:300px;">
                    <label class="fc-form-label">Match Threshold (%)</label>
                    <input type="range" min="60" max="99" step="1" @bind="_batchThreshold" class="fc-input" />
                    <span class="fc-text-muted">@_batchThreshold%</span>
                </div>
                <button class="fc-btn fc-btn--primary" style="width:100%;margin-top:var(--space-2);"
                        @onclick="ScreenBatchAsync"
                        disabled="@(_screening || string.IsNullOrWhiteSpace(_batchNames))">
                    @if (_screening) { <span class="fc-spinner fc-spinner--xs"></span> }
                    Screen Batch
                </button>
            </div>
        </div>
    </div>

    @* Screening Results *@
    @if (_screeningRun is not null)
    {
        <div class="fc-card fc-card--mb" style="margin-top:var(--space-4);">
            <div class="fc-card__header">
                <h2 class="fc-card__title">Screening Results</h2>
                <span class="fc-badge fc-badge--neutral" style="margin-left:var(--space-2);">@_screeningRun.ScreenedAt.ToString("dd MMM yyyy HH:mm")</span>
            </div>
            <div class="fc-card__body">
                <div class="rg-san-kpi-strip rg-san-kpi-strip--compact">
                    <div class="rg-san-kpi">
                        <div class="rg-san-kpi-value">@_screeningRun.TotalSubjects</div>
                        <div class="rg-san-kpi-label">Subjects</div>
                    </div>
                    <div class="rg-san-kpi">
                        <div class="rg-san-kpi-value @(_screeningRun.MatchCount > 0 ? "rg-san-kpi-value--red" : "rg-san-kpi-value--green")">
                            @_screeningRun.MatchCount
                        </div>
                        <div class="rg-san-kpi-label">Matches</div>
                    </div>
                    <div class="rg-san-kpi">
                        <div class="rg-san-kpi-value">@_screeningRun.ThresholdPercent.ToString("F0")%</div>
                        <div class="rg-san-kpi-label">Threshold</div>
                    </div>
                </div>

                <DataTable TItem="SanctionsScreeningResultRow"
                           Items="@_screeningRun.Results"
                           PageSize="20"
                           Sortable="true"
                           ShowExport="true"
                           ExportFileName="screening-results"
                           EmptyTitle="No matches"
                           EmptyText="All subjects cleared against the watchlist.">
                    <ChildContent>
                        <DataColumn TItem="SanctionsScreeningResultRow" Title="Subject" SortKey="@(x => x.Subject)">
                            <CellTemplate><strong>@context.Subject</strong></CellTemplate>
                        </DataColumn>
                        <DataColumn TItem="SanctionsScreeningResultRow" Title="Disposition" Width="130px" SortKey="@(x => x.Disposition)">
                            <CellTemplate>
                                <span class="fc-badge @DispositionBadge(context.Disposition)">@context.Disposition</span>
                            </CellTemplate>
                        </DataColumn>
                        <DataColumn TItem="SanctionsScreeningResultRow" Title="Score" Width="90px" SortKey="@(x => x.MatchScore)">
                            <CellTemplate>
                                <strong class="@(context.MatchScore >= 90 ? "rg-san-kpi-value--red" : context.MatchScore >= 80 ? "rg-san-kpi-value--amber" : "")">
                                    @context.MatchScore.ToString("F1")%
                                </strong>
                            </CellTemplate>
                        </DataColumn>
                        <DataColumn TItem="SanctionsScreeningResultRow" Title="Matched Name" SortKey="@(x => x.MatchedName)">
                            <CellTemplate>@context.MatchedName</CellTemplate>
                        </DataColumn>
                        <DataColumn TItem="SanctionsScreeningResultRow" Title="Source" Width="100px" SortKey="@(x => x.SourceCode)">
                            <CellTemplate><span class="fc-badge fc-badge--neutral">@context.SourceCode</span></CellTemplate>
                        </DataColumn>
                        <DataColumn TItem="SanctionsScreeningResultRow" Title="Category" Width="100px" SortKey="@(x => x.Category)">
                            <CellTemplate>@context.Category</CellTemplate>
                        </DataColumn>
                        <DataColumn TItem="SanctionsScreeningResultRow" Title="Risk" Width="90px" SortKey="@(x => x.RiskLevel)">
                            <CellTemplate>
                                <span class="fc-badge @RiskBadge(context.RiskLevel)">@context.RiskLevel</span>
                            </CellTemplate>
                        </DataColumn>
                    </ChildContent>
                </DataTable>
            </div>
        </div>
    }

    @* Transaction Screening *@
    <div class="fc-card" style="margin-top:var(--space-4);">
        <div class="fc-card__header"><h2 class="fc-card__title">Transaction Screening</h2></div>
        <div class="fc-card__body">
            <div class="rg-grid rg-grid-2">
                <div>
                    <div class="fc-form-row">
                        <label class="fc-form-label">Transaction Reference</label>
                        <input type="text" class="fc-input" @bind="_txRef" />
                    </div>
                    <div class="fc-form-row">
                        <label class="fc-form-label">Originator</label>
                        <input type="text" class="fc-input" @bind="_txOriginator" />
                    </div>
                    <div class="fc-form-row">
                        <label class="fc-form-label">Beneficiary</label>
                        <input type="text" class="fc-input" @bind="_txBeneficiary" />
                    </div>
                </div>
                <div>
                    <div class="fc-form-row">
                        <label class="fc-form-label">Amount</label>
                        <input type="number" class="fc-input" step="0.01" @bind="_txAmount" />
                    </div>
                    <div class="fc-form-row">
                        <label class="fc-form-label">Currency</label>
                        <input type="text" class="fc-input" @bind="_txCurrency" />
                    </div>
                    <div class="fc-form-row">
                        <label class="fc-form-label">Counterparty (optional)</label>
                        <input type="text" class="fc-input" @bind="_txCounterparty" />
                    </div>
                </div>
            </div>
            <div class="fc-form-row" style="margin-top:var(--space-2);">
                <label class="fc-form-label"><input type="checkbox" @bind="_txHighRisk" /> High-Risk Transaction</label>
            </div>
            <button class="fc-btn fc-btn--gold" style="margin-top:var(--space-2);"
                    @onclick="ScreenTransactionAsync"
                    disabled="@(_screening || string.IsNullOrWhiteSpace(_txOriginator) || string.IsNullOrWhiteSpace(_txBeneficiary))">
                @if (_screening) { <span class="fc-spinner fc-spinner--xs"></span> }
                Screen Transaction
            </button>
        </div>
    </div>

    @if (_txResult is not null)
    {
        <div class="fc-card" style="margin-top:var(--space-4);">
            <div class="fc-card__header">
                <h2 class="fc-card__title">Transaction Result: @_txResult.TransactionReference</h2>
                <span class="fc-badge @ControlBadge(_txResult.ControlDecision)" style="margin-left:var(--space-2);">@_txResult.ControlDecision</span>
            </div>
            <div class="fc-card__body">
                <p class="fc-text-muted">@_txResult.Narrative</p>

                <DataTable TItem="SanctionsTransactionPartyResult"
                           Items="@_txResult.PartyResults"
                           Sortable="true"
                           EmptyTitle="No party matches"
                           EmptyText="All parties cleared.">
                    <ChildContent>
                        <DataColumn TItem="SanctionsTransactionPartyResult" Title="Party Role" Width="120px" SortKey="@(x => x.PartyRole)">
                            <CellTemplate><strong>@context.PartyRole</strong></CellTemplate>
                        </DataColumn>
                        <DataColumn TItem="SanctionsTransactionPartyResult" Title="Party Name" SortKey="@(x => x.PartyName)">
                            <CellTemplate>@context.PartyName</CellTemplate>
                        </DataColumn>
                        <DataColumn TItem="SanctionsTransactionPartyResult" Title="Disposition" Width="130px" SortKey="@(x => x.Disposition)">
                            <CellTemplate>
                                <span class="fc-badge @DispositionBadge(context.Disposition)">@context.Disposition</span>
                            </CellTemplate>
                        </DataColumn>
                        <DataColumn TItem="SanctionsTransactionPartyResult" Title="Score" Width="90px" SortKey="@(x => x.MatchScore)">
                            <CellTemplate>@context.MatchScore.ToString("F1")%</CellTemplate>
                        </DataColumn>
                        <DataColumn TItem="SanctionsTransactionPartyResult" Title="Matched Name" SortKey="@(x => x.MatchedName)">
                            <CellTemplate>@context.MatchedName</CellTemplate>
                        </DataColumn>
                        <DataColumn TItem="SanctionsTransactionPartyResult" Title="Source" Width="100px" SortKey="@(x => x.SourceCode)">
                            <CellTemplate><span class="fc-badge fc-badge--neutral">@context.SourceCode</span></CellTemplate>
                        </DataColumn>
                        <DataColumn TItem="SanctionsTransactionPartyResult" Title="Risk" Width="90px" SortKey="@(x => x.RiskLevel)">
                            <CellTemplate><span class="fc-badge @RiskBadge(context.RiskLevel)">@context.RiskLevel</span></CellTemplate>
                        </DataColumn>
                    </ChildContent>
                </DataTable>
            </div>
        </div>
    }
</div>

@code {
    private bool _screening;
    private string _singleName = "";
    private double _threshold = 80;
    private string _batchNames = "";
    private double _batchThreshold = 80;
    private SanctionsScreeningRun? _screeningRun;

    // Transaction fields
    private string _txRef = "", _txOriginator = "", _txBeneficiary = "", _txCounterparty = "", _txCurrency = "NGN";
    private decimal _txAmount;
    private bool _txHighRisk;
    private SanctionsTransactionScreeningResult? _txResult;

    private async Task ScreenSingleAsync()
    {
        if (string.IsNullOrWhiteSpace(_singleName)) return;
        _screening = true;
        try
        {
            _screeningRun = await ScreeningEngine.ScreenNamesAsync(new[] { _singleName.Trim() }, _threshold / 100.0);
            Toast.Show(new ToastItem { Variant = ToastVariant.Success, Title = "Screening Complete", Message = $"{_screeningRun.MatchCount} match(es) found." });
        }
        catch (Exception ex) { Toast.Error("Screening failed: " + ex.Message); }
        finally { _screening = false; }
    }

    private async Task ScreenBatchAsync()
    {
        if (string.IsNullOrWhiteSpace(_batchNames)) return;
        _screening = true;
        try
        {
            var names = _batchNames.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            _screeningRun = await ScreeningEngine.ScreenNamesAsync(names, _batchThreshold / 100.0);
            Toast.Show(new ToastItem { Variant = ToastVariant.Success, Title = "Batch Screening Complete", Message = $"{_screeningRun.TotalSubjects} screened, {_screeningRun.MatchCount} match(es)." });
        }
        catch (Exception ex) { Toast.Error("Batch screening failed: " + ex.Message); }
        finally { _screening = false; }
    }

    private async Task ScreenTransactionAsync()
    {
        _screening = true;
        try
        {
            _txResult = await ScreeningEngine.ScreenTransactionAsync(new SanctionsTransactionScreeningRequest
            {
                TransactionReference = _txRef,
                Amount = _txAmount,
                Currency = _txCurrency,
                OriginatorName = _txOriginator,
                BeneficiaryName = _txBeneficiary,
                CounterpartyName = _txCounterparty,
                HighRisk = _txHighRisk
            });
            Toast.Show(new ToastItem
            {
                Variant = _txResult.ControlDecision == "Clear" ? ToastVariant.Success : ToastVariant.Warning,
                Title = "Transaction Screened",
                Message = $"Decision: {_txResult.ControlDecision}"
            });
        }
        catch (Exception ex) { Toast.Error("Transaction screening failed: " + ex.Message); }
        finally { _screening = false; }
    }

    private static string DispositionBadge(string d) => d switch
    {
        "Clear" => "fc-badge--success",
        "Potential Match" => "fc-badge--warning",
        "True Match" => "fc-badge--danger",
        _ => "fc-badge--neutral"
    };

    private static string RiskBadge(string r) => r switch
    {
        "critical" => "fc-badge--danger",
        "high" => "fc-badge--warning",
        "medium" => "fc-badge--info",
        _ => "fc-badge--neutral"
    };

    private static string ControlBadge(string d) => d switch
    {
        "Block" => "fc-badge--danger",
        "Escalate" => "fc-badge--warning",
        "Clear" => "fc-badge--success",
        _ => "fc-badge--neutral"
    };
}
