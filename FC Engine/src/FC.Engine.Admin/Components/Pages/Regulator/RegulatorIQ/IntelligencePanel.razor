@using System.Globalization

<aside class="regiq-panel @(_collapsed ? "regiq-panel--collapsed" : "") @(_isLoading ? "regiq-panel--loading" : "")" aria-label="Contextual intelligence panel">
    @if (_isLoading)
    {
        <!-- Loading skeleton -->
        <div class="regiq-panel__skeleton">
            <div class="regiq-panel__skeleton-header fc-skel">
                <div class="fc-skel__rect" style="width: 80px; height: 12px; margin-bottom: 8px;"></div>
                <div class="fc-skel__rect" style="width: 140px; height: 20px; margin-bottom: 4px;"></div>
                <div class="fc-skel__rect" style="width: 200px; height: 14px;"></div>
            </div>
            <div class="regiq-panel__skeleton-content fc-skel">
                <div class="fc-skel__rect" style="width: 100%; height: 80px; margin-bottom: 12px;"></div>
                <div class="fc-skel__rect" style="width: 100%; height: 60px; margin-bottom: 12px;"></div>
                <div class="fc-skel__rect" style="width: 70%; height: 40px;"></div>
            </div>
        </div>
    }
    else
    {
        <div class="regiq-panel__header regiq-panel__header--@CurrentScope.ToLowerInvariant()">
            <div class="regiq-panel__header-top">
                <div class="regiq-panel__header-icon" style="--rp-accent:@ResolveScopeColor(CurrentScope);">
                    <i class="bi @ResolveScopeIcon(CurrentScope)" aria-hidden="true"></i>
                </div>
                <div class="regiq-panel__header-text">
                    <span class="regiq-panel__eyebrow">Context Panel</span>
                    <h3 class="regiq-panel__title">Current supervisory picture</h3>
                </div>
                <button type="button" class="regiq-panel__toggle" @onclick="ToggleCollapsedAsync" aria-label="@(_collapsed ? "Expand panel" : "Collapse panel")">
                    <i class="bi bi-chevron-@(_collapsed ? "up" : "down")" aria-hidden="true"></i>
                </button>
            </div>
            <div class="regiq-panel__header-meta">
                <span class="regiq-panel__scope-badge" style="--rp-accent:@ResolveScopeColor(CurrentScope);">
                    <span class="regiq-panel__scope-dot"></span>
                    @ResolveScopeLabel(CurrentScope)
                </span>
                <span class="regiq-panel__subtitle">@ResolveSubtitle()</span>
            </div>
        </div>

    @if (EntityProfile is not null && CurrentScope.Equals("ENTITY", StringComparison.OrdinalIgnoreCase))
    {
        <div class="regiq-panel__quick-actions">
            <button type="button" class="regiq-panel__quick-action" @onclick='() => OnQuickQuery.InvokeAsync($"Generate an examination briefing for {EntityProfile.InstitutionName}")'>
                <i class="bi bi-clipboard-check"></i>
                <span>Examination Brief</span>
            </button>
            <button type="button" class="regiq-panel__quick-action" @onclick='() => OnQuickQuery.InvokeAsync($"Compare {EntityProfile.InstitutionName} with peer median on CAR and NPL")'>
                <i class="bi bi-bar-chart"></i>
                <span>Peer Compare</span>
            </button>
            <button type="button" class="regiq-panel__quick-action" @onclick='() => OnQuickQuery.InvokeAsync($"Show filing history for {EntityProfile.InstitutionName}")'>
                <i class="bi bi-clock"></i>
                <span>Filing History</span>
            </button>
        </div>
        <div class="regiq-panel__entity-card">
            <EntityProfileCard Profile="EntityProfile" Compact="true" OnDeepDive="OnDeepDive" />
        </div>
    }
    else if (SystemicDashboard is not null && CurrentScope.Equals("SYSTEMIC", StringComparison.OrdinalIgnoreCase))
    {
        <section class="regiq-panel__card regiq-panel__card--systemic">
            <div class="regiq-panel__gauge">
                <div class="regiq-panel__gauge-ring @ResolveGaugeTone(SystemicDashboard.Summary.SystemicRiskIndex)">
                    <svg class="regiq-panel__gauge-svg" viewBox="0 0 120 120">
                        <defs>
                            <linearGradient id="systemic-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" style="stop-color:#fef3c7;stop-opacity:0.8" />
                                <stop offset="100%" style="stop-color:#fed7aa;stop-opacity:0.6" />
                            </linearGradient>
                        </defs>
                        <circle cx="60" cy="60" r="50" fill="url(#systemic-gradient)" stroke="rgba(148, 163, 184, 0.2)" stroke-width="8"/>
                        <path d="M60,60 L60,10 A50,50 0 0,1 60,10 Z" fill="none" stroke="currentColor" stroke-width="8" stroke-linecap="round" transform="rotate(-90 60 60)" style="stroke-dasharray: @(Math.Clamp((double)SystemicDashboard.Summary.SystemicRiskIndex / 100.0 * 270.0, 0.0, 270.0)) 270; transition: stroke-dasharray 0.8s cubic-bezier(0.4, 0, 0.2, 1);"/>
                    </svg>
                    <div class="regiq-panel__gauge-content">
                        <strong class="regiq-panel__gauge-value">@SystemicDashboard.Summary.SystemicRiskIndex.ToString("N1", CultureInfo.InvariantCulture)</strong>
                        <span class="regiq-panel__gauge-label">Systemic Index</span>
                    </div>
                </div>
                <div class="regiq-panel__gauge-meta">
                    <div class="regiq-panel__meta-item">
                        <span class="regiq-panel__meta-label">Red-rated entities</span>
                        <strong class="regiq-panel__meta-value">@SystemicDashboard.Summary.RedCount</strong>
                    </div>
                    <div class="regiq-panel__meta-item">
                        <span class="regiq-panel__meta-label">Active flags</span>
                        <strong class="regiq-panel__meta-value">@SystemicDashboard.Summary.TotalActiveFlags</strong>
                    </div>
                </div>
            </div>

            @if (SystemicDashboard.SystemicIndicators.Count > 0)
            {
                <div class="regiq-panel__indicators">
                    <div class="regiq-panel__section-title">
                        <i class="bi bi-exclamation-triangle"></i>
                        Critical Indicators
                    </div>
                    <ul class="regiq-panel__list">
                        @foreach (var indicator in SystemicDashboard.SystemicIndicators.Take(4))
                        {
                            <li class="regiq-panel__indicator-item">
                                <div class="regiq-panel__indicator-badge">
                                    <span class="badge @ResolveRiskBadge(indicator.Severity.ToString())">@indicator.Severity.ToString().ToUpperInvariant()</span>
                                </div>
                                <div class="regiq-panel__indicator-content">
                                    <strong class="regiq-panel__indicator-title">@indicator.Title</strong>
                                    <div class="regiq-panel__indicator-value">
                                        <span class="regiq-panel__current-value">@indicator.CurrentValue.ToString("N1", CultureInfo.InvariantCulture)</span>
                                        <span class="regiq-panel__threshold">vs @indicator.Threshold.ToString("N1", CultureInfo.InvariantCulture)</span>
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            }

            <div class="regiq-panel__actions">
                <button type="button" class="regiq-panel__action-btn regiq-panel__action-btn--primary" @onclick="OpenSystemicDashboardAsync">
                    <i class="bi bi-activity"></i>
                    <span>Open systemic dashboard</span>
                </button>
            </div>
        </section>
    }
    else if (SectorSummary is not null)
    {
        <section class="regiq-panel__card regiq-panel__card--sector">
            <div class="regiq-panel__stats-grid">
                <div class="regiq-panel__kpi" style="--rpk-accent:#3B82F6;--rpk-bg:rgba(59,130,246,0.08);">
                    <div class="regiq-panel__kpi-icon"><i class="bi bi-building"></i></div>
                    <strong class="regiq-panel__kpi-value">@SectorSummary.EntityCount</strong>
                    <span class="regiq-panel__kpi-label">Entities</span>
                </div>
                <div class="regiq-panel__kpi" style="--rpk-accent:#22C55E;--rpk-bg:rgba(34,197,94,0.08);">
                    <div class="regiq-panel__kpi-icon"><i class="bi bi-shield-check"></i></div>
                    <strong class="regiq-panel__kpi-value">@FormatPercent(SectorSummary.AverageCarRatio)</strong>
                    <span class="regiq-panel__kpi-label">Avg CAR</span>
                </div>
                <div class="regiq-panel__kpi" style="--rpk-accent:#F59E0B;--rpk-bg:rgba(245,158,11,0.08);">
                    <div class="regiq-panel__kpi-icon"><i class="bi bi-graph-up"></i></div>
                    <strong class="regiq-panel__kpi-value">@FormatPercent(SectorSummary.AverageNplRatio)</strong>
                    <span class="regiq-panel__kpi-label">Avg NPL</span>
                </div>
                <div class="regiq-panel__kpi" style="--rpk-accent:#8B5CF6;--rpk-bg:rgba(139,92,246,0.08);">
                    <div class="regiq-panel__kpi-icon"><i class="bi bi-check-circle"></i></div>
                    <strong class="regiq-panel__kpi-value">@FormatScore(SectorSummary.AverageComplianceHealthScore)</strong>
                    <span class="regiq-panel__kpi-label">Avg CHS</span>
                </div>
            </div>

            <div class="regiq-panel__alerts">
                <div class="regiq-panel__alert @(SectorSummary.OverdueFilingCount > 0 ? "regiq-panel__alert--warn" : "regiq-panel__alert--ok")">
                    <div class="regiq-panel__alert-icon">
                        <i class="bi @(SectorSummary.OverdueFilingCount > 0 ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill")"></i>
                    </div>
                    <div class="regiq-panel__alert-body">
                        <span class="regiq-panel__alert-label">Overdue filings</span>
                        <strong class="regiq-panel__alert-value">@SectorSummary.OverdueFilingCount</strong>
                    </div>
                </div>
                <div class="regiq-panel__alert @(SectorSummary.HighRiskEntityCount > 0 ? "regiq-panel__alert--danger" : "regiq-panel__alert--ok")">
                    <div class="regiq-panel__alert-icon">
                        <i class="bi @(SectorSummary.HighRiskEntityCount > 0 ? "bi-shield-exclamation" : "bi-shield-check")"></i>
                    </div>
                    <div class="regiq-panel__alert-body">
                        <span class="regiq-panel__alert-label">High-risk entities</span>
                        <strong class="regiq-panel__alert-value">@SectorSummary.HighRiskEntityCount</strong>
                    </div>
                </div>
                <div class="regiq-panel__alert regiq-panel__alert--info">
                    <div class="regiq-panel__alert-icon"><i class="bi bi-funnel"></i></div>
                    <div class="regiq-panel__alert-body">
                        <span class="regiq-panel__alert-label">Licence filter</span>
                        <strong class="regiq-panel__alert-value" style="font-size:0.78rem;">@(string.IsNullOrWhiteSpace(SectorSummary.LicenceCategory) ? "All supervised" : SectorSummary.LicenceCategory)</strong>
                    </div>
                </div>
            </div>

            @if (SectorSummary.WatchList.Count > 0)
            {
                <div class="regiq-panel__watchlist">
                    <div class="regiq-panel__section-title">
                        <i class="bi bi-eye"></i>
                        Watch List
                    </div>
                    <ul class="regiq-panel__list">
                        @foreach (var item in SectorSummary.WatchList.Take(4))
                        {
                            <li class="regiq-panel__watch-item">
                                <button type="button"
                                        class="regiq-panel__watch-link"
                                        @onclick="() => OnDeepDive.InvokeAsync(item.InstitutionName)"
                                        aria-label="@($"Open full profile for {item.InstitutionName}")">
                                    <span class="regiq-panel__watch-name">@item.InstitutionName</span>
                                    <span class="badge @ResolveTrendBadge(item.Trend.ToString()) regiq-panel__watch-trend">@item.Trend.ToString().ToUpperInvariant()</span>
                                </button>
                            </li>
                        }
                    </ul>
                </div>
            }

            <div class="regiq-panel__actions">
                <button type="button" class="regiq-panel__action-btn regiq-panel__action-btn--secondary" @onclick="OpenSectorOverviewAsync">
                    <i class="bi bi-bar-chart"></i>
                    <span>Open sector overview</span>
                </button>
            </div>
        </section>
    }
    else
    {
        <div class="regiq-panel__empty">
            <div class="regiq-panel__empty-icon">
                <i class="bi bi-compass" aria-hidden="true"></i>
            </div>
            <div class="regiq-panel__empty-content">
                <h4 class="regiq-panel__empty-title">Intelligence Context</h4>
                <p class="regiq-panel__empty-text">Start a query to populate the right-hand intelligence panel with relevant supervisory data and insights.</p>
            </div>
        </div>
    }
    }
</aside>

@code {
    [Parameter] public string CurrentScope { get; set; } = "SECTOR";
    [Parameter] public EntityIntelligenceProfile? EntityProfile { get; set; }
    [Parameter] public SectorIntelligenceSummary? SectorSummary { get; set; }
    [Parameter] public SystemicRiskDashboard? SystemicDashboard { get; set; }
    [Parameter] public EventCallback<string> OnDeepDive { get; set; }
    [Parameter] public EventCallback<string> OnQuickQuery { get; set; }
    [Parameter] public bool Collapsed { get; set; }

    private bool _collapsed;
    private bool _isLoading;

    protected override void OnParametersSet()
    {
        _collapsed = Collapsed;
        // Simulate loading state for demo - in real app this would be based on data fetching
        _isLoading = EntityProfile == null && SectorSummary == null && SystemicDashboard == null && CurrentScope != "SECTOR";
    }

    private Task ToggleCollapsedAsync()
    {
        _collapsed = !_collapsed;
        return Task.CompletedTask;
    }

    private Task OpenSystemicDashboardAsync() => OnQuickQuery.InvokeAsync("Show me the systemic risk dashboard");
    private Task OpenSectorOverviewAsync() => OnQuickQuery.InvokeAsync("Show sector health summary");

    private string ResolveSubtitle()
    {
        return CurrentScope.ToUpperInvariant() switch
        {
            "ENTITY" when EntityProfile is not null => $"Pinned on {EntityProfile.InstitutionName}",
            "SYSTEMIC" when SystemicDashboard is not null => "System-wide risk posture from the current regulator dashboard",
            _ => "Sector-wide snapshot for the current regulator scope"
        };
    }

    private static string ResolveScopeLabel(string? scope) => scope?.ToUpperInvariant() switch
    {
        "ENTITY" => "Entity scope",
        "SYSTEMIC" => "Systemic scope",
        _ => "Sector scope"
    };

    private static string ResolveScopeColor(string? scope) => scope?.ToUpperInvariant() switch
    {
        "ENTITY" => "#8B5CF6",
        "SYSTEMIC" => "#EF4444",
        _ => "#22C55E"
    };

    private static string ResolveScopeIcon(string? scope) => scope?.ToUpperInvariant() switch
    {
        "ENTITY" => "bi-building",
        "SYSTEMIC" => "bi-activity",
        _ => "bi-bar-chart-line"
    };

    private static string FormatPercent(decimal? value) => value.HasValue ? $"{value.Value:N1}%" : "N/A";
    private static string FormatScore(decimal? value) => value.HasValue ? value.Value.ToString("N1", CultureInfo.InvariantCulture) : "N/A";

    private static string ResolveGaugeTone(decimal score)
    {
        if (score >= 70m)
        {
            return "regiq-panel__gauge-ring--danger";
        }

        if (score >= 40m)
        {
            return "regiq-panel__gauge-ring--warning";
        }

        return "regiq-panel__gauge-ring--success";
    }

    private static string ResolveRiskBadge(string? severity)
    {
        return severity?.ToUpperInvariant() switch
        {
            "RED" or "CRITICAL" or "HIGH" => "text-bg-danger",
            "AMBER" or "WARNING" or "MEDIUM" => "text-bg-warning",
            _ => "text-bg-success"
        };
    }

    private static string ResolveTrendClass(string? trend)
    {
        return trend?.ToUpperInvariant() switch
        {
            "INCREASING" => "regiq-panel__gauge-trend--up",
            "DECLINING" => "regiq-panel__gauge-trend--down",
            _ => "regiq-panel__gauge-trend--stable"
        };
    }

    private static string ResolveTrendIcon(string? trend)
    {
        return trend?.ToUpperInvariant() switch
        {
            "INCREASING" => "bi-arrow-up-circle-fill",
            "DECLINING" => "bi-arrow-down-circle-fill",
            _ => "bi-dash-circle-fill"
        };
    }

    private static string ResolveTrendText(string? trend)
    {
        return trend?.ToUpperInvariant() switch
        {
            "INCREASING" => "Rising",
            "DECLINING" => "Falling",
            _ => "Stable"
        };
    }

    private static string ResolveTrendBadge(string? trend)
    {
        return trend?.ToUpperInvariant() switch
        {
            "DECLINING" => "text-bg-danger",
            "STABLE" => "text-bg-warning",
            _ => "text-bg-success"
        };
    }

    private static string ResolveUrgencyClass(bool hasIssues)
    {
        return hasIssues ? "regiq-panel__summary-value--urgent" : "";
    }
}
