@page "/platform/tenants"
@attribute [Authorize(Policy = "PlatformAdmin")]
@using FC.Engine.Domain.Enums
@using Microsoft.AspNetCore.WebUtilities
@inject PlatformAdminService PlatformService
@inject TenantManagementService TenantManagementService
@inject NavigationManager Navigation

<PageTitle>Platform Tenants</PageTitle>

<section class="billing-shell">
    <header class="billing-hero">
        <div>
            <p class="billing-kicker">Platform Console</p>
            <h1>Global Tenant List</h1>
            <p>Search, filter, sort, export, and perform quick tenant actions.</p>
        </div>
        <div class="billing-hero-note">
            <button class="btn btn-outline btn-sm" @onclick="Export">Export Excel</button>
            <span>@DateTime.UtcNow.ToString("dd MMM yyyy HH:mm") UTC</span>
        </div>
    </header>

    <section class="card billing-surface">
        <div class="billing-toolbar billing-toolbar-wrap">
            <input class="form-control billing-search"
                   type="search"
                   placeholder="Search tenant name, slug, email"
                   @bind="_query.Search"
                   @bind:event="oninput"
                   @oninput="async _ => await Load()" />

            <select class="form-control billing-select" @bind="_query.Status" @onchange="async _ => await Load()">
                <option value="">All statuses</option>
                @foreach (var status in Enum.GetValues<TenantStatus>())
                {
                    <option value="@status.ToString()">@status</option>
                }
            </select>

            <select class="form-control billing-select" @bind="_query.PlanCode" @onchange="async _ => await Load()">
                <option value="">All plans</option>
                @foreach (var plan in _planOptions)
                {
                    <option value="@plan">@plan</option>
                }
            </select>

            <select class="form-control billing-select" @bind="_query.LicenceType" @onchange="async _ => await Load()">
                <option value="">All licence types</option>
                @foreach (var licence in _licenceOptions)
                {
                    <option value="@licence">@licence</option>
                }
            </select>

            <select class="form-control billing-select" @bind="_query.SortBy" @onchange="async _ => await Load()">
                <option value="name">Sort: Name</option>
                <option value="status">Sort: Status</option>
                <option value="plan">Sort: Plan</option>
                <option value="modules">Sort: Active modules</option>
                <option value="users">Sort: Users</option>
                <option value="entities">Sort: Entities</option>
                <option value="mrr">Sort: MRR</option>
                <option value="created">Sort: Created</option>
            </select>

            <label style="display:flex; align-items:center; gap:0.45rem;">
                <input type="checkbox" @bind="_query.SortDescending" @onchange="async _ => await Load()" />
                Desc
            </label>
        </div>
    </section>

    @if (_loading)
    {
        <section class="card billing-surface">
            <p>Loading tenants...</p>
        </section>
    }
    else
    {
        <section class="card billing-surface">
            <div class="billing-table-wrap">
                <table class="data-table billing-table">
                    <thead>
                        <tr>
                            <th>Tenant Name</th>
                            <th>Slug</th>
                            <th>Status</th>
                            <th>Plan</th>
                            <th>Active Modules</th>
                            <th>Users</th>
                            <th>Entities</th>
                            <th>MRR</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_tenants.Count == 0)
                        {
                            <tr>
                                <td colspan="10" class="billing-empty-cell">No tenants match current filters.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var tenant in _tenants)
                            {
                                <tr>
                                    <td>
                                        <div class="billing-plan-name">@tenant.TenantName</div>
                                        <div class="billing-plan-code">@tenant.LicenceType</div>
                                    </td>
                                    <td><code>@tenant.TenantSlug</code></td>
                                    <td><span class="badge @GetBadge(tenant.Status)">@tenant.Status</span></td>
                                    <td>@tenant.PlanName</td>
                                    <td>@tenant.ActiveModules</td>
                                    <td>@tenant.Users</td>
                                    <td>@tenant.Entities</td>
                                    <td>@tenant.Mrr.ToString("N2")</td>
                                    <td>@tenant.CreatedAt.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        <div class="billing-actions-grid">
                                            <button class="btn btn-outline btn-sm" @onclick="() => OpenTenant(tenant.TenantId)">View</button>
                                            <button class="btn btn-primary btn-sm" @onclick="() => Impersonate(tenant.TenantId)">Impersonate</button>
                                            @if (tenant.Status == TenantStatus.Active)
                                            {
                                                <button class="btn btn-danger btn-sm" @onclick="() => Suspend(tenant.TenantId)">Suspend</button>
                                            }
                                            @if (tenant.Status == TenantStatus.PendingActivation || tenant.Status == TenantStatus.Suspended)
                                            {
                                                <button class="btn btn-success btn-sm" @onclick="() => Activate(tenant.TenantId)">Activate</button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
</section>

@code {
    private readonly PlatformTenantListQuery _query = new();
    private List<PlatformTenantListItem> _tenants = new();
    private List<string> _planOptions = new();
    private List<string> _licenceOptions = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        _loading = true;
        var result = await PlatformService.GetTenantList(_query);
        _tenants = result.Tenants;
        _planOptions = result.PlanOptions;
        _licenceOptions = result.LicenceOptions;
        _loading = false;
    }

    private void OpenTenant(Guid tenantId)
    {
        Navigation.NavigateTo($"/platform/tenants/{tenantId}");
    }

    private void Impersonate(Guid tenantId)
    {
        Navigation.NavigateTo($"/platform/impersonate?tenantId={tenantId}", forceLoad: true);
    }

    private async Task Activate(Guid tenantId)
    {
        await TenantManagementService.ActivateTenantAsync(tenantId);
        await Load();
    }

    private async Task Suspend(Guid tenantId)
    {
        await TenantManagementService.SuspendTenantAsync(tenantId);
        await Load();
    }

    private void Export()
    {
        var query = new Dictionary<string, string?>
        {
            ["search"] = _query.Search,
            ["status"] = _query.Status,
            ["plan"] = _query.PlanCode,
            ["licence"] = _query.LicenceType,
            ["sortBy"] = _query.SortBy,
            ["sortDesc"] = _query.SortDescending.ToString().ToLowerInvariant()
        };

        var url = QueryHelpers.AddQueryString("/platform/tenants/export", query!);
        Navigation.NavigateTo(url, forceLoad: true);
    }

    private static string GetBadge(TenantStatus status) => status switch
    {
        TenantStatus.Active => "badge-published",
        TenantStatus.PendingActivation => "badge-review",
        TenantStatus.Suspended => "badge-deprecated",
        TenantStatus.Deactivated => "badge-deprecated",
        TenantStatus.Archived => "badge-draft",
        _ => "badge-review"
    };
}
