@page "/platform/health"
@attribute [Authorize(Policy = "PlatformAdmin")]
@using FC.Engine.Admin.Services
@using FC.Engine.Domain.Models
@using FC.Engine.Infrastructure.Charts
@inject PlatformAdminService PlatformService
@inject ChartJsInterop Charts
@implements IDisposable

<PageTitle>Platform Health</PageTitle>

<header class="dash-header" role="banner">
    <div class="dash-header-text">
        <h1>Platform Health</h1>
        <p>Latency, error rate, sessions, queue depth, database, and cache telemetry.</p>
    </div>
</header>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="portal-alert portal-alert-danger">@_error</div>
}

@if (_loading)
{
    <div class="portal-card"><div class="portal-card-body">Loading platform health...</div></div>
}
else if (_data is not null)
{
    <div class="portal-grid portal-grid-4" style="margin-bottom:1rem;">
        <div class="portal-card"><div class="portal-card-body"><div class="portal-stat-label">Latency p50</div><div class="portal-stat-value">@_data.ApiLatencyP50Ms.ToString("0") ms</div></div></div>
        <div class="portal-card"><div class="portal-card-body"><div class="portal-stat-label">Latency p95</div><div class="portal-stat-value">@_data.ApiLatencyP95Ms.ToString("0") ms</div></div></div>
        <div class="portal-card"><div class="portal-card-body"><div class="portal-stat-label">Latency p99</div><div class="portal-stat-value">@_data.ApiLatencyP99Ms.ToString("0") ms</div></div></div>
        <div class="portal-card"><div class="portal-card-body"><div class="portal-stat-label">Error Rate</div><div class="portal-stat-value">@_data.ErrorRatePercent.ToString("0.##")%</div></div></div>
    </div>

    <div class="portal-grid portal-grid-3" style="margin-bottom:1rem;">
        <div class="portal-card"><div class="portal-card-body"><div class="portal-kv"><span>Active Sessions</span><strong>@_data.ActiveSessions</strong></div><div class="portal-kv"><span>Queue Depth</span><strong>@_data.QueueDepth</strong></div><div class="portal-kv"><span>RabbitMQ Pending</span><strong>@_data.RabbitMqPending</strong></div></div></div>
        <div class="portal-card"><div class="portal-card-body"><div class="portal-kv"><span>DB Query Duration</span><strong>@_data.DatabaseQueryDurationMs ms</strong></div><div class="portal-kv"><span>DB Pool Utilisation</span><strong>@_data.DatabasePoolUtilisationPercent.ToString("0.##")%</strong></div></div></div>
        <div class="portal-card"><div class="portal-card-body"><div class="portal-kv"><span>Redis Hit Ratio</span><strong>@_data.RedisCacheHitRatioPercent.ToString("0.##")%</strong></div><div class="portal-kv"><span>Redis Memory</span><strong>@_data.RedisMemoryUsageMb.ToString("0.##") MB</strong></div></div></div>
    </div>

    <div class="portal-grid portal-grid-2">
        <div class="portal-card"><div class="portal-card-header"><h2 class="portal-card-title">Latency Percentiles</h2></div><div class="portal-card-body" style="height:320px;"><canvas id="healthLatencyChart"></canvas></div></div>
        <div class="portal-card"><div class="portal-card-header"><h2 class="portal-card-title">Error Rate (Live Samples)</h2></div><div class="portal-card-body" style="height:320px;"><canvas id="healthErrorTrendChart"></canvas></div></div>
    </div>

    <div style="margin-top:0.75rem; color:#64748b; font-size:0.85rem;">
        Auto-refresh every 30 seconds. Last update: @_lastUpdated.ToString("dd MMM yyyy HH:mm:ss")
    </div>
}

@code {
    private PlatformHealthData? _data;
    private bool _loading = true;
    private string? _error;
    private bool _chartDirty;
    private Timer? _refreshTimer;
    private DateTime _lastUpdated = DateTime.UtcNow;
    private readonly Queue<decimal> _errorSamples = new();
    private readonly Queue<string> _errorLabels = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();

        _refreshTimer = new Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await LoadAsync(silent: true);
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_data is null || !_chartDirty)
        {
            return;
        }

        await Charts.RenderBarChart("healthLatencyChart", BuildLatencyChart(_data));
        await Charts.RenderLineChart("healthErrorTrendChart", BuildErrorTrendChart());
        _chartDirty = false;
    }

    private async Task LoadAsync(bool silent = false)
    {
        if (!silent)
        {
            _loading = true;
            _error = null;
        }

        try
        {
            _data = await PlatformService.GetPlatformHealth();
            _lastUpdated = DateTime.UtcNow;

            EnqueueSample(_errorSamples, _data.ErrorRatePercent, 24);
            EnqueueSample(_errorLabels, _lastUpdated.ToString("HH:mm:ss"), 24);

            _chartDirty = true;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            if (!silent)
            {
                _loading = false;
            }
        }
    }

    private static void EnqueueSample<T>(Queue<T> queue, T value, int max)
    {
        queue.Enqueue(value);
        while (queue.Count > max)
        {
            queue.Dequeue();
        }
    }

    private static TrendData BuildLatencyChart(PlatformHealthData data)
    {
        return new TrendData
        {
            Title = "API Latency",
            Labels = new List<string> { "p50", "p95", "p99" },
            Datasets =
            {
                new TrendDataset
                {
                    Label = "Milliseconds",
                    Data = new List<decimal> { data.ApiLatencyP50Ms, data.ApiLatencyP95Ms, data.ApiLatencyP99Ms },
                    BackgroundColor = "#0f766e",
                    BorderColor = "#0f766e"
                }
            }
        };
    }

    private TrendData BuildErrorTrendChart()
    {
        return new TrendData
        {
            Title = "Error Rate Trend",
            Labels = _errorLabels.ToList(),
            Datasets =
            {
                new TrendDataset
                {
                    Label = "5xx Error Rate %",
                    Data = _errorSamples.ToList(),
                    BackgroundColor = "#b91c1c",
                    BorderColor = "#b91c1c"
                }
            }
        };
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }
}
