@page "/platform/health"
@attribute [Authorize(Policy = "PlatformAdmin")]
@using FC.Engine.Admin.Services
@using FC.Engine.Domain.Models
@using FC.Engine.Infrastructure.Charts
@inject PlatformAdminService PlatformService
@inject ChartJsInterop Charts
@implements IDisposable

<PageTitle>Platform Health</PageTitle>

<PageHeader Title="Platform Health"
            Subtitle="Latency, error rate, sessions, queue depth, database, and cache telemetry." />

<div class="fc-page">

    <!-- Error Display -->
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="fc-alert fc-alert--inline fc-alert--error">@_error</div>
    }

    <!-- Content -->
    @if (_loading)
    {
        <!-- Skeleton: KPI cards -->
        <div class="fc-grid fc-grid-4 fc-mb-4">
            @for (var i = 0; i < 4; i++)
            {
                <div class="fc-card">
                    <div class="fc-card__body">
                        <div class="fc-skel fc-skel-text" style="--skel-w:80px;--skel-mb:0.5rem"></div>
                        <div class="fc-skel fc-skel-text" style="--skel-w:60px;--skel-h:1.5rem"></div>
                    </div>
                </div>
            }
        </div>

        <!-- Skeleton: Infrastructure metrics -->
        <div class="fc-grid fc-grid-3 fc-mb-4">
            @for (var i = 0; i < 3; i++)
            {
                <div class="fc-card">
                    <div class="fc-card__body">
                        <div class="fc-skel fc-skel-text" style="--skel-w:120px;--skel-mb:0.75rem"></div>
                        <div class="fc-skel fc-skel-text" style="--skel-w:90px;--skel-mb:0.5rem"></div>
                        <div class="fc-skel fc-skel-text" style="--skel-w:100px"></div>
                    </div>
                </div>
            }
        </div>

        <!-- Skeleton: Charts -->
        <div class="fc-grid fc-grid-2">
            @for (var i = 0; i < 2; i++)
            {
                <div class="fc-card">
                    <div class="fc-card__header">
                        <div class="fc-skel fc-skel-text" style="--skel-w:160px"></div>
                    </div>
                    <div class="fc-card__body fc-chart-height">
                        <div class="fc-skel fc-skel-block" style="--skel-w:100%;--skel-h:100%"></div>
                    </div>
                </div>
            }
        </div>
    }
    else if (_data is not null)
    {
        <!-- System Health Banner -->
        <div class="fc-health-banner fc-health-banner--@BannerLevel">
            <span class="fc-health-orb"></span>
            <div class="fc-health-banner__body">
                <span class="fc-health-banner__headline">@BannerHeadline</span>
                <span class="fc-health-banner__ts">Last checked @_lastUpdated.ToString("HH:mm:ss") UTC</span>
            </div>
        </div>

        <!-- KPI Cards -->
        <div class="fc-grid fc-grid-4 fc-mb-4">
            <!-- p50 -->
            <div class="fc-card fc-kpi-card fc-kpi-card--@GetLatencyLevel(_data.ApiLatencyP50Ms, 200, 500)">
                <div class="fc-card__body">
                    <div class="fc-stat-label">Latency p50</div>
                    <div class="fc-kpi-row">
                        <div class="fc-stat-value">@_data.ApiLatencyP50Ms.ToString("0") ms</div>
                        <span class="fc-kpi-trend fc-kpi-trend--@GetTrendClass(_data.ApiLatencyP50Ms, _snapshot?.ApiLatencyP50Ms, higherIsBad: true)">
                            @GetTrendArrow(_data.ApiLatencyP50Ms, _snapshot?.ApiLatencyP50Ms, higherIsBad: true)
                        </span>
                    </div>
                    <div class="fc-kpi-delta">@GetDelta(_data.ApiLatencyP50Ms, _snapshot?.ApiLatencyP50Ms, "ms")</div>
                </div>
            </div>

            <!-- p95 -->
            <div class="fc-card fc-kpi-card fc-kpi-card--@GetLatencyLevel(_data.ApiLatencyP95Ms, 400, 800)">
                <div class="fc-card__body">
                    <div class="fc-stat-label">Latency p95</div>
                    <div class="fc-kpi-row">
                        <div class="fc-stat-value">@_data.ApiLatencyP95Ms.ToString("0") ms</div>
                        <span class="fc-kpi-trend fc-kpi-trend--@GetTrendClass(_data.ApiLatencyP95Ms, _snapshot?.ApiLatencyP95Ms, higherIsBad: true)">
                            @GetTrendArrow(_data.ApiLatencyP95Ms, _snapshot?.ApiLatencyP95Ms, higherIsBad: true)
                        </span>
                    </div>
                    <div class="fc-kpi-delta">@GetDelta(_data.ApiLatencyP95Ms, _snapshot?.ApiLatencyP95Ms, "ms")</div>
                </div>
            </div>

            <!-- p99 -->
            <div class="fc-card fc-kpi-card fc-kpi-card--@GetLatencyLevel(_data.ApiLatencyP99Ms, 500, 1000)">
                <div class="fc-card__body">
                    <div class="fc-stat-label">Latency p99</div>
                    <div class="fc-kpi-row">
                        <div class="fc-stat-value">@_data.ApiLatencyP99Ms.ToString("0") ms</div>
                        <span class="fc-kpi-trend fc-kpi-trend--@GetTrendClass(_data.ApiLatencyP99Ms, _snapshot?.ApiLatencyP99Ms, higherIsBad: true)">
                            @GetTrendArrow(_data.ApiLatencyP99Ms, _snapshot?.ApiLatencyP99Ms, higherIsBad: true)
                        </span>
                    </div>
                    <div class="fc-kpi-delta">@GetDelta(_data.ApiLatencyP99Ms, _snapshot?.ApiLatencyP99Ms, "ms")</div>
                </div>
            </div>

            <!-- Error Rate -->
            <div class="fc-card fc-kpi-card fc-kpi-card--@GetErrorLevel(_data.ErrorRatePercent)">
                <div class="fc-card__body">
                    <div class="fc-stat-label">Error Rate</div>
                    <div class="fc-kpi-row">
                        <div class="fc-stat-value">@_data.ErrorRatePercent.ToString("0.##")%</div>
                        <span class="fc-kpi-trend fc-kpi-trend--@GetTrendClass(_data.ErrorRatePercent, _snapshot?.ErrorRatePercent, higherIsBad: true)">
                            @GetTrendArrow(_data.ErrorRatePercent, _snapshot?.ErrorRatePercent, higherIsBad: true)
                        </span>
                    </div>
                    <div class="fc-kpi-delta">@GetDelta(_data.ErrorRatePercent, _snapshot?.ErrorRatePercent, "%")</div>
                </div>
            </div>
        </div>

        <!-- Infrastructure Metrics -->
        <div class="fc-grid fc-grid-3 fc-mb-4">
            <div class="fc-card">
                <div class="fc-card__body">
                    <div class="fc-kv"><span>Active Sessions</span><strong>@_data.ActiveSessions</strong></div>
                    <div class="fc-kv"><span>Queue Depth</span><strong>@_data.QueueDepth</strong></div>
                    <div class="fc-kv"><span>RabbitMQ Pending</span><strong>@_data.RabbitMqPending</strong></div>
                </div>
            </div>
            <div class="fc-card">
                <div class="fc-card__body">
                    <div class="fc-kv"><span>DB Query Duration</span><strong>@_data.DatabaseQueryDurationMs ms</strong></div>
                    <div class="fc-kv"><span>DB Pool Utilisation</span><strong>@_data.DatabasePoolUtilisationPercent.ToString("0.##")%</strong></div>
                </div>
            </div>
            <div class="fc-card">
                <div class="fc-card__body">
                    <div class="fc-kv"><span>Redis Hit Ratio</span><strong>@_data.RedisCacheHitRatioPercent.ToString("0.##")%</strong></div>
                    <div class="fc-kv"><span>Redis Memory</span><strong>@_data.RedisMemoryUsageMb.ToString("0.##") MB</strong></div>
                </div>
            </div>
        </div>

        <!-- Charts -->
        <div class="fc-grid fc-grid-2">
            <div class="fc-card">
                <div class="fc-card__header"><h2 class="fc-card__title">Latency Percentiles</h2></div>
                <div class="fc-card__body fc-chart-height"><canvas id="healthLatencyChart"></canvas></div>
            </div>
            <div class="fc-card">
                <div class="fc-card__header"><h2 class="fc-card__title">Error Rate (Live Samples)</h2></div>
                <div class="fc-card__body fc-chart-height"><canvas id="healthErrorTrendChart"></canvas></div>
            </div>
        </div>

        <!-- Auto-refresh indicator -->
        <div class="fc-refresh-row">
            <span class="fc-badge fc-badge--success">Auto-refresh</span>
            <span class="fc-refresh-label">Every 30 seconds &middot; Last update: @_lastUpdated.ToString("dd MMM yyyy HH:mm:ss")</span>
        </div>
    }

</div>

@code {
    private PlatformHealthData? _data;
    private PlatformHealthData? _snapshot;   // previous poll, used for trend arrows
    private bool _loading = true;
    private string? _error;
    private bool _chartDirty;
    private Timer? _refreshTimer;
    private DateTime _lastUpdated = DateTime.UtcNow;
    private readonly Queue<decimal> _errorSamples = new();
    private readonly Queue<string> _errorLabels = new();

    // ── Banner derived properties ─────────────────────────
    private string BannerLevel => _data is null ? "green" : new[]
    {
        GetLatencyLevel(_data.ApiLatencyP50Ms, 200, 500),
        GetLatencyLevel(_data.ApiLatencyP95Ms, 400, 800),
        GetLatencyLevel(_data.ApiLatencyP99Ms, 500, 1000),
        GetErrorLevel(_data.ErrorRatePercent)
    }.Aggregate(WorstLevel);

    private string BannerHeadline => BannerLevel switch
    {
        "red"   => "Incident Detected",
        "amber" => "Degraded Performance",
        _       => "All Systems Operational"
    };

    // ── Threshold helpers ──────────────────────────────────
    private static string GetLatencyLevel(decimal ms, decimal amber, decimal red) =>
        ms >= red ? "red" : ms >= amber ? "amber" : "green";

    private static string GetErrorLevel(decimal pct) =>
        pct >= 5 ? "red" : pct >= 1 ? "amber" : "green";

    private static string WorstLevel(string a, string b) =>
        a == "red" || b == "red" ? "red" :
        a == "amber" || b == "amber" ? "amber" : "green";

    // ── Trend helpers ──────────────────────────────────────
    private static string GetTrendArrow(decimal current, decimal? prev, bool higherIsBad)
    {
        if (prev is null) return "→";
        if (current > prev.Value) return "↑";
        if (current < prev.Value) return "↓";
        return "→";
    }

    private static string GetTrendClass(decimal current, decimal? prev, bool higherIsBad)
    {
        if (prev is null) return "neutral";
        if (current > prev.Value) return higherIsBad ? "up-bad" : "down-good";
        if (current < prev.Value) return higherIsBad ? "down-good" : "up-bad";
        return "neutral";
    }

    private static string GetDelta(decimal current, decimal? prev, string unit)
    {
        if (prev is null) return "—";
        var delta = current - prev.Value;
        if (delta == 0) return "no change";
        return (delta > 0 ? "+" : "") + delta.ToString("0.##") + "\u202f" + unit;
    }

    // ── Lifecycle ──────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();

        _refreshTimer = new Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await LoadAsync(silent: true);
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_data is null || !_chartDirty) return;

        await Charts.RenderBarChart("healthLatencyChart", BuildLatencyChart(_data));
        await Charts.RenderLineChart("healthErrorTrendChart", BuildErrorTrendChart());
        _chartDirty = false;
    }

    private async Task LoadAsync(bool silent = false)
    {
        if (!silent)
        {
            _loading = true;
            _error = null;
        }

        try
        {
            // Capture current data as the snapshot before overwriting
            _snapshot = _data;

            _data = await PlatformService.GetPlatformHealth();
            _lastUpdated = DateTime.UtcNow;

            EnqueueSample(_errorSamples, _data.ErrorRatePercent, 24);
            EnqueueSample(_errorLabels, _lastUpdated.ToString("HH:mm:ss"), 24);

            _chartDirty = true;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            if (!silent) _loading = false;
        }
    }

    private static void EnqueueSample<T>(Queue<T> queue, T value, int max)
    {
        queue.Enqueue(value);
        while (queue.Count > max) queue.Dequeue();
    }

    private static TrendData BuildLatencyChart(PlatformHealthData data)
    {
        return new TrendData
        {
            Title = "API Latency",
            Labels = new List<string> { "p50", "p95", "p99" },
            Datasets =
            {
                new TrendDataset
                {
                    Label = "Milliseconds",
                    Data = new List<decimal> { data.ApiLatencyP50Ms, data.ApiLatencyP95Ms, data.ApiLatencyP99Ms },
                    BackgroundColor = "#0f766e",
                    BorderColor = "#0f766e"
                }
            }
        };
    }

    private TrendData BuildErrorTrendChart()
    {
        return new TrendData
        {
            Title = "Error Rate Trend",
            Labels = _errorLabels.ToList(),
            Datasets =
            {
                new TrendDataset
                {
                    Label = "5xx Error Rate %",
                    Data = _errorSamples.ToList(),
                    BackgroundColor = "#b91c1c",
                    BorderColor = "#b91c1c"
                }
            }
        };
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }
}
