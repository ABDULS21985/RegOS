@page "/platform/templates"
@attribute [Authorize(Policy = "PlatformAdmin")]
@inject PlatformAdminService PlatformService
@inject NavigationManager Navigation

<PageTitle>Template Console</PageTitle>

<section class="billing-shell">
    <header class="billing-hero">
        <div>
            <p class="billing-kicker">Platform Console</p>
            <h1>Template Management Console</h1>
            <p>Version visibility, publish/deprecate operations, and version diffs.</p>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="cbn-alert cbn-alert-success">@_message</div>
    }
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="cbn-alert cbn-alert-error">@_error</div>
    }

    @if (_loading)
    {
        <section class="card billing-surface"><p>Loading templates...</p></section>
    }
    else
    {
        <section class="card billing-surface">
            <div class="billing-table-wrap">
                <table class="data-table billing-table">
                    <thead>
                        <tr>
                            <th>Module</th>
                            <th>Template</th>
                            <th>Current Version</th>
                            <th>Draft Version</th>
                            <th>Fields</th>
                            <th>Formulas</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _items)
                        {
                            <tr>
                                <td>
                                    <div class="billing-plan-name">@item.ModuleName</div>
                                    <div class="billing-plan-code">@item.ModuleCode</div>
                                </td>
                                <td>
                                    <div class="billing-plan-name">@item.TemplateName</div>
                                    <div class="billing-plan-code">@item.ReturnCode</div>
                                </td>
                                <td>@(item.CurrentVersionNumber.HasValue ? $"v{item.CurrentVersionNumber}" : "-")</td>
                                <td>
                                    @if (item.DraftVersionNumber.HasValue)
                                    {
                                        <span>v@item.DraftVersionNumber (@item.DraftStatus)</span>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                                <td>@item.FieldCount</td>
                                <td>@item.FormulaCount</td>
                                <td>
                                    <div class="billing-actions-grid">
                                        <button class="btn btn-outline btn-sm" @onclick="() => ViewDefinition(item.ReturnCode)">Definition</button>
                                        @if (item.DraftVersionId.HasValue)
                                        {
                                            <button class="btn btn-primary btn-sm" @onclick="() => Publish(item.TemplateId)">Publish Draft</button>
                                        }
                                        @if (item.CurrentVersionId.HasValue)
                                        {
                                            <button class="btn btn-danger btn-sm" @onclick="() => Deprecate(item.TemplateId, item.CurrentVersionId.Value)">Deprecate</button>
                                        }
                                        <button class="btn btn-outline btn-sm" @onclick="() => ShowDiff(item.TemplateId, item.TemplateName, item.ReturnCode)">Diff</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }

    @if (_diff is not null)
    {
        <section class="card billing-surface">
            <h3>Version Diff — @_diff.TemplateName (@_diff.ReturnCode)</h3>
            <p>v@_diff.FromVersionNumber → v@_diff.ToVersionNumber</p>
            <div class="detail-info-grid">
                <div class="detail-info-item">
                    <span class="detail-info-label">Added fields</span>
                    <span class="detail-info-value">@string.Join(", ", _diff.AddedFields.DefaultIfEmpty("-"))</span>
                </div>
                <div class="detail-info-item">
                    <span class="detail-info-label">Removed fields</span>
                    <span class="detail-info-value">@string.Join(", ", _diff.RemovedFields.DefaultIfEmpty("-"))</span>
                </div>
                <div class="detail-info-item">
                    <span class="detail-info-label">Changed fields</span>
                    <span class="detail-info-value">@string.Join(", ", _diff.ChangedFields.DefaultIfEmpty("-"))</span>
                </div>
                <div class="detail-info-item">
                    <span class="detail-info-label">Formula count</span>
                    <span class="detail-info-value">@_diff.FormulaCountFrom → @_diff.FormulaCountTo</span>
                </div>
            </div>
        </section>
    }
</section>

@code {
    private bool _loading = true;
    private string? _message;
    private string? _error;
    private List<TemplateConsoleItem> _items = new();
    private TemplateVersionDiffData? _diff;

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        _loading = true;
        var data = await PlatformService.GetTemplateConsole();
        _items = data.Items;
        _loading = false;
    }

    private void ViewDefinition(string returnCode)
    {
        Navigation.NavigateTo($"/templates/{returnCode}");
    }

    private async Task Publish(int templateId)
    {
        _error = null;
        _message = null;
        try
        {
            await PlatformService.PublishDraftVersion(templateId, "platform-admin");
            _message = "Draft version published successfully.";
            await Load();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task Deprecate(int templateId, int versionId)
    {
        _error = null;
        _message = null;
        try
        {
            await PlatformService.DeprecateVersion(templateId, versionId, "platform-admin");
            _message = $"Version {versionId} deprecated.";
            await Load();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task ShowDiff(int templateId, string templateName, string returnCode)
    {
        _error = null;
        _diff = await PlatformService.GetTemplateDiff(templateId, null, null);
        if (_diff is null)
        {
            _error = "No comparable versions available for diff.";
            return;
        }

        _diff.TemplateName = templateName;
        _diff.ReturnCode = returnCode;
    }
}
