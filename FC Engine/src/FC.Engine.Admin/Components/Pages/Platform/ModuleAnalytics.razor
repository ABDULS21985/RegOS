@page "/platform/module-analytics"
@attribute [Authorize(Policy = "PlatformAdmin")]
@using Microsoft.AspNetCore.Authorization
@using FC.Engine.Admin.Services
@using FC.Engine.Domain.Models
@using FC.Engine.Infrastructure.Charts
@inject PlatformAdminService PlatformService
@inject ChartJsInterop Charts

<PageTitle>Module Analytics</PageTitle>

<PageHeader Title="Module Analytics"
            Subtitle="Adoption heatmap and validation hotspot drilldown across active modules." />

<div class="fc-page">

    <!-- Content -->
    @if (_loading)
    {
        <div class="fc-card fc-card--mb">
            <div class="fc-card__body fc-card-body--flush">
                <table class="fc-table">
                    <thead><tr><th>Module</th><th>Tenants</th><th>Active Users</th><th>Returns</th><th>Error Rate</th><th>Heat</th><th></th></tr></thead>
                    <tbody>
                        @for (var i = 0; i < 5; i++)
                        {
                            <tr>
                                <td><div class="fc-skel fc-skel-text" style="--skel-w:140px"></div></td>
                                <td><div class="fc-skel fc-skel-text" style="--skel-w:30px"></div></td>
                                <td><div class="fc-skel fc-skel-text" style="--skel-w:30px"></div></td>
                                <td><div class="fc-skel fc-skel-text" style="--skel-w:30px"></div></td>
                                <td><div class="fc-skel fc-skel-text" style="--skel-w:50px"></div></td>
                                <td><div class="fc-skel" style="--skel-w:50px;--skel-h:20px"></div></td>
                                <td><div class="fc-skel" style="--skel-w:70px;--skel-h:28px"></div></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else if (_data is not null)
    {
        <!-- Adoption Matrix -->
        <div class="fc-card fc-card--mb">
            <div class="fc-card__header"><h2 class="fc-card__title">Adoption Matrix</h2></div>
            <div class="fc-card__body fc-card-body--flush">
                <table class="fc-table">
                    <thead>
                        <tr>
                            <th>Module</th>
                            <th>Tenants</th>
                            <th>Active Users</th>
                            <th>Returns Submitted</th>
                            <th>Validation Error Rate</th>
                            <th>Heat</th>
                            <th class="fc-text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _data.Items)
                        {
                            <tr>
                                <td>
                                    <div class="fc-fw-600">@row.ModuleName</div>
                                    <small class="fc-cell-sub">@row.ModuleCode</small>
                                </td>
                                <td><span class="fc-badge fc-badge--neutral">@row.TenantCount</span></td>
                                <td>@row.ActiveUsers</td>
                                <td>@row.ReturnsSubmitted</td>
                                <td>
                                    <span class="fc-badge @(row.ValidationErrorRate > 10 ? "fc-badge--danger" : row.ValidationErrorRate > 5 ? "fc-badge--warning" : "fc-badge--success")">
                                        @row.ValidationErrorRate.ToString("0.##")%
                                    </span>
                                </td>
                                <td>
                                    <span class="fc-badge @HeatBadge(row.Heat) fc-capitalize">@row.Heat</span>
                                </td>
                                <td class="fc-text-right">
                                    <button class="fc-btn fc-btn--ghost @(_selected?.ModuleId == row.ModuleId ? "fc-btn--primary" : "")" @onclick="() => SelectModule(row.ModuleId)" type="button" title="Drilldown">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                                        Drilldown
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Chart -->
        <div class="fc-card fc-card--mb">
            <div class="fc-card__header"><h2 class="fc-card__title">Module Filing Volumes</h2></div>
            <div class="fc-card__body fc-chart-height"><canvas id="moduleVolumeChart"></canvas></div>
        </div>

        <!-- Hotspot Drilldown -->
        @if (_selected is not null)
        {
            <div class="fc-card">
                <div class="fc-card__header">
                    <h2 class="fc-card__title">Error Hotspots: @_selected.ModuleName (@_selected.ModuleCode)</h2>
                </div>
                <div class="fc-card__body fc-card-body--flush">
                    @if (_selected.Hotspots.Count == 0)
                    {
                        <div class="fc-table-empty-cell">No validation hotspots found for this module.</div>
                    }
                    else
                    {
                        <table class="fc-table">
                            <thead><tr><th>Rule</th><th>Field</th><th>Count</th></tr></thead>
                            <tbody>
                                @foreach (var hotspot in _selected.Hotspots)
                                {
                                    <tr>
                                        <td><code>@hotspot.RuleId</code></td>
                                        <td>@hotspot.Field</td>
                                        <td><span class="fc-badge fc-badge--danger">@hotspot.Count</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        }
    }
</div>

@code {
    private ModuleAnalyticsData? _data;
    private ModuleAnalyticsItem? _selected;
    private bool _loading = true;
    private bool _chartsRendered;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            _data = await PlatformService.GetModuleAnalytics();
            _selected = _data.Items.OrderByDescending(x => x.ValidationErrorRate).FirstOrDefault();
        }
        catch { }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_data is null || _chartsRendered) return;
        await Charts.RenderBarChart("moduleVolumeChart", BuildVolumeChart(_data));
        _chartsRendered = true;
    }

    private void SelectModule(int moduleId)
    {
        _selected = _data?.Items.FirstOrDefault(x => x.ModuleId == moduleId);
    }

    private static string HeatBadge(string heat) => heat.ToLowerInvariant() switch
    {
        "red" => "fc-badge--danger",
        "amber" => "fc-badge--warning",
        _ => "fc-badge--success"
    };

    private static TrendData BuildVolumeChart(ModuleAnalyticsData data) => new()
    {
        Title = "Returns by Module",
        Labels = data.Items.Select(i => i.ModuleCode).ToList(),
        Datasets =
        {
            new TrendDataset
            {
                Label = "Returns Submitted",
                Data = data.Items.Select(i => (decimal)i.ReturnsSubmitted).ToList(),
                BackgroundColor = "#0f766e",
                BorderColor = "#0f766e"
            }
        }
    };
}
