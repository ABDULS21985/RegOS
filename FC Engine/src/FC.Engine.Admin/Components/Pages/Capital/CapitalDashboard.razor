@page "/platform/capital"
@attribute [Authorize(Policy = "PlatformAdmin")]
@inject FC.Engine.Admin.Services.Capital.RwaOptimizationService RwaService
@inject FC.Engine.Admin.Services.Capital.CapitalStackOptimizerService StackService
@inject FC.Engine.Infrastructure.Services.CapitalPlanningScenarioStoreService ScenarioStore
@inject FC.Engine.Infrastructure.Services.CapitalActionCatalogService ActionCatalog

<PageTitle>Capital Management</PageTitle>

<PageHeader Title="Capital Management"
            Subtitle="RWA optimisation, buffer management, capital planning, and stack optimization."
            StatusBadge="@(_scenario is not null ? "Scenario Loaded" : "No Scenario")"
            StatusVariant="@(_scenario is not null ? "success" : "warning")" />

<div class="fc-page">
    <SectionErrorBoundary Title="Failed to load capital data" ExternalError="@_loadException" OnRetry="ReloadAsync">
        @if (_loading)
        {
            <div class="fc-cap-kpi-strip">
                @for (var i = 0; i < 4; i++)
                {
                    <div class="fc-cap-kpi"><SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Block" Height="88px" /></div>
                }
            </div>
            <div class="rg-hub-grid">
                @for (var i = 0; i < 5; i++)
                {
                    <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.Card" />
                }
            </div>
        }
        else
        {
            <div class="fc-cap-kpi-strip">
                <div class="fc-cap-kpi">
                    <div class="fc-cap-kpi-value @CarColorClass(_scenario?.CurrentCarPercent ?? 0)">
                        @((_scenario?.CurrentCarPercent ?? 0).ToString("F1"))%
                    </div>
                    <div class="fc-cap-kpi-label">Current CAR</div>
                </div>
                <div class="fc-cap-kpi">
                    <div class="fc-cap-kpi-value">
                        @((_scenario?.CurrentRwaBn ?? 0).ToString("F1"))bn
                    </div>
                    <div class="fc-cap-kpi-label">Total RWA</div>
                </div>
                <div class="fc-cap-kpi">
                    <div class="fc-cap-kpi-value @BufferColorClass(_bufferHeadroom)">
                        @(_bufferHeadroom.ToString("F1"))%
                    </div>
                    <div class="fc-cap-kpi-label">Buffer Headroom</div>
                </div>
                <div class="fc-cap-kpi">
                    <div class="fc-cap-kpi-value">@_actionCount</div>
                    <div class="fc-cap-kpi-label">Action Templates</div>
                </div>
            </div>

            <div class="rg-hub-grid">
                <a class="rg-hub-card" href="/platform/capital/rwa" style="--stagger-i:0;">
                    <div class="rg-hub-card-icon rg-hub-icon--blue">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true">
                            <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 002 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0022 16z"/>
                            <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                            <line x1="12" y1="22.08" x2="12" y2="12"/>
                        </svg>
                    </div>
                    <h3 class="rg-hub-card-title">RWA Optimisation</h3>
                    <p class="rg-hub-card-desc">Analyse RWA composition and identify optimisation opportunities</p>
                </a>
                <a class="rg-hub-card" href="/platform/capital/buffers" style="--stagger-i:1;">
                    <div class="rg-hub-card-icon rg-hub-icon--amber">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                        </svg>
                    </div>
                    <h3 class="rg-hub-card-title">Buffer Management</h3>
                    <p class="rg-hub-card-desc">Track conservation, countercyclical, and D-SIB buffers with trigger warnings</p>
                </a>
                <a class="rg-hub-card" href="/platform/capital/planning" style="--stagger-i:2;">
                    <div class="rg-hub-card-icon rg-hub-icon--green">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true">
                            <line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/>
                        </svg>
                    </div>
                    <h3 class="rg-hub-card-title">Capital Planning</h3>
                    <p class="rg-hub-card-desc">Project CAR over 4–8 quarters using growth, profit, and issuance assumptions</p>
                </a>
                <a class="rg-hub-card" href="/platform/capital/actions" style="--stagger-i:3;">
                    <div class="rg-hub-card-icon rg-hub-icon--purple">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true">
                            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                            <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
                        </svg>
                    </div>
                    <h3 class="rg-hub-card-title">What-If Actions</h3>
                    <p class="rg-hub-card-desc">Compare issuance, disposal, and portfolio action scenarios side by side</p>
                </a>
                <a class="rg-hub-card" href="/platform/capital/stack" style="--stagger-i:4;">
                    <div class="rg-hub-card-icon rg-hub-icon--red">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true">
                            <line x1="12" y1="1" x2="12" y2="23"/>
                            <path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
                        </svg>
                    </div>
                    <h3 class="rg-hub-card-title">Capital Stack Optimiser</h3>
                    <p class="rg-hub-card-desc">Find the optimal CET1 / AT1 / Tier 2 mix to minimise cost of capital</p>
                </a>
            </div>

            @if (_scenario is not null)
            {
                <div class="fc-cap-scenario-meta">
                    <span class="fc-text-muted">Scenario last saved @_scenario.SavedAtUtc.ToString("dd MMM yyyy HH:mm") UTC</span>
                </div>
            }
        }
    </SectionErrorBoundary>
</div>

@code {
    private bool _loading = true;
    private Exception? _loadException;
    private CapitalPlanningScenarioState? _scenario;
    private decimal _bufferHeadroom;
    private int _actionCount;

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        _loadException = null;
        try
        {
            _scenario = await ScenarioStore.LoadAsync();
            var catalog = await ActionCatalog.LoadAsync();
            _actionCount = catalog.Templates.Count;

            if (_scenario is not null)
            {
                var totalBufferReq = _scenario.MinimumRequirementPercent
                                     + _scenario.ConservationBufferPercent
                                     + _scenario.CountercyclicalBufferPercent
                                     + _scenario.DsibBufferPercent;
                _bufferHeadroom = _scenario.CurrentCarPercent - totalBufferReq;
            }
        }
        catch (Exception ex)
        {
            _loadException = ex;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string CarColorClass(decimal car) => car switch
    {
        >= 15 => "fc-cap-kpi-value--green",
        >= 10 => "fc-cap-kpi-value--amber",
        _ => "fc-cap-kpi-value--red"
    };

    private static string BufferColorClass(decimal headroom) => headroom switch
    {
        >= 3 => "fc-cap-kpi-value--green",
        >= 1 => "fc-cap-kpi-value--amber",
        _ => "fc-cap-kpi-value--red"
    };
}
