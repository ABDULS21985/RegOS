@page "/business-rules"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize]
@using FC.Engine.Admin.Utilities
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Enums
@using FC.Engine.Domain.Validation
@using FC.Engine.Application.Services
@inject IFormulaRepository FormulaRepo
@inject FormulaService FormulaService
@inject ToastService Toast
@inject DialogService Dialog

<PageHeader Title="Business Rules"
            Subtitle="Expression-based validation rules with template applicability"
            CountBadge="@(!_loading ? _rules.Count : null)" />

<div class="fc-list-page">

    @if (_showAddForm)
    {
        <div class="fc-list-inline-form">
            <h3>@(_editRuleId.HasValue ? "Edit Business Rule" : "Add Business Rule")</h3>
            <div class="fc-grid fc-grid-2">
                <div class="fc-form-group">
                    <label>Rule Code</label>
                    <input class="fc-form-input" @bind="_addCode" placeholder="e.g. BR-001" aria-label="Rule Code" disabled="@(_editRuleId.HasValue)" />
                </div>
                <div class="fc-form-group">
                    <label>Rule Name</label>
                    <input class="fc-form-input" @bind="_addName" placeholder="e.g. Date Validity Check" aria-label="Rule Name" />
                </div>
                <div class="fc-form-group">
                    <label>Rule Type</label>
                    <select class="fc-form-input" @bind="_addRuleType" aria-label="Rule Type">
                        <option value="Completeness">Completeness</option>
                        <option value="DateCheck">DateCheck</option>
                        <option value="ThresholdCheck">ThresholdCheck</option>
                        <option value="Custom">Custom</option>
                    </select>
                </div>
                <div class="fc-form-group">
                    <label>Severity</label>
                    <select class="fc-form-input" @bind="_addSeverity" aria-label="Severity">
                        @foreach (var s in Enum.GetValues<ValidationSeverity>())
                        {
                            <option value="@s">@s</option>
                        }
                    </select>
                </div>
                <div class="fc-form-group">
                    <label>Expression (optional)</label>
                    <input class="fc-form-input" @bind="_addExpression" placeholder="e.g. total_assets > 0" aria-label="Expression" />
                </div>
                <div class="fc-form-group">
                    <label>Applies To Templates (comma-separated, blank=all)</label>
                    <input class="fc-form-input" @bind="_addAppliesToTemplates" placeholder="e.g. MFCR 300,MFCR 301" aria-label="Applies To Templates" />
                </div>
                <div class="fc-form-group fc-grid-span-full">
                    <label>Description (optional)</label>
                    <input class="fc-form-input" @bind="_addDescription" placeholder="Description of what this rule validates" aria-label="Description" />
                </div>
            </div>
            <div class="fc-list-form-actions">
                @if (_editRuleId.HasValue)
                {
                    <button class="fc-btn fc-btn--primary fc-btn--sm @(_isSaving ? "fc-btn--loading" : "")" @onclick="UpdateRule" disabled="@_isSaving" aria-busy="@(_isSaving ? "true" : null)">
                        @if (_isSaving) { <span class="fc-spinner fc-spinner--sm fc-spinner--white" aria-hidden="true"></span> }
                        Update
                    </button>
                }
                else
                {
                    <button class="fc-btn fc-btn--primary fc-btn--sm @(_isSaving ? "fc-btn--loading" : "")" @onclick="AddRule" disabled="@_isSaving" aria-busy="@(_isSaving ? "true" : null)">
                        @if (_isSaving) { <span class="fc-spinner fc-spinner--sm fc-spinner--white" aria-hidden="true"></span> }
                        Create
                    </button>
                }
                <button class="fc-btn fc-btn--outline fc-btn--sm" @onclick="CancelAdd" disabled="@_isSaving">Cancel</button>
            </div>
        </div>
    }

    <DataTable TItem="BusinessRule"
               Items="@FilteredRules"
               Loading="_loading"
               PageSize="25"
               PageSizeOptions="new[]{10,25,50,100}"
               ShowPagination="true"
               ShowPageSizeSelector="true"
               Sortable="true"
               EmptyTitle="No business rules found"
               EmptyText="No rules match your current filters. Try adjusting your search or create a new business rule."
               SkeletonRows="5"
               ExportFileName="business-rules">
        <ToolbarContent>
            <div class="fc-list-toolbar-filters">
                <div class="fc-list-search-wrap">
                    <svg class="fc-list-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                    <input class="fc-list-search-input" placeholder="Search by rule code or name..." @bind="_search" @bind:event="oninput" />
                </div>
                <select class="fc-list-filter-select" @bind="_typeFilter">
                    <option value="">All Types</option>
                    <option value="Completeness">Completeness</option>
                    <option value="DateCheck">DateCheck</option>
                    <option value="ThresholdCheck">ThresholdCheck</option>
                    <option value="Custom">Custom</option>
                </select>
                <select class="fc-list-filter-select" @bind="_severityFilter">
                    <option value="">All Severities</option>
                    @foreach (var s in Enum.GetValues<ValidationSeverity>())
                    {
                        <option value="@s">@s</option>
                    }
                </select>
                <select class="fc-list-filter-select" @bind="_statusFilter">
                    <option value="">All Statuses</option>
                    <option value="Active">Active</option>
                    <option value="Inactive">Inactive</option>
                </select>
            </div>
            <div class="fc-list-toolbar-actions">
                <AuthorizeView Roles="Admin,Approver">
                    <Authorized Context="addAuth">
                        <button class="fc-btn fc-btn--gold" @onclick="ShowAddRule">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
                            New Business Rule
                        </button>
                    </Authorized>
                </AuthorizeView>
            </div>
        </ToolbarContent>
        <ChildContent>
            <DataColumn TItem="BusinessRule"
                        Title="Rule Code"
                        SortKey="x => x.RuleCode"
                        CellClass="fc-list-cell-code">
                <CellTemplate>
                    @context.RuleCode
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="BusinessRule"
                        Title="Name"
                        SortKey="x => x.RuleName"
                        CellClass="fc-list-cell-strong">
                <CellTemplate>
                    @context.RuleName
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="BusinessRule"
                        Title="Type">
                <CellTemplate>
                    <span class="fc-badge fc-badge--review">@context.RuleType</span>
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="BusinessRule"
                        Title="Expression"
                        CellClass="fc-list-cell-code fc-list-cell-truncate">
                <CellTemplate>
                    <span title="@context.Expression">@(context.Expression ?? "—")</span>
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="BusinessRule"
                        Title="Applies To"
                        CellClass="fc-list-cell-muted fc-list-cell-truncate">
                <CellTemplate>
                    <span title="@ParseAppliesToDisplay(context.AppliesToTemplates)">@(string.IsNullOrWhiteSpace(context.AppliesToTemplates) ? "All" : (context.AppliesToTemplates == "*" ? "All" : ParseAppliesToDisplay(context.AppliesToTemplates)))</span>
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="BusinessRule"
                        Title="Severity">
                <CellTemplate>
                    <span class="fc-badge @StatusBadge(context.Severity.ToString())">@context.Severity</span>
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="BusinessRule"
                        Title="Status">
                <CellTemplate>
                    @if (context.IsActive)
                    {
                        <span class="fc-badge fc-badge--success">Active</span>
                    }
                    else
                    {
                        <span class="fc-badge fc-badge--muted">Disabled</span>
                    }
                </CellTemplate>
            </DataColumn>
            <DataColumn TItem="BusinessRule"
                        Title="Actions"
                        Width="140px">
                <CellTemplate>
                    <AuthorizeView Roles="Admin,Approver">
                        <Authorized Context="editAuth">
                            <div class="fc-list-row-actions">
                                <button class="fc-btn fc-btn--ghost fc-btn--xs" @onclick="() => EditRule(context)" @onclick:stopPropagation="true">Edit</button>
                                <button class="fc-btn fc-btn--ghost fc-btn--xs" @onclick="() => ToggleRule(context)" @onclick:stopPropagation="true">
                                    @(context.IsActive ? "Disable" : "Enable")
                                </button>
                                <button class="fc-btn fc-btn--ghost fc-btn--xs fc-btn--danger" @onclick="() => DeleteRule(context)" @onclick:stopPropagation="true">Delete</button>
                            </div>
                        </Authorized>
                    </AuthorizeView>
                </CellTemplate>
            </DataColumn>
        </ChildContent>
    </DataTable>

</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private bool _isSaving;
    private IReadOnlyList<BusinessRule> _rules = Array.Empty<BusinessRule>();
    private string _search = "", _typeFilter = "", _severityFilter = "", _statusFilter = "";
    private string _currentUser = string.Empty;

    // Add/Edit form
    private bool _showAddForm;
    private int? _editRuleId;
    private string _addCode = "", _addName = "", _addRuleType = "Completeness";
    private string _addExpression = "", _addAppliesToTemplates = "", _addDescription = "";
    private ValidationSeverity _addSeverity = ValidationSeverity.Error;

    private IReadOnlyList<BusinessRule> FilteredRules => _rules
        .Where(r => string.IsNullOrEmpty(_search) ||
                    r.RuleCode.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                    r.RuleName.Contains(_search, StringComparison.OrdinalIgnoreCase))
        .Where(r => string.IsNullOrEmpty(_typeFilter) || r.RuleType == _typeFilter)
        .Where(r => string.IsNullOrEmpty(_severityFilter) || r.Severity.ToString() == _severityFilter)
        .Where(r => string.IsNullOrEmpty(_statusFilter) ||
                    (_statusFilter == "Active" && r.IsActive) ||
                    (_statusFilter == "Inactive" && !r.IsActive))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        var state = AuthState is null ? null : await AuthState;
        _currentUser = UserIdentityResolver.ResolveActor(state?.User);
        _rules = await FormulaRepo.GetAllBusinessRules();
        _loading = false;
    }

    private void ShowAddRule()
    {
        ResetForm();
        _showAddForm = true;
    }

    private void CancelAdd()
    {
        _showAddForm = false;
        _editRuleId = null;
    }

    private void ResetForm()
    {
        _editRuleId = null;
        _addCode = "";
        _addName = "";
        _addRuleType = "Completeness";
        _addExpression = "";
        _addAppliesToTemplates = "";
        _addDescription = "";
        _addSeverity = ValidationSeverity.Error;
    }

    private void EditRule(BusinessRule rule)
    {
        _showAddForm = true;
        _editRuleId = rule.Id;
        _addCode = rule.RuleCode;
        _addName = rule.RuleName;
        _addRuleType = rule.RuleType;
        _addExpression = rule.Expression ?? "";
        _addAppliesToTemplates = ParseAppliesToDisplay(rule.AppliesToTemplates);
        _addDescription = rule.Description ?? "";
        _addSeverity = rule.Severity;
    }

    private static string StatusBadge(string status) => status.ToLowerInvariant() switch
    {
        "published" or "active" or "accepted" => "fc-badge--success",
        "draft" or "pending" => "fc-badge--warning",
        "review" or "inreview" => "fc-badge--review",
        "deprecated" or "retired" or "disabled" or "archived" => "fc-badge--muted",
        "rejected" or "failed" or "error" => "fc-badge--danger",
        "processing" or "validating" or "parsing" => "fc-badge--info",
        "acceptedwithwarnings" or "warnings" or "warning" => "fc-badge--warning",
        _ => "fc-badge--neutral"
    };

    private bool ValidateForm()
    {
        if (string.IsNullOrWhiteSpace(_addCode))
        {
            Toast.Error("Rule Code is required.", "Validation Error");
            return false;
        }
        if (string.IsNullOrWhiteSpace(_addName))
        {
            Toast.Error("Rule Name is required.", "Validation Error");
            return false;
        }
        return true;
    }

    /// <summary>
    /// Converts comma-separated template codes to JSON array for persistence.
    /// Returns null for blank input, "*" as-is, otherwise a JSON array like ["MFCR 300","BSL 100"].
    /// </summary>
    private static string? BuildAppliesToJson(string? input)
    {
        if (string.IsNullOrWhiteSpace(input)) return null;
        var trimmed = input.Trim();
        if (trimmed == "*") return "*";
        var codes = trimmed.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return System.Text.Json.JsonSerializer.Serialize(codes);
    }

    /// <summary>
    /// Parses JSON array (or "*") back to comma-separated display string for the edit form.
    /// </summary>
    private static string ParseAppliesToDisplay(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return "";
        if (json == "*") return "*";
        try
        {
            var codes = System.Text.Json.JsonSerializer.Deserialize<string[]>(json);
            return codes != null ? string.Join(", ", codes) : json;
        }
        catch { return json; }
    }

    private async Task AddRule()
    {
        if (!ValidateForm()) return;

        _isSaving = true;
        try
        {
            await FormulaService.AddBusinessRule(
                _addCode, _addName, _addRuleType,
                string.IsNullOrWhiteSpace(_addExpression) ? null : _addExpression,
                BuildAppliesToJson(_addAppliesToTemplates),
                _addSeverity, _currentUser,
                string.IsNullOrWhiteSpace(_addDescription) ? null : _addDescription);

            Toast.Success($"Business rule '{_addCode}' created.", "Rule Created");
            _showAddForm = false;
            _rules = await FormulaRepo.GetAllBusinessRules();
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message, "Create Failed");
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task UpdateRule()
    {
        if (!_editRuleId.HasValue || !ValidateForm()) return;

        _isSaving = true;
        try
        {
            await FormulaService.UpdateBusinessRule(
                _editRuleId.Value, _addName, _addRuleType,
                string.IsNullOrWhiteSpace(_addExpression) ? null : _addExpression,
                BuildAppliesToJson(_addAppliesToTemplates),
                _addSeverity, _currentUser,
                string.IsNullOrWhiteSpace(_addDescription) ? null : _addDescription);

            Toast.Success($"Business rule '{_addCode}' updated.", "Rule Updated");
            _showAddForm = false;
            _editRuleId = null;
            _rules = await FormulaRepo.GetAllBusinessRules();
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message, "Update Failed");
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task ToggleRule(BusinessRule rule)
    {
        var action = rule.IsActive ? "Disable" : "Enable";
        var confirmed = await Dialog.Confirm(new ConfirmRequest
        {
            Title = $"{action} Business Rule",
            Message = $"{action} rule '{rule.RuleCode}'? {(rule.IsActive ? "Disabled rules will not run during validation." : "This rule will be included in validation runs.")}",
            ConfirmText = action,
            IsDestructive = rule.IsActive
        });
        if (!confirmed) return;

        try
        {
            await FormulaService.ToggleBusinessRule(rule.Id, !rule.IsActive, _currentUser);
            Toast.Success($"Rule '{rule.RuleCode}' {(rule.IsActive ? "disabled" : "enabled")}.", $"Rule {action}d");
            _rules = await FormulaRepo.GetAllBusinessRules();
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message, $"{action} Failed");
        }
    }

    private async Task DeleteRule(BusinessRule rule)
    {
        var confirmed = await Dialog.ConfirmDelete("Business Rule");
        if (!confirmed) return;

        try
        {
            await FormulaService.DeleteBusinessRule(rule.Id, _currentUser);
            Toast.Success($"Rule '{rule.RuleCode}' deleted.", "Rule Deleted");
            _rules = await FormulaRepo.GetAllBusinessRules();
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message, "Delete Failed");
        }
    }
}
