@page "/cross-sheet-rules/{Id:int}"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize]
@using FC.Engine.Admin.Utilities
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.Enums
@using FC.Engine.Domain.Validation
@using FC.Engine.Application.Services
@inject IFormulaRepository FormulaRepo
@inject FormulaService FormulaService
@inject ToastService Toast
@inject DialogService Dialog
@inject NavigationManager Nav

<PageHeader Title="@(_rule?.RuleCode ?? $"Rule #{Id}")"
            BackUrl="/cross-sheet-rules">
    <PrimaryAction>
        @if (_rule != null)
        {
            <AuthorizeView Roles="Admin">
                <Authorized Context="actionAuth">
                    <button class="fc-btn fc-btn--gold fc-btn--sm" @onclick="StartEdit" disabled="@_isEditing">Edit</button>
                    <button class="fc-btn @(_rule.IsActive ? "fc-btn--outline" : "fc-btn--primary") fc-btn--sm" @onclick="ToggleRule">
                        @(_rule.IsActive ? "Disable Rule" : "Enable Rule")
                    </button>
                    <button class="fc-btn fc-btn--danger fc-btn--sm" @onclick="DeleteRule">Delete</button>
                </Authorized>
            </AuthorizeView>
        }
    </PrimaryAction>
</PageHeader>

<div class="fc-detail-page" aria-busy="@(_loading ? "true" : null)">

    @if (_loading)
    {
        <div class="fc-skel-detail" role="status" aria-label="Loading rule details">
            <div class="fc-skel-detail-hero">
                <div class="fc-skel fc-skel-text-xl" style="--skel-w:240px"></div>
                <div class="fc-skel fc-skel-text" style="--skel-w:320px"></div>
                <div class="fc-flex-row fc-mt-2">
                    <div class="fc-skel" style="--skel-w:110px;--skel-h:24px"></div>
                    <div class="fc-skel" style="--skel-w:80px;--skel-h:24px"></div>
                </div>
            </div>
            <div class="fc-skel-detail-section">
                @for (var i = 0; i < 4; i++)
                {
                    <div class="fc-skel fc-skel-text" style="--skel-w: @(35 + i * 12)%"></div>
                }
            </div>
        </div>
    }
    else if (_rule == null)
    {
        <div class="fc-alert fc-alert--inline fc-alert--error">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
            Cross-sheet rule not found.
        </div>
    }
    else
    {
        <section class="fc-detail-hero" role="banner">
            <div class="fc-detail-hero-left">
                <div class="fc-detail-hero-title-row">
                    <h1 class="fc-detail-hero-title">@_rule.RuleName</h1>
                    <span class="fc-badge @StatusBadge(_rule.Severity.ToString())">@_rule.Severity</span>
                    @if (_rule.IsActive)
                    {
                        <span class="fc-badge fc-badge--success">Active</span>
                    }
                    else
                    {
                        <span class="fc-badge fc-badge--muted">Inactive</span>
                    }
                </div>

                <p class="fc-detail-hero-subtitle">
                    @(_rule.Description ?? "No description provided for this cross-sheet rule.")
                </p>

                <div class="fc-detail-hero-meta">
                    <div class="fc-detail-meta-item">
                        <span class="fc-detail-meta-label">Rule Code</span>
                        <span class="fc-detail-meta-value"><code>@_rule.RuleCode</code></span>
                    </div>
                    <div class="fc-detail-meta-item">
                        <span class="fc-detail-meta-label">Rule ID</span>
                        <span class="fc-detail-meta-value">#@_rule.Id</span>
                    </div>
                    <div class="fc-detail-meta-item">
                        <span class="fc-detail-meta-label">Operands</span>
                        <span class="fc-detail-meta-value">@SortedOperands.Count()</span>
                    </div>
                    <div class="fc-detail-meta-item">
                        <span class="fc-detail-meta-label">Templates Referenced</span>
                        <span class="fc-detail-meta-value">@ReferencedTemplates.Count</span>
                    </div>
                    <div class="fc-detail-meta-item">
                        <span class="fc-detail-meta-label">Created By</span>
                        <span class="fc-detail-meta-value">@(_rule.CreatedBy ?? "—")</span>
                    </div>
                    <div class="fc-detail-meta-item">
                        <span class="fc-detail-meta-label">Created At</span>
                        <span class="fc-detail-meta-value">@FormatUtc(_rule.CreatedAt)</span>
                    </div>
                </div>
            </div>

        </section>

        @if (_isEditing)
        {
            <div class="fc-list-inline-form">
                <h3>Edit Cross-Sheet Rule</h3>
                <div class="fc-grid fc-grid-2">
                    <div class="fc-form-group">
                        <label>Rule Name</label>
                        <input class="fc-form-input" @bind="_editName" aria-label="Rule Name" />
                    </div>
                    <div class="fc-form-group">
                        <label>Severity</label>
                        <select class="fc-form-input" @bind="_editSeverity" aria-label="Severity">
                            @foreach (var s in Enum.GetValues<ValidationSeverity>())
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                    </div>
                    <div class="fc-form-group fc-grid-span-full">
                        <label>Description</label>
                        <input class="fc-form-input" @bind="_editDescription" placeholder="Description of the validation rule" aria-label="Description" />
                    </div>
                </div>

                <h4 class="fc-section-header">Operands</h4>
                @for (int i = 0; i < _editOperands.Count; i++)
                {
                    var idx = i;
                    <div class="fc-grid fc-grid-2 fc-operand-row fc-operand-row--2col">
                        <div class="fc-form-group">
                            <label>Alias</label>
                            <input class="fc-form-input" @bind="_editOperands[idx].Alias" aria-label="Operand Alias" />
                        </div>
                        <div class="fc-form-group">
                            <label>Template Return Code</label>
                            <input class="fc-form-input" @bind="_editOperands[idx].ReturnCode" aria-label="Template Return Code" />
                        </div>
                        <div class="fc-form-group">
                            <label>Field Name</label>
                            <input class="fc-form-input" @bind="_editOperands[idx].FieldName" aria-label="Field Name" />
                        </div>
                        <div class="fc-form-group">
                            <label>Aggregate (optional)</label>
                            <select class="fc-form-input" @bind="_editOperands[idx].Aggregate" aria-label="Aggregate function">
                                <option value="">None</option>
                                <option value="SUM">SUM</option>
                                <option value="COUNT">COUNT</option>
                                <option value="MAX">MAX</option>
                                <option value="MIN">MIN</option>
                                <option value="AVG">AVG</option>
                            </select>
                        </div>
                        <div class="fc-form-group">
                            <label>Line Code (optional)</label>
                            <input class="fc-form-input" @bind="_editOperands[idx].LineCode" aria-label="Line Code" />
                        </div>
                        <div class="fc-form-group">
                            <label>Filter Item Code (optional)</label>
                            <input class="fc-form-input" @bind="_editOperands[idx].FilterItemCode" aria-label="Filter Item Code" />
                        </div>
                    </div>
                }
                <button class="fc-btn fc-btn--outline fc-btn--sm fc-mt-2" @onclick="AddEditOperandRow">+ Add Operand</button>

                <h4 class="fc-section-header">Expression</h4>
                <div class="fc-grid fc-grid-2">
                    <div class="fc-form-group">
                        <label>Expression</label>
                        <input class="fc-form-input" @bind="_editExpression" aria-label="Expression" />
                    </div>
                    <div class="fc-form-group">
                        <label>Tolerance Amount</label>
                        <input type="number" step="0.01" class="fc-form-input" @bind="_editToleranceAmount" aria-label="Tolerance Amount" />
                    </div>
                    <div class="fc-form-group">
                        <label>Tolerance Percent (optional)</label>
                        <input type="number" step="0.01" class="fc-form-input" @bind="_editTolerancePercent" aria-label="Tolerance Percent" />
                    </div>
                    <div class="fc-form-group">
                        <label>Error Message</label>
                        <input class="fc-form-input" @bind="_editErrorMessage" aria-label="Error Message" />
                    </div>
                </div>
                <div class="fc-list-form-actions">
                    <button class="fc-btn fc-btn--primary fc-btn--sm @(_isSaving ? "fc-btn--loading" : "")" @onclick="SaveEdit" disabled="@_isSaving" aria-busy="@(_isSaving ? "true" : null)">
                        @if (_isSaving) { <span class="fc-spinner fc-spinner--sm fc-spinner--white" aria-hidden="true"></span> }
                        Save Changes
                    </button>
                    <button class="fc-btn fc-btn--outline fc-btn--sm" @onclick="CancelEdit" disabled="@_isSaving">Cancel</button>
                </div>
            </div>
        }

        <div class="fc-section">
            <div class="fc-section-header">
                <h3>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
                    Rule Definition
                </h3>
            </div>
            <div class="fc-section-body">
                <div class="fc-detail-info-grid">
                    <div class="fc-detail-info-item">
                        <span class="fc-detail-info-label">Expression</span>
                        <span class="fc-detail-info-value"><code>@(_rule.Expression?.Expression ?? "—")</code></span>
                    </div>
                    <div class="fc-detail-info-item">
                        <span class="fc-detail-info-label">Tolerance Amount</span>
                        <span class="fc-detail-info-value">@(_rule.Expression?.ToleranceAmount.ToString("0.####") ?? "—")</span>
                    </div>
                    <div class="fc-detail-info-item">
                        <span class="fc-detail-info-label">Tolerance Percent</span>
                        <span class="fc-detail-info-value">@(_rule.Expression?.TolerancePercent?.ToString("0.####") ?? "—")</span>
                    </div>
                    <div class="fc-detail-info-item">
                        <span class="fc-detail-info-label">Error Message</span>
                        <span class="fc-detail-info-value">@(_rule.Expression?.ErrorMessage ?? "—")</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="fc-section">
            <div class="fc-section-header">
                <h3>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
                    Expression Preview
                </h3>
            </div>
            <div class="fc-section-body">
                <pre class="fc-detail-code-block">@BuildExpressionPreview(_rule)</pre>
            </div>
        </div>

        <div class="fc-section">
            <div class="fc-section-header">
                <h3>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                    Operand Mapping
                </h3>
            </div>
            <div class="fc-section-body">
                @if (SortedOperands.Any())
                {
                    <div class="fc-overflow-x">
                        <table class="fc-detail-field-table" role="table">
                            <thead>
                                <tr>
                                    <th scope="col">Order</th>
                                    <th scope="col">Alias</th>
                                    <th scope="col">Template</th>
                                    <th scope="col">Field</th>
                                    <th scope="col">Line Code</th>
                                    <th scope="col">Aggregate</th>
                                    <th scope="col">Filter Item Code</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var operand in SortedOperands)
                                {
                                    <tr>
                                        <td>@operand.SortOrder</td>
                                        <td><code>@operand.OperandAlias</code></td>
                                        <td><code>@operand.TemplateReturnCode</code></td>
                                        <td><code>@operand.FieldName</code></td>
                                        <td>@(string.IsNullOrWhiteSpace(operand.LineCode) ? "—" : operand.LineCode)</td>
                                        <td>@(string.IsNullOrWhiteSpace(operand.AggregateFunction) ? "—" : operand.AggregateFunction)</td>
                                        <td>@(string.IsNullOrWhiteSpace(operand.FilterItemCode) ? "—" : operand.FilterItemCode)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="fc-alert fc-alert--inline fc-alert--error">
                        This rule has no configured operands.
                    </div>
                }
            </div>
        </div>

        <div class="fc-section">
            <div class="fc-section-header">
                <h3>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="7.5 4.21 12 6.81 16.5 4.21"/></svg>
                    Referenced Templates
                </h3>
            </div>
            <div class="fc-section-body">
                @if (ReferencedTemplates.Count == 0)
                {
                    <span class="fc-detail-info-value">No templates referenced.</span>
                }
                else
                {
                    <div class="fc-wizard-modules-row">
                        @foreach (var template in ReferencedTemplates)
                        {
                            <a href="/templates/@template" class="fc-badge fc-badge--review fc-link-plain">
                                @template
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private bool _isEditing;
    private bool _isSaving;
    private CrossSheetRule? _rule;
    private string _currentUser = string.Empty;

    // Edit form state
    private string _editName = "", _editDescription = "";
    private string _editExpression = "", _editErrorMessage = "";
    private decimal _editToleranceAmount;
    private decimal? _editTolerancePercent;
    private ValidationSeverity _editSeverity = ValidationSeverity.Error;
    private List<EditOperandModel> _editOperands = new();

    private IEnumerable<CrossSheetRuleOperand> SortedOperands =>
        _rule?.Operands
            .OrderBy(o => o.SortOrder)
            .ThenBy(o => o.OperandAlias)
        ?? Enumerable.Empty<CrossSheetRuleOperand>();

    private IReadOnlyList<string> ReferencedTemplates =>
        SortedOperands
            .Select(o => o.TemplateReturnCode)
            .Where(code => !string.IsNullOrWhiteSpace(code))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(code => code)
            .ToList();

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        var state = AuthState is null ? null : await AuthState;
        _currentUser = UserIdentityResolver.ResolveActor(state?.User);
        _rule = await FormulaRepo.GetCrossSheetRuleById(Id);
        _loading = false;
    }

    private async Task ToggleRule()
    {
        if (_rule == null) return;
        var action = _rule.IsActive ? "Disable" : "Enable";
        var confirmed = await Dialog.Confirm(new ConfirmRequest
        {
            Title = $"{action} Cross-Sheet Rule",
            Message = $"{action} rule '{_rule.RuleCode}'?",
            ConfirmText = action,
            IsDestructive = _rule.IsActive
        });
        if (!confirmed) return;

        try
        {
            await FormulaService.ToggleCrossSheetRule(_rule.Id, !_rule.IsActive, _currentUser);
            Toast.Success($"Rule '{_rule.RuleCode}' {(_rule.IsActive ? "disabled" : "enabled")}.", $"Rule {action}d");
            _rule = await FormulaRepo.GetCrossSheetRuleById(Id);
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message, $"{action} Failed");
        }
    }

    private async Task DeleteRule()
    {
        if (_rule == null) return;
        var confirmed = await Dialog.ConfirmDelete("Cross-Sheet Rule");
        if (!confirmed) return;

        try
        {
            await FormulaService.DeleteCrossSheetRule(_rule.Id, _currentUser);
            Toast.Success($"Rule '{_rule.RuleCode}' deleted.", "Rule Deleted");
            Nav.NavigateTo("/cross-sheet-rules");
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message, "Delete Failed");
        }
    }

    private void StartEdit()
    {
        if (_rule == null) return;
        _editName = _rule.RuleName;
        _editDescription = _rule.Description ?? "";
        _editSeverity = _rule.Severity;
        _editExpression = _rule.Expression?.Expression ?? "";
        _editToleranceAmount = _rule.Expression?.ToleranceAmount ?? 0;
        _editTolerancePercent = _rule.Expression?.TolerancePercent;
        _editErrorMessage = _rule.Expression?.ErrorMessage ?? "";
        _editOperands = _rule.Operands.OrderBy(o => o.SortOrder).Select(o => new EditOperandModel
        {
            Alias = o.OperandAlias,
            ReturnCode = o.TemplateReturnCode,
            FieldName = o.FieldName,
            LineCode = o.LineCode ?? "",
            Aggregate = o.AggregateFunction ?? "",
            FilterItemCode = o.FilterItemCode ?? ""
        }).ToList();
        _isEditing = true;
    }

    private void CancelEdit() => _isEditing = false;

    private void AddEditOperandRow()
    {
        var nextAlias = ((char)('A' + _editOperands.Count)).ToString();
        _editOperands.Add(new EditOperandModel { Alias = nextAlias });
    }

    private async Task SaveEdit()
    {
        if (_rule == null) return;
        if (string.IsNullOrWhiteSpace(_editName))
        {
            Toast.Error("Rule Name is required.", "Validation Error");
            return;
        }

        _isSaving = true;
        try
        {
            var operands = _editOperands.Select((o, i) => new CrossSheetRuleOperand
            {
                OperandAlias = o.Alias,
                TemplateReturnCode = o.ReturnCode,
                FieldName = o.FieldName,
                LineCode = string.IsNullOrWhiteSpace(o.LineCode) ? null : o.LineCode,
                AggregateFunction = string.IsNullOrWhiteSpace(o.Aggregate) ? null : o.Aggregate,
                FilterItemCode = string.IsNullOrWhiteSpace(o.FilterItemCode) ? null : o.FilterItemCode,
                SortOrder = i + 1
            }).ToList();

            var expression = new CrossSheetRuleExpression
            {
                Expression = _editExpression,
                ToleranceAmount = _editToleranceAmount,
                TolerancePercent = _editTolerancePercent,
                ErrorMessage = string.IsNullOrWhiteSpace(_editErrorMessage) ? null : _editErrorMessage
            };

            await FormulaService.UpdateCrossSheetRule(
                _rule.Id, _editName,
                string.IsNullOrWhiteSpace(_editDescription) ? null : _editDescription,
                operands, expression, _editSeverity, _currentUser);

            Toast.Success($"Rule '{_rule.RuleCode}' updated.", "Rule Updated");
            _isEditing = false;
            _rule = await FormulaRepo.GetCrossSheetRuleById(Id);
        }
        catch (Exception ex)
        {
            Toast.Error(ex.Message, "Update Failed");
        }
        finally
        {
            _isSaving = false;
        }
    }

    private class EditOperandModel
    {
        public string Alias { get; set; } = "";
        public string ReturnCode { get; set; } = "";
        public string FieldName { get; set; } = "";
        public string LineCode { get; set; } = "";
        public string Aggregate { get; set; } = "";
        public string FilterItemCode { get; set; } = "";
    }

    private static string StatusBadge(string status) => status.ToLowerInvariant() switch
    {
        "published" or "active" or "accepted" => "fc-badge--success",
        "draft" or "pending" => "fc-badge--warning",
        "review" or "inreview" => "fc-badge--review",
        "deprecated" or "retired" or "disabled" or "archived" => "fc-badge--muted",
        "rejected" or "failed" or "error" => "fc-badge--danger",
        "processing" or "validating" or "parsing" => "fc-badge--info",
        "acceptedwithwarnings" or "warnings" or "warning" => "fc-badge--warning",
        _ => "fc-badge--neutral"
    };

    private static string FormatUtc(DateTime dateTime)
    {
        if (dateTime == default)
        {
            return "—";
        }

        return dateTime.ToUniversalTime().ToString("d MMM yyyy, HH:mm 'UTC'");
    }

    private static string BuildExpressionPreview(CrossSheetRule rule)
    {
        var expression = rule.Expression;
        if (expression == null)
        {
            return "No expression is configured for this rule.";
        }

        var lines = new List<string>
        {
            $"Expression: {expression.Expression}"
        };

        lines.Add($"ToleranceAmount: {expression.ToleranceAmount:0.####}");

        if (expression.TolerancePercent.HasValue)
        {
            lines.Add($"TolerancePercent: {expression.TolerancePercent.Value:0.####}");
        }

        if (!string.IsNullOrWhiteSpace(expression.ErrorMessage))
        {
            lines.Add($"ErrorMessage: {expression.ErrorMessage}");
        }

        return string.Join(Environment.NewLine, lines);
    }
}
