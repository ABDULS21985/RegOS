@* Skeleton loading placeholder with shimmer wave animation *@

@switch (Variant)
{
    case SkeletonVariant.Text:
        <div class="fc-skel fc-skel-text" style="width: @Width; --skeleton-index: @Index;" aria-hidden="true"></div>
        break;

    case SkeletonVariant.TextLarge:
        <div class="fc-skel fc-skel-text-lg" style="width: @Width; --skeleton-index: @Index;" aria-hidden="true"></div>
        break;

    case SkeletonVariant.Heading:
        <div class="fc-skel fc-skel-text-xl" style="width: @Width; --skeleton-index: @Index;" aria-hidden="true"></div>
        break;

    case SkeletonVariant.Circle:
        <div class="fc-skel fc-skel-circle" style="width: @Size; height: @Size; --skeleton-index: @Index;" aria-hidden="true"></div>
        break;

    case SkeletonVariant.Block:
        <div class="fc-skel fc-skel-block" style="width: @Width; height: @Height; --skeleton-index: @Index;" aria-hidden="true"></div>
        break;

    case SkeletonVariant.Card:
        <div class="fc-skel-card" aria-hidden="true">
            <div class="fc-skel fc-skel-block" style="height: 140px; --skeleton-index: @Index;"></div>
            <div style="padding: var(--space-4); display: flex; flex-direction: column; gap: var(--space-2);">
                <div class="fc-skel fc-skel-text-lg" style="width: 70%; --skeleton-index: @(Index + 1);"></div>
                <div class="fc-skel fc-skel-text" style="width: 90%; --skeleton-index: @(Index + 2);"></div>
                <div class="fc-skel fc-skel-text" style="width: 50%; --skeleton-index: @(Index + 3);"></div>
            </div>
        </div>
        break;

    case SkeletonVariant.TableRows:
        <div aria-hidden="true">
            @for (int i = 0; i < RowCount; i++)
            {
                var rowIndex = Index + i;
                <div class="fc-skel-row">
                    <div class="fc-skel fc-skel-text" style="width: 15%; --skeleton-index: @rowIndex;"></div>
                    <div class="fc-skel fc-skel-text" style="width: 25%; --skeleton-index: @rowIndex;"></div>
                    <div class="fc-skel fc-skel-text" style="width: 20%; --skeleton-index: @rowIndex;"></div>
                    <div class="fc-skel fc-skel-text" style="width: 15%; --skeleton-index: @rowIndex;"></div>
                    <div class="fc-skel fc-skel-text" style="width: 10%; --skeleton-index: @rowIndex;"></div>
                </div>
            }
        </div>
        break;

    case SkeletonVariant.Stat:
        <div class="fc-skel-stat" aria-hidden="true">
            <div class="fc-skel fc-skel-text" style="width: 55%; --skeleton-index: @Index;"></div>
            <div class="fc-skel fc-skel-text-xl fc-skel--fast" style="width: 40%; --skeleton-index: @(Index + 1);"></div>
            <div class="fc-skel fc-skel-text" style="width: 70%; --skeleton-index: @(Index + 2);"></div>
        </div>
        break;

    case SkeletonVariant.ChartBar:
        <div class="fc-skel-card-body" aria-hidden="true">
            <div class="fc-skel fc-skel-text-lg" style="width: 45%; --skeleton-index: @Index; margin-bottom: var(--space-4);"></div>
            <div class="fc-skel-chart-bar">
                @{ var _barHeights = new[] { "60%", "80%", "45%", "90%", "55%", "70%", "65%" }; }
                @for (int i = 0; i < 7; i++)
                {
                    var barIndex = Index + i;
                    var barH = _barHeights[i];
                    <div class="fc-skel fc-skel-chart-bar__bar fc-skel--slow" style="height: @barH; --skeleton-index: @barIndex;"></div>
                }
            </div>
        </div>
        break;

    case SkeletonVariant.CalendarGrid:
        <div class="fc-skel-card-body" aria-hidden="true">
            <div class="fc-skel fc-skel-text-lg" style="width: 40%; margin-bottom: var(--space-4); --skeleton-index: @Index;"></div>
            <div class="fc-skel-cal">
                @for (int i = 0; i < 35; i++)
                {
                    var cellIndex = Index + (i / 7);
                    <div class="fc-skel fc-skel-cal__cell fc-skel--slow" style="--skeleton-index: @cellIndex;"></div>
                }
            </div>
        </div>
        break;

    case SkeletonVariant.NotificationRow:
        <div aria-hidden="true">
            @for (int i = 0; i < RowCount; i++)
            {
                var rowIndex = Index + i;
                <div class="fc-skel-notif-row">
                    <div class="fc-skel fc-skel-circle" style="width: 40px; height: 40px; --skeleton-index: @rowIndex;"></div>
                    <div class="fc-skel-notif-row__body">
                        <div class="fc-skel fc-skel-text-lg" style="width: 60%; --skeleton-index: @rowIndex;"></div>
                        <div class="fc-skel fc-skel-text" style="width: 80%; --skeleton-index: @rowIndex;"></div>
                    </div>
                </div>
            }
        </div>
        break;

    case SkeletonVariant.KanbanCard:
        <div class="fc-skel-kanban-card" aria-hidden="true">
            <div class="fc-skel fc-skel-text" style="width: 35%; --skeleton-index: @Index;"></div>
            <div class="fc-skel fc-skel-text-lg" style="width: 80%; --skeleton-index: @(Index + 1);"></div>
            <div class="fc-skel fc-skel-text" style="width: 65%; --skeleton-index: @(Index + 2);"></div>
            <div style="display: flex; gap: var(--space-2); margin-top: var(--space-2);">
                <div class="fc-skel fc-skel-text" style="width: 60px; --skeleton-index: @(Index + 3);"></div>
                <div class="fc-skel fc-skel-circle" style="width: 24px; height: 24px; --skeleton-index: @(Index + 3);"></div>
            </div>
        </div>
        break;

    case SkeletonVariant.FormField:
        <div class="fc-skel-form-field" aria-hidden="true">
            <div class="fc-skel fc-skel-text" style="width: 30%; --skeleton-index: @Index;"></div>
            <div class="fc-skel fc-skel-form-field__input" style="width: @Width; --skeleton-index: @(Index + 1);"></div>
        </div>
        break;

    case SkeletonVariant.FormTable:
        <div class="fc-skel-form-table" aria-hidden="true">
            <div class="fc-skel-form-table__header">
                @{ var _hdrW = new[] { "10%", "25%", "20%", "15%", "15%", "10%" }; }
                @for (int c = 0; c < _hdrW.Length; c++)
                {
                    <div class="fc-skel fc-skel-text" style="width: @_hdrW[c]; --skeleton-index: @Index;"></div>
                }
            </div>
            @{ var _rowW = new[] {
                new[] { "10%", "30%", "20%", "15%", "15%", "8%" },
                new[] { "10%", "25%", "22%", "12%", "18%", "8%" },
                new[] { "10%", "28%", "18%", "16%", "14%", "8%" },
                new[] { "10%", "22%", "24%", "14%", "16%", "8%" },
                new[] { "10%", "26%", "20%", "13%", "17%", "8%" }
            }; }
            @for (int r = 0; r < _rowW.Length; r++)
            {
                var rowIdx = Index + r + 1;
                <div class="fc-skel-form-table__row">
                    @for (int c = 0; c < _rowW[r].Length; c++)
                    {
                        <div class="fc-skel fc-skel-text" style="width: @_rowW[r][c]; --skeleton-index: @rowIdx;"></div>
                    }
                </div>
            }
        </div>
        break;
}

@code {
    [Parameter] public SkeletonVariant Variant { get; set; } = SkeletonVariant.Text;
    [Parameter] public string Width { get; set; } = "100%";
    [Parameter] public string Height { get; set; } = "100px";
    [Parameter] public string Size { get; set; } = "40px";
    [Parameter] public int RowCount { get; set; } = 5;
    /// <summary>Stagger index: drives animation-delay via --skeleton-index CSS var (40ms per step).</summary>
    [Parameter] public int Index { get; set; } = 0;

    public enum SkeletonVariant
    {
        Text,
        TextLarge,
        Heading,
        Circle,
        Block,
        Card,
        TableRows,
        Stat,
        ChartBar,
        CalendarGrid,
        NotificationRow,
        KanbanCard,
        FormField,
        FormTable
    }
}
