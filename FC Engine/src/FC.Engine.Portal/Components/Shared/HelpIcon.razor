<span class="portal-help-wrap">
    <button class="portal-help-icon" @onclick="Toggle" type="button" aria-label="Show field help">?</button>

    @if (_showHelp)
    {
        <div class="portal-help-popover" role="dialog">
            <h4>@(string.IsNullOrWhiteSpace(FieldLabel) ? FieldCode : FieldLabel)</h4>
            @if (!string.IsNullOrWhiteSpace(HelpText))
            {
                <p>@HelpText</p>
            }
            @if (!string.IsNullOrWhiteSpace(RegulatoryReference))
            {
                <p class="portal-help-ref">Reference: @RegulatoryReference</p>
            }
            @if (!string.IsNullOrWhiteSpace(DataType))
            {
                <p class="portal-help-type">Data type: @DataType</p>
            }
        </div>
    }
</span>

@code {
    [Parameter] public string? FieldCode { get; set; }
    [Parameter] public string? FieldLabel { get; set; }
    [Parameter] public string? HelpText { get; set; }
    [Parameter] public string? RegulatoryReference { get; set; }
    [Parameter] public string? DataType { get; set; }

    private bool _showHelp;

    private void Toggle()
    {
        _showHelp = !_showHelp;
    }
}
