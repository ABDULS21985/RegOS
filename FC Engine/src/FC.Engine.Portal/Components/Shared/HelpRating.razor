@* Article helpfulness rating — thumbs up/down persisted in localStorage *@
@inject IJSRuntime JS

<div class="fc-hr-wrapper" role="region" aria-label="Article feedback">
    @if (_rated is null)
    {
        <p class="fc-hr-prompt">Was this article helpful?</p>
        <div class="fc-hr-buttons">
            <button class="fc-hr-btn fc-hr-btn--yes" @onclick='() => Rate(true)' type="button" aria-label="Yes, this was helpful">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M14 9V5a3 3 0 00-3-3l-4 9v11h11.28a2 2 0 002-1.7l1.38-9a2 2 0 00-2-2.3H14z"/>
                    <path d="M7 22H4a2 2 0 01-2-2v-7a2 2 0 012-2h3"/>
                </svg>
                Yes
            </button>
            <button class="fc-hr-btn fc-hr-btn--no" @onclick='() => Rate(false)' type="button" aria-label="No, this was not helpful">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M10 15v4a3 3 0 003 3l4-9V2H5.72a2 2 0 00-2 1.7l-1.38 9a2 2 0 002 2.3H10z"/>
                    <path d="M17 2h2.67A2.31 2.31 0 0122 4v7a2.31 2.31 0 01-2.33 2H17"/>
                </svg>
                No
            </button>
        </div>
    }
    else if (_rated == true)
    {
        <div class="fc-hr-thanks fc-hr-thanks--yes">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            Thanks for the feedback! Glad this was helpful.
        </div>
    }
    else
    {
        <div class="fc-hr-thanks fc-hr-thanks--no">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Thanks for the feedback.
            <a href="/help/support">Contact support</a> if you need more help.
        </div>
    }
</div>

@code {
    [Parameter] public string ArticleId { get; set; } = "";

    private bool? _rated = null;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !string.IsNullOrEmpty(ArticleId))
        {
            try
            {
                var existing = await JS.InvokeAsync<System.Text.Json.JsonElement?>("fcHelp.getArticleRating", ArticleId);
                if (existing.HasValue && existing.Value.ValueKind == System.Text.Json.JsonValueKind.True)
                    _rated = true;
                else if (existing.HasValue && existing.Value.ValueKind == System.Text.Json.JsonValueKind.False)
                    _rated = false;
                StateHasChanged();
            }
            catch { }
        }
    }

    private async Task Rate(bool helpful)
    {
        _rated = helpful;
        try { await JS.InvokeVoidAsync("fcHelp.rateArticle", ArticleId, helpful); } catch { }
    }
}
