@* Global toast notification container — placed once in PortalLayout *@
@using FC.Engine.Portal.Services
@inject ToastService ToastService
@implements IDisposable

<div class="portal-toast-container" aria-label="Notifications">
    @foreach (var toast in ToastService.Toasts)
    {
        <div class="portal-toast portal-toast-@GetVariantClass(toast.Variant) @(toast.IsExiting ? "portal-toast-exiting" : "")"
             role="@GetAriaRole(toast.Variant)"
             aria-live="@(toast.Variant is ToastVariant.Error or ToastVariant.Warning ? "assertive" : "polite")"
             aria-atomic="true">

            <div class="portal-toast-icon" aria-hidden="true">
                @switch (toast.Variant)
                {
                    case ToastVariant.Success:
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                            <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                            <polyline points="22 4 12 14.01 9 11.01"/>
                        </svg>
                        break;
                    case ToastVariant.Warning:
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                            <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                            <line x1="12" y1="9" x2="12" y2="13"/>
                            <line x1="12" y1="17" x2="12.01" y2="17"/>
                        </svg>
                        break;
                    case ToastVariant.Error:
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="15" y1="9" x2="9" y2="15"/>
                            <line x1="9" y1="9" x2="15" y2="15"/>
                        </svg>
                        break;
                    case ToastVariant.Loading:
                        <svg class="portal-toast-spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" width="18" height="18">
                            <circle cx="12" cy="12" r="10" stroke-dasharray="50.27" stroke-dashoffset="37.7" opacity="0.25"/>
                            <path d="M12 2a10 10 0 0 1 10 10"/>
                        </svg>
                        break;
                    default: @* Info *@
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="16" x2="12" y2="12"/>
                            <line x1="12" y1="8" x2="12.01" y2="8"/>
                        </svg>
                        break;
                }
            </div>

            <div class="portal-toast-content">
                @if (!string.IsNullOrEmpty(toast.Title))
                {
                    <strong class="portal-toast-title">@toast.Title</strong>
                }
                <span class="portal-toast-message">
                    @toast.Message
                    @if (toast.DuplicateCount > 1)
                    {
                        <span class="portal-toast-count" aria-label="@toast.DuplicateCount occurrences">x@toast.DuplicateCount</span>
                    }
                </span>
                @if (!string.IsNullOrEmpty(toast.ActionLabel))
                {
                    <button class="portal-toast-action" type="button"
                            @onclick="() => { toast.ActionCallback?.Invoke(); ToastService.Dismiss(toast.Id); }">
                        @toast.ActionLabel
                    </button>
                }
            </div>

            @if (toast.Dismissible)
            {
                <button class="portal-toast-dismiss" @onclick="() => ToastService.Dismiss(toast.Id)"
                        aria-label="Dismiss notification" type="button">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" aria-hidden="true">
                        <line x1="18" y1="6" x2="6" y2="18"/>
                        <line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
            }

            @if (toast.DurationMs > 0 && !toast.IsExiting)
            {
                <div class="portal-toast-progress portal-toast-progress-@GetVariantClass(toast.Variant)"
                     style="animation-duration: @(toast.DurationMs)ms"
                     aria-hidden="true"></div>
            }
        </div>
    }

    @if (ToastService.QueuedCount > 0)
    {
        <div class="portal-toast-queue-badge" aria-live="polite" aria-atomic="true">
            @ToastService.QueuedCount more waiting
        </div>
    }
</div>

@code {
    protected override void OnInitialized()
    {
        ToastService.OnChange += HandleStateChanged;
    }

    private void HandleStateChanged() => InvokeAsync(StateHasChanged);

    private static string GetVariantClass(ToastVariant variant) => variant switch
    {
        ToastVariant.Success => "success",
        ToastVariant.Warning => "warning",
        ToastVariant.Error   => "error",
        ToastVariant.Loading => "loading",
        _                    => "info"
    };

    private static string GetAriaRole(ToastVariant variant) => variant switch
    {
        ToastVariant.Error or ToastVariant.Warning => "alert",
        _                                          => "status"
    };

    public void Dispose()
    {
        ToastService.OnChange -= HandleStateChanged;
    }
}
