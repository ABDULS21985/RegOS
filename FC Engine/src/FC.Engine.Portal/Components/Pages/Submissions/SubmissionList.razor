    public void Dispose()
    {
        _dotNetRef?.Dispose();
        _ = DragDrop.Destroy("submissions-kanban");
        _ = DragDrop.Destroy("submissions-table");
        _ = JS.InvokeVoidAsync("portalDisposeEscHandler");
    }

    private static string RelativeTime(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt.ToUniversalTime();
        if (diff.TotalMinutes < 2) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return dt.ToString("d MMM");
    }

    private static string GetCardAccentClass(string status) => status switch
    {
        "Accepted" => "portal-kanban-card--accent-success",
        "AcceptedWithWarnings" => "portal-kanban-card--accent-warning",
        "Rejected" or "ApprovalRejected" => "portal-kanban-card--accent-danger",
        "PendingApproval" => "portal-kanban-card--accent-info",
        _ => "portal-kanban-card--accent-neutral"
    };

    private async Task LoadSubmissions()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            var state = await AuthState!;
            var instIdStr = state.User.FindFirst("InstitutionId")?.Value;
            int.TryParse(instIdStr, out var institutionId);

            var rawSubmissions = await SubmissionRepo.GetByInstitution(institutionId);

            var allTemplates = await TemplateCache.GetAllPublishedTemplates();
            var templateNameMap = allTemplates.ToDictionary(
                t => t.ReturnCode,
                t => t.Name,
                StringComparer.OrdinalIgnoreCase
            );

            submissions = rawSubmissions.Select(s => new SubmissionListItem
            {
                Id = s.Id,
                ReturnCode = s.ReturnCode,
                TemplateName = templateNameMap.GetValueOrDefault(s.ReturnCode, s.ReturnCode),
                PeriodLabel = s.ReturnPeriod is not null
                    ? new DateTime(s.ReturnPeriod.Year, s.ReturnPeriod.Month, 1).ToString("MMM yyyy")
                    : "—",
                SubmittedAt = s.SubmittedAt,
                Status = s.Status.ToString(),
                ErrorCount = s.ValidationReport?.ErrorCount ?? 0,
                WarningCount = s.ValidationReport?.WarningCount ?? 0,
                ProcessingDurationMs = s.ProcessingDurationMs
            }).OrderByDescending(s => s.SubmittedAt).ToList();

            availableReturnCodes = submissions
                .Select(s => s.ReturnCode)
                .Distinct()
                .OrderBy(c => c)
                .ToList();

            ApplyFilters();
        }
        catch
        {
            // Silently handle — empty list shown
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void ApplyFilters()
    {
        _selectedIds.Clear();
        _allMatchingSelected = false;
        var query = submissions.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            var q = searchQuery.Trim();
            query = query.Where(s =>
                s.ReturnCode.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                s.Id.ToString().Contains(q) ||
                (s.TemplateName?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false)
            );
        }

        if (!string.IsNullOrEmpty(filterStatus))
        {
            query = query.Where(s => s.Status.Equals(filterStatus, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrEmpty(filterReturnCode))
        {
            query = query.Where(s => s.ReturnCode.Equals(filterReturnCode, StringComparison.OrdinalIgnoreCase));
        }

        query = sortBy switch
        {
            "date-asc" => query.OrderBy(s => s.SubmittedAt),
            "status" => query.OrderBy(s => s.Status).ThenByDescending(s => s.SubmittedAt),
            "returncode" => query.OrderBy(s => s.ReturnCode).ThenByDescending(s => s.SubmittedAt),
            _ => query.OrderByDescending(s => s.SubmittedAt)
        };

        filteredSubmissions = query.ToList();
        currentPage = 1;
        StateHasChanged();
    }

    private void ClearAllFilters()
    {
        searchQuery = "";
        filterStatus = "";
        filterReturnCode = "";
        sortBy = "date-desc";
        ApplyFilters();
    }

    private void ToggleSelectAll()
    {
        _allMatchingSelected = false;
        if (AllPageSelected)
            foreach (var sub in pagedSubmissions) _selectedIds.Remove(sub.Id);
        else
            foreach (var sub in pagedSubmissions) _selectedIds.Add(sub.Id);
        _lastSelectedPageIndex = -1;
        StateHasChanged();
    }

    private void ToggleSelect(MouseEventArgs e, int id, int pageIndex)
    {
        _allMatchingSelected = false;
        if (e.ShiftKey && _lastSelectedPageIndex >= 0)
        {
            int minIdx = Math.Min(_lastSelectedPageIndex, pageIndex);
            int maxIdx = Math.Max(_lastSelectedPageIndex, pageIndex);
            bool shouldSelect = !_selectedIds.Contains(id);
            for (int i = minIdx; i <= maxIdx && i < pagedSubmissions.Count; i++)
            {
                if (shouldSelect) _selectedIds.Add(pagedSubmissions[i].Id);
                else _selectedIds.Remove(pagedSubmissions[i].Id);
            }
        }
        else
        {
            if (_selectedIds.Contains(id)) _selectedIds.Remove(id);
            else _selectedIds.Add(id);
            _lastSelectedPageIndex = pageIndex;
        }
        StateHasChanged();
    }

    private void OnRowKeyDown(KeyboardEventArgs e, int id, int pageIndex)
    {
        if (e.Key == " " || e.Key == "Spacebar")
        {
            _allMatchingSelected = false;
            if (_selectedIds.Contains(id)) _selectedIds.Remove(id);
            else _selectedIds.Add(id);
            _lastSelectedPageIndex = pageIndex;
            StateHasChanged();
        }
    }

    private void SelectAllMatching()
    {
        _allMatchingSelected = true;
        foreach (var sub in filteredSubmissions) _selectedIds.Add(sub.Id);
        StateHasChanged();
    }

    private void DeselectAll()
    {
        _selectedIds.Clear();
        _allMatchingSelected = false;
        StateHasChanged();
    }

    [JSInvokable]
    public void HandleEscapeKey()
    {
        if (_selectedIds.Any())
        {
            _selectedIds.Clear();
            _allMatchingSelected = false;
            InvokeAsync(StateHasChanged);
        }
    }

