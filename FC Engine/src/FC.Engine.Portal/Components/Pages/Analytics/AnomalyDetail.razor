@page "/analytics/anomalies/{ReportId:int}"
@attribute [Authorize]
@inject IAnomalyDetectionService AnomalyService
@inject NavigationManager Navigation
@inject ToastService Toast

<PageTitle>Anomaly Detail</PageTitle>

<div class="portal-page portal-ad-shell">
    <PortalPageHeader Title="@(_report is null ? "Anomaly Detail" : $"{_report.ModuleCode} · {_report.PeriodCode}")"
                      Subtitle="Review explanations, acknowledge legitimate outliers, and confirm the return is ready to move forward."
                      BackUrl="/analytics/anomalies"
                      Breadcrumb="@_breadcrumb">
        <PrimaryAction>
            @if (_report is not null)
            {
                <span class="portal-ad-traffic @TrafficLightClass(_report.TrafficLight)">@_report.TrafficLight</span>
            }
        </PrimaryAction>
    </PortalPageHeader>

    @if (_isLoading)
    {
        <div class="portal-ad-flow" aria-busy="true" aria-label="Loading anomaly details">
            <div class="portal-ad-stat-grid">
                @for (var i = 0; i < 4; i++)
                {
                    <div class="portal-ad-stat portal-skeleton" style="height: 120px;"></div>
                }
            </div>
            <div class="portal-card portal-skeleton" style="height: 120px;"></div>
            <div class="portal-card portal-skeleton" style="height: 400px;"></div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="portal-ad-error">
            <strong>Unable to load anomaly report.</strong>
            <span>@_error</span>
            <button class="portal-btn portal-btn-primary portal-btn-sm" @onclick="LoadAsync">Retry</button>
        </div>
    }
    else if (_report is null)
    {
        <div class="portal-ad-empty portal-card">
            <h3>Report not found</h3>
            <p>This anomaly report could not be located. It may have been removed or belong to another tenant.</p>
            <a class="portal-btn portal-btn-primary portal-btn-sm" href="/analytics/anomalies">Back to dashboard</a>
        </div>
    }
    else
    {
        var unackCount = _report.Findings.Count(x => !x.IsAcknowledged);

        <div class="portal-ad-flow">
            <section class="portal-ad-stat-grid" aria-label="Report metrics">
                <article class="portal-ad-stat">
                    <span class="portal-ad-stat-label">Institution</span>
                    <strong class="portal-ad-stat-value portal-ad-stat-value--sm">@_report.InstitutionName</strong>
                    <span class="portal-ad-stat-note">@_report.ModuleCode · @_report.PeriodCode</span>
                </article>
                <article class="portal-ad-stat">
                    <span class="portal-ad-stat-label">Quality score</span>
                    <strong class="portal-ad-stat-value @QualityValueClass(_report.OverallQualityScore)">@_report.OverallQualityScore.ToString("F1")%</strong>
                    <span class="portal-ad-stat-note">Overall quality assessment for this return.</span>
                </article>
                <article class="portal-ad-stat">
                    <span class="portal-ad-stat-label">Total findings</span>
                    <strong class="portal-ad-stat-value">@_report.TotalFindings</strong>
                    <span class="portal-ad-stat-note">Statistical signals across all detection methods.</span>
                </article>
                <article class="portal-ad-stat">
                    <span class="portal-ad-stat-label">Unacknowledged</span>
                    <strong class="portal-ad-stat-value @(unackCount > 0 ? "portal-ad-stat-value--warning" : "portal-ad-stat-value--success")">@unackCount</strong>
                    <span class="portal-ad-stat-note">Findings still pending human review.</span>
                </article>
            </section>

            <section class="portal-card portal-ad-panel">
                <div class="portal-ad-panel-head">
                    <div>
                        <span class="portal-ad-panel-eyebrow">Narrative</span>
                        <h2 class="portal-ad-panel-title">Assessment summary</h2>
                    </div>
                </div>
                <div class="portal-ad-panel-body">
                    <p class="portal-ad-narrative">@_report.NarrativeSummary</p>
                </div>
            </section>

            @if (_activeFindingId.HasValue)
            {
                <section class="portal-card portal-ad-panel portal-ad-ack-panel">
                    <div class="portal-ad-panel-head">
                        <div>
                            <span class="portal-ad-panel-eyebrow">Acknowledgement</span>
                            <h2 class="portal-ad-panel-title">Acknowledge finding</h2>
                        </div>
                    </div>
                    <div class="portal-ad-panel-body">
                        <div class="portal-ad-ack-form">
                            <label class="portal-ad-label" for="ack-reason">Reason</label>
                            <textarea id="ack-reason"
                                      class="portal-ad-textarea"
                                      rows="3"
                                      @bind="_ackReason"
                                      placeholder="Explain why this anomaly is valid and does not require correction."></textarea>
                        </div>
                        <div class="portal-ad-ack-actions">
                            <button class="portal-btn portal-btn-primary portal-btn-sm" @onclick="ConfirmAcknowledgementAsync" disabled="@string.IsNullOrWhiteSpace(_ackReason)">Save acknowledgement</button>
                            <button class="portal-btn portal-btn-ghost portal-btn-sm" @onclick="CancelAcknowledgement">Cancel</button>
                        </div>
                    </div>
                </section>
            }

            @foreach (var group in _report.Findings.GroupBy(x => x.FindingType).OrderBy(x => x.Key))
            {
                <section class="portal-card portal-ad-panel">
                    <div class="portal-ad-panel-head">
                        <div>
                            <span class="portal-ad-panel-eyebrow">@group.Key detection</span>
                            <h2 class="portal-ad-panel-title">@group.Key findings</h2>
                            <p class="portal-ad-panel-copy">@group.Count() finding(s) detected via @group.Key.ToLowerInvariant() analysis.</p>
                        </div>
                    </div>
                    <div class="portal-ad-table-wrap">
                        <table class="portal-ad-table" aria-label="@($"{group.Key} findings")">
                            <thead>
                                <tr>
                                    <th>Field</th>
                                    <th>Reported</th>
                                    <th>Expected</th>
                                    <th>Severity</th>
                                    <th>Explanation</th>
                                    <th>Status</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var finding in group.OrderByDescending(x => SeverityRank(x.Severity)).ThenBy(x => x.FieldLabel))
                                {
                                    <tr>
                                        <td>
                                            <div class="portal-ad-field-name">@finding.FieldLabel</div>
                                            @if (!string.IsNullOrWhiteSpace(finding.RelatedFieldLabel))
                                            {
                                                <div class="portal-ad-field-related">paired with @finding.RelatedFieldLabel</div>
                                            }
                                        </td>
                                        <td>@(finding.ReportedValue?.ToString("N2") ?? "N/A")</td>
                                        <td>@ResolveExpectedValue(finding)</td>
                                        <td><span class="portal-ad-badge @SeverityClass(finding.Severity)">@finding.Severity</span></td>
                                        <td class="portal-ad-explanation">@finding.Explanation</td>
                                        <td>
                                            @if (finding.IsAcknowledged)
                                            {
                                                <span class="portal-ad-badge portal-ad-badge--success">Acknowledged</span>
                                                <div class="portal-ad-ack-meta">@finding.AcknowledgedBy · @finding.AcknowledgedAt?.ToString("dd MMM HH:mm")</div>
                                            }
                                            else
                                            {
                                                <span class="portal-ad-badge portal-ad-badge--muted">Pending review</span>
                                            }
                                        </td>
                                        <td class="portal-ad-action-cell">
                                            @if (finding.IsAcknowledged)
                                            {
                                                <button class="portal-btn portal-btn-ghost portal-btn-sm" @onclick="() => RevokeAcknowledgementAsync(finding.Id)">Revoke</button>
                                            }
                                            else
                                            {
                                                <button class="portal-btn portal-btn--outline portal-btn-sm" @onclick="() => StartAcknowledgement(finding.Id)">Acknowledge</button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </section>
            }
        </div>
    }
</div>

<style>
    .portal-ad-shell {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .portal-ad-flow {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .portal-ad-stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1rem;
    }

    .portal-ad-stat {
        display: grid;
        gap: 0.75rem;
        padding: 1.1rem 1.15rem;
        border-radius: 22px;
        background: linear-gradient(180deg, rgba(255,255,255,.98), rgba(248,251,248,.95));
        border: 1px solid rgba(15, 23, 42, 0.08);
        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.07);
    }

    .portal-ad-stat-label {
        color: var(--portal-muted-strong, #64748b);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
    }

    .portal-ad-stat-value {
        font-size: 1.8rem;
        line-height: 1;
        color: var(--portal-text, #18212f);
    }

    .portal-ad-stat-value--sm { font-size: 1.2rem; }
    .portal-ad-stat-value--success { color: #0b6b3f; }
    .portal-ad-stat-value--warning { color: #b97908; }
    .portal-ad-stat-value--danger { color: #b91c1c; }

    .portal-ad-stat-note {
        color: var(--portal-muted, #66758b);
        line-height: 1.6;
    }

    .portal-ad-panel {
        border-radius: 26px;
        overflow: hidden;
        border: 1px solid rgba(15, 23, 42, 0.08);
        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.07);
    }

    .portal-ad-panel-head {
        padding: 1.25rem 1.35rem 0;
    }

    .portal-ad-panel-eyebrow {
        color: var(--portal-muted-strong, #64748b);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
    }

    .portal-ad-panel-title {
        margin: 0.5rem 0 0;
        color: var(--portal-text, #18212f);
        font-weight: 800;
        letter-spacing: -0.03em;
    }

    .portal-ad-panel-copy {
        color: var(--portal-muted, #66758b);
        line-height: 1.6;
    }

    .portal-ad-panel-body {
        padding: 1rem 1.35rem 1.35rem;
    }

    .portal-ad-narrative {
        margin: 0;
        color: var(--portal-text, #18212f);
        line-height: 1.7;
    }

    .portal-ad-ack-panel {
        border-color: rgba(0, 107, 63, 0.2);
        background: linear-gradient(180deg, rgba(247, 254, 249, 0.97), rgba(255,255,255,.97));
    }

    .portal-ad-ack-form {
        margin-bottom: 1rem;
    }

    .portal-ad-label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 600;
        color: var(--portal-text, #18212f);
    }

    .portal-ad-textarea {
        display: block;
        width: 100%;
        padding: 0.75rem;
        border: 1px solid rgba(148, 163, 184, 0.4);
        border-radius: 14px;
        font-size: 0.92rem;
        line-height: 1.5;
        background: #fff;
        resize: vertical;
        transition: border-color 150ms ease;
    }

    .portal-ad-textarea:focus {
        outline: none;
        border-color: var(--cbn-green-deep, #006B3F);
        box-shadow: 0 0 0 3px rgba(0, 107, 63, 0.12);
    }

    .portal-ad-ack-actions {
        display: flex;
        gap: 0.75rem;
    }

    .portal-ad-table-wrap {
        overflow: auto;
        padding: 1rem 1.35rem 1.35rem;
    }

    .portal-ad-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.92rem;
    }

    .portal-ad-table th,
    .portal-ad-table td {
        padding: 0.8rem 0.5rem;
        border-bottom: 1px solid rgba(148, 163, 184, 0.2);
        text-align: left;
    }

    .portal-ad-table th {
        color: var(--portal-muted-strong, #64748b);
        font-size: 0.75rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .portal-ad-field-name {
        font-weight: 600;
        color: var(--portal-text, #18212f);
    }

    .portal-ad-field-related {
        font-size: 0.82rem;
        color: var(--portal-muted, #66758b);
    }

    .portal-ad-explanation {
        min-width: 340px;
        color: var(--portal-muted, #66758b);
        line-height: 1.5;
    }

    .portal-ad-ack-meta {
        font-size: 0.78rem;
        color: var(--portal-muted, #66758b);
        margin-top: 0.35rem;
    }

    .portal-ad-action-cell {
        text-align: right;
        white-space: nowrap;
    }

    .portal-ad-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 72px;
        min-height: 28px;
        padding: 0 0.7rem;
        border-radius: 999px;
        font-size: 0.76rem;
        font-weight: 700;
    }

    .portal-ad-badge--danger { background: rgba(185, 28, 28, 0.12); color: #b91c1c; }
    .portal-ad-badge--warning { background: rgba(224, 124, 36, 0.14); color: #b97908; }
    .portal-ad-badge--info { background: rgba(14, 165, 233, 0.12); color: #0369a1; }
    .portal-ad-badge--success { background: rgba(11, 107, 63, 0.12); color: #0b6b3f; }
    .portal-ad-badge--muted { background: rgba(100, 116, 139, 0.12); color: #64748b; }

    .portal-ad-traffic {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 80px;
        min-height: 34px;
        padding: 0 0.9rem;
        border-radius: 999px;
        font-size: 0.82rem;
        font-weight: 800;
        color: #fff;
    }

    .portal-ad-traffic--danger { background: linear-gradient(135deg, #b91c1c, #dc2626); }
    .portal-ad-traffic--warning { background: linear-gradient(135deg, #b45309, #f59e0b); color: #1a1a1a; }
    .portal-ad-traffic--success { background: linear-gradient(135deg, #0f7a4b, #16a34a); }

    .portal-ad-error,
    .portal-ad-empty {
        display: grid;
        gap: 0.75rem;
        padding: 1.25rem;
        border-radius: 24px;
        background: rgba(255,255,255,.97);
        border: 1px solid rgba(15, 23, 42, 0.08);
        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.07);
    }

    .portal-ad-error { color: #991b1b; }

    .portal-ad-empty {
        text-align: center;
        justify-items: center;
        padding: 2rem;
    }

    .portal-ad-empty h3 { margin: 0; color: var(--portal-text, #18212f); }
    .portal-ad-empty p { color: var(--portal-muted, #66758b); max-width: 48ch; }

    @@media (max-width: 860px) {
        .portal-ad-stat-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 560px) {
        .portal-ad-stat-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    [Parameter] public int ReportId { get; set; }
    [CascadingParameter] private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private readonly List<BreadcrumbItem> _breadcrumb =
    [
        new("Home", "/"),
        new("Analytics", "/analytics/foresight"),
        new("Anomalies", "/analytics/anomalies"),
        new("Detail", IsCurrent: true)
    ];

    private AnomalyReport? _report;
    private bool _isLoading = true;
    private string? _error;
    private int? _activeFindingId;
    private string _ackReason = string.Empty;

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;

        try
        {
            var auth = await AuthenticationStateTask;
            var tenantId = PortalTenantClaimResolver.ResolveTenantId(auth.User);
            _report = await AnomalyService.GetReportByIdAsync(ReportId, tenantId);
        }
        catch (Exception ex)
        {
            _error = $"Unable to load anomaly report: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void StartAcknowledgement(int findingId)
    {
        _activeFindingId = findingId;
        _ackReason = string.Empty;
    }

    private void CancelAcknowledgement()
    {
        _activeFindingId = null;
        _ackReason = string.Empty;
    }

    private async Task ConfirmAcknowledgementAsync()
    {
        if (!_activeFindingId.HasValue)
        {
            return;
        }

        try
        {
            var auth = await AuthenticationStateTask;
            var tenantId = PortalTenantClaimResolver.ResolveTenantId(auth.User);
            var acknowledgedBy = auth.User.Identity?.Name
                ?? auth.User.FindFirst(ClaimTypes.Email)?.Value
                ?? "portal-user";

            await AnomalyService.AcknowledgeFindingAsync(new AnomalyAcknowledgementRequest
            {
                FindingId = _activeFindingId.Value,
                TenantId = tenantId,
                Reason = _ackReason.Trim(),
                AcknowledgedBy = acknowledgedBy
            });

            Toast.Success("Finding acknowledged successfully.");
            CancelAcknowledgement();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = $"Unable to save acknowledgement: {ex.Message}";
        }
    }

    private async Task RevokeAcknowledgementAsync(int findingId)
    {
        try
        {
            var auth = await AuthenticationStateTask;
            var tenantId = PortalTenantClaimResolver.ResolveTenantId(auth.User);
            var revokedBy = auth.User.Identity?.Name
                ?? auth.User.FindFirst(ClaimTypes.Email)?.Value
                ?? "portal-user";

            await AnomalyService.RevokeAcknowledgementAsync(findingId, tenantId, revokedBy);
            Toast.Success("Acknowledgement revoked.");
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = $"Unable to revoke acknowledgement: {ex.Message}";
        }
    }

    private static int SeverityRank(string severity) => severity switch
    {
        "ALERT" => 3,
        "WARNING" => 2,
        "INFO" => 1,
        _ => 0
    };

    private static string TrafficLightClass(string trafficLight) => trafficLight switch
    {
        "RED" => "portal-ad-traffic--danger",
        "AMBER" => "portal-ad-traffic--warning",
        _ => "portal-ad-traffic--success"
    };

    private static string SeverityClass(string severity) => severity switch
    {
        "ALERT" => "portal-ad-badge--danger",
        "WARNING" => "portal-ad-badge--warning",
        _ => "portal-ad-badge--info"
    };

    private static string QualityValueClass(decimal score) => score switch
    {
        >= 90m => "portal-ad-stat-value--success",
        >= 75m => "portal-ad-stat-value--warning",
        _ => "portal-ad-stat-value--danger"
    };

    private static string ResolveExpectedValue(AnomalyFinding finding)
    {
        if (finding.ExpectedRangeLow.HasValue || finding.ExpectedRangeHigh.HasValue)
        {
            return $"{finding.ExpectedRangeLow?.ToString("N2") ?? "N/A"} - {finding.ExpectedRangeHigh?.ToString("N2") ?? "N/A"}";
        }

        if (finding.ExpectedValue.HasValue)
        {
            return finding.ExpectedValue.Value.ToString("N2");
        }

        if (finding.BaselineValue.HasValue)
        {
            return finding.BaselineValue.Value.ToString("N2");
        }

        return "N/A";
    }
}
