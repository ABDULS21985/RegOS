@page "/"
@attribute [Authorize]

<PageTitle>Dashboard — FC Engine Portal</PageTitle>

<div class="portal-page-header">
    <h1 class="portal-page-title">Dashboard</h1>
    <p class="portal-page-subtitle">Financial Institution Reporting Portal</p>
</div>

<div class="portal-placeholder">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="48" height="48" style="color: #9ca3af; margin-bottom: 1rem;" aria-hidden="true">
        <rect x="3" y="3" width="7" height="7"/>
        <rect x="14" y="3" width="7" height="7"/>
        <rect x="14" y="14" width="7" height="7"/>
        <rect x="3" y="14" width="7" height="7"/>
    </svg>
    <p style="font-size: 1rem; font-weight: 600; color: #374151;">Welcome to the FC Engine Portal</p>
    <p>Your institution dashboard with compliance overview, submission status, and upcoming deadlines will be here.</p>
</div>
