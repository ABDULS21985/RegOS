                <div>
                    <strong>ISO 27001</strong>
                    <span>Certified Security</span>
                </div>
            </div>
            <div class="lp-trust-divider" aria-hidden="true"></div>
            <div class="lp-trust-item">
                <svg viewBox="0 0 20 20" fill="currentColor" width="20" height="20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
                </svg>
                <div>
                    <strong>99.9% Uptime</strong>
                    <span>Since 2019</span>
                </div>
            </div>
        </div>
    </section>

    @* ══════════════════════════════════════════════════════════════
       STATS MARQUEE
       ══════════════════════════════════════════════════════════════ *@
    <section class="lp-stats" aria-label="Platform statistics">
        <div class="lp-stats-grid">
            <div class="lp-stat-card">
                <span class="lp-stat-number">500+</span>
                <span class="lp-stat-label">Licensed Institutions</span>
                <span class="lp-stat-desc">Banks, MFBs, OFIs, and PMIs actively filing</span>
            </div>
            <div class="lp-stat-card">
                <span class="lp-stat-number">&#8358;2.3T</span>
                <span class="lp-stat-label">Returns Processed</span>
                <span class="lp-stat-desc">Annual volume of regulatory filings</span>
            </div>
            <div class="lp-stat-card">
                <span class="lp-stat-number">12</span>
                <span class="lp-stat-label">Regulatory Modules</span>
                <span class="lp-stat-desc">CISS, eFASS, MDFR, FDR, CCDR, and more</span>
            </div>
            <div class="lp-stat-card">
                <span class="lp-stat-number">80%</span>
                <span class="lp-stat-label">Faster Filing</span>
                <span class="lp-stat-desc">Average time saved vs. manual reporting</span>
            </div>
        </div>
    </section>

    @* ══════════════════════════════════════════════════════════════
       FEATURES GRID
       ══════════════════════════════════════════════════════════════ *@
    <section class="lp-features" id="features">
        <div class="lp-section-head">
            <span class="lp-overline">Capabilities</span>
            <h2 class="lp-section-title">Everything your compliance team needs</h2>
            <p class="lp-section-desc">From data entry to final submission — a unified workspace that replaces spreadsheets, emails, and manual reconciliation with one intelligent platform.</p>
        </div>

        <div class="lp-features-grid">
            @* Feature 1 — Smart Data Entry *@
            <div class="lp-feature-card lp-feature-card--highlight">
                <div class="lp-feature-icon lp-feature-icon--green">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="28" height="28">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
                    </svg>
                </div>
                <h3>Smart Data Entry</h3>
                <p>Template-driven forms with auto-calculated fields, cross-sheet validation, and section-by-section progress tracking. Save drafts and resume anytime.</p>
                <div class="lp-feature-tags">
                    <span>Auto-calculate</span>
                    <span>Drag & drop</span>
                    <span>Bulk upload</span>
                </div>
            </div>

            @* Feature 2 — Real-Time Validation *@
            <div class="lp-feature-card">
                <div class="lp-feature-icon lp-feature-icon--emerald">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="28" height="28">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                        <polyline points="22 4 12 14.01 9 11.01"/>
                    </svg>
                </div>
                <h3>Real-Time Validation</h3>
                <p>300+ CBN validation rules run as you type. Fix errors before submission, not after rejection. Dry-run validation gives you confidence.</p>
                <div class="lp-feature-tags">
                    <span>300+ rules</span>
                    <span>Instant feedback</span>
                    <span>Dry-run</span>
                </div>
            </div>

            @* Feature 3 — Compliance Dashboard *@
            <div class="lp-feature-card">
                <div class="lp-feature-icon lp-feature-icon--blue">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="28" height="28">
                        <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                        <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
                    </svg>
                </div>
                <h3>Compliance Dashboard</h3>
                <p>Bird's-eye view of submission status, overdue returns, validation scores, and deadline coverage across every module in your workspace.</p>
                <div class="lp-feature-tags">
                    <span>Heat maps</span>
                    <span>Trend lines</span>
                    <span>Module view</span>
                </div>
            </div>

            @* Feature 4 — Analytics & ForeSight *@
            <div class="lp-feature-card">
                <div class="lp-feature-icon lp-feature-icon--gold">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="28" height="28">
                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                    </svg>
                </div>
                <h3>Analytics &amp; ForeSight</h3>
                <p>Anomaly detection, trend analysis, and predictive insights powered by AI. Spot outliers before the regulator does.</p>
                <div class="lp-feature-tags">
                    <span>AI-powered</span>
                    <span>Anomaly alerts</span>
                    <span>Forecasting</span>
                </div>
            </div>

            @* Feature 5 — Calendar & Deadlines *@
            <div class="lp-feature-card">
                <div class="lp-feature-icon lp-feature-icon--orange">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="28" height="28">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/>
                        <line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                    </svg>
                </div>
                <h3>Calendar &amp; Deadlines</h3>
                <p>Never miss a filing window. Smart calendar shows every reporting period, deadline, and extension — with email and in-app reminders.</p>
                <div class="lp-feature-tags">
                    <span>Reminders</span>
                    <span>Extensions</span>
                    <span>Timeline</span>
                </div>
            </div>

            @* Feature 6 — Team & Audit *@
            <div class="lp-feature-card lp-feature-card--highlight">
                <div class="lp-feature-icon lp-feature-icon--purple">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="28" height="28">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                </div>
                <h3>Team &amp; Audit Trail</h3>
                <p>Role-based access (Admin, Maker, Viewer) with maker-checker workflows. Full audit trail captures every change, approval, and submission.</p>
                <div class="lp-feature-tags">
                    <span>RBAC</span>
                    <span>Approval flow</span>
                    <span>Audit log</span>
                </div>
            </div>
        </div>
    </section>

    @* ══════════════════════════════════════════════════════════════
       HOW IT WORKS — 3 Steps
       ══════════════════════════════════════════════════════════════ *@
    <section class="lp-how" id="how-it-works">
        <div class="lp-section-head">
            <span class="lp-overline">How It Works</span>
            <h2 class="lp-section-title">From signup to first filing in under 10 minutes</h2>
            <p class="lp-section-desc">Our guided onboarding gets your institution workspace operational fast — verified identity, activated modules, and team access in one seamless flow.</p>
        </div>

        <div class="lp-how-steps">
            <div class="lp-how-step">
                <div class="lp-how-step-num" aria-hidden="true">
                    <span>01</span>
                </div>
                <div class="lp-how-step-content">
                    <h3>Verify &amp; Register</h3>
                    <p>Select your CBN-licensed institution from our verified directory. Confirm your compliance contacts and institution profile in seconds.</p>
                </div>
                <div class="lp-how-step-visual" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" width="40" height="40">
                        <path d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001z" transform="translate(2,2)"/>
                        <polyline points="11 14 13 16 17 12" />
                    </svg>
                </div>
            </div>

            <div class="lp-how-connector" aria-hidden="true">
                <svg viewBox="0 0 60 24" fill="none" stroke="var(--cbn-primary,#006B3F)" stroke-width="2" stroke-dasharray="6 4" stroke-linecap="round" width="60" height="24">
                    <path d="M0 12 h60"/>
                </svg>
            </div>

            <div class="lp-how-step">
                <div class="lp-how-step-num" aria-hidden="true">
                    <span>02</span>
                </div>
                <div class="lp-how-step-content">
                    <h3>Configure Workspace</h3>
                    <p>Choose your plan, activate the regulatory modules you need (CISS, eFASS, MDFR, and more), and invite your team — all in one guided wizard.</p>
                </div>
                <div class="lp-how-step-visual" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="40" height="40">
                        <circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                    </svg>
                </div>
            </div>

            <div class="lp-how-connector" aria-hidden="true">
                <svg viewBox="0 0 60 24" fill="none" stroke="var(--cbn-primary,#006B3F)" stroke-width="2" stroke-dasharray="6 4" stroke-linecap="round" width="60" height="24">
                    <path d="M0 12 h60"/>
                </svg>
            </div>

            <div class="lp-how-step">
                <div class="lp-how-step-num" aria-hidden="true">
                    <span>03</span>
                </div>
                <div class="lp-how-step-content">
                    <h3>Submit Returns</h3>
                    <p>Open the intelligent data entry form, fill in your regulatory data with real-time validation guidance, and submit with confidence. It's that simple.</p>
                </div>
                <div class="lp-how-step-visual" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="40" height="40">
                        <polyline points="10,3 10,13"/><polyline points="6,7 10,3 14,7"/>
                        <path d="M3 17h14" transform="translate(1.5,2)"/>
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" transform="translate(0,0) scale(0.7)" stroke-width="2"/>
                    </svg>
                </div>
            </div>
        </div>
    </section>

    @* ══════════════════════════════════════════════════════════════
       SECURITY / COMPLIANCE
       ══════════════════════════════════════════════════════════════ *@
    <section class="lp-security" id="security">
        <div class="lp-security-grid">
            <div class="lp-security-content">
                <span class="lp-overline">Enterprise Security</span>
                <h2 class="lp-section-title">Built for regulated environments</h2>
                <p class="lp-section-desc" style="text-align:left">
                    RegOS is designed from the ground up for the Nigerian financial services sector. Every layer — from infrastructure to UI — meets the strictest regulatory and security standards.
                </p>

                <div class="lp-security-list">
                    <div class="lp-security-item">
                        <div class="lp-security-item-icon" aria-hidden="true">
                            <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg>
                        </div>
                        <div>
                            <strong>End-to-end encryption</strong>
                            <span>AES-256 at rest, TLS 1.3 in transit. Zero plaintext storage of sensitive data.</span>
                        </div>
                    </div>
                    <div class="lp-security-item">
                        <div class="lp-security-item-icon" aria-hidden="true">
                            <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18"><path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1.323l3.954 1.582 1.599-.547a1 1 0 01.64 1.898l-1.263.432-.14.466a8 8 0 01-12.58 0l-.14-.466-1.263-.432a1 1 0 01.64-1.898l1.599.547L8 4.323V3a1 1 0 011-1z" clip-rule="evenodd"/><path d="M3 14s1 2 7 2 7-2 7-2"/></svg>
                        </div>
                        <div>
                            <strong>Multi-factor authentication</strong>
                            <span>TOTP authenticator app, backup codes, and device-remember for trusted workstations.</span>
                        </div>
                    </div>
                    <div class="lp-security-item">
                        <div class="lp-security-item-icon" aria-hidden="true">
                            <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18"><path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
