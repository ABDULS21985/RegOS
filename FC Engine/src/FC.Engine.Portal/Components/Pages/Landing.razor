@page "/landing"
@layout LoginLayout

<PageTitle>RegOS™ — Regulatory Reporting Platform for Financial Institutions</PageTitle>

<div class="lp-shell">

    @* ═══ Ambient background orbs ═══ *@
    <div class="lp-orb lp-orb--emerald" aria-hidden="true"></div>
    <div class="lp-orb lp-orb--gold" aria-hidden="true"></div>
    <div class="lp-orb lp-orb--teal" aria-hidden="true"></div>

    @* ═══ Floating navbar ═══ *@
    <nav class="lp-nav" role="navigation" aria-label="Landing page navigation">
        <div class="lp-nav-inner">
            <div class="lp-nav-brand">
                <div class="lp-nav-logo-mark" aria-hidden="true">
                    <svg viewBox="0 0 36 36" width="32" height="32">
                        <rect width="36" height="36" rx="9" fill="var(--cbn-green-deep,#006B3F)"/>
                        <text x="18" y="24" text-anchor="middle" fill="white" font-size="12" font-weight="700" font-family="sans-serif">RE</text>
                    </svg>
                </div>
                <div class="lp-nav-brand-copy">
                    <span class="lp-nav-brand-name">RegOS<sup>™</sup></span>
                    <span class="lp-nav-brand-sub">Institution Portal</span>
                </div>
            </div>

            <div class="lp-nav-links">
                <a href="#features" class="lp-nav-link">Features</a>
                <a href="#how-it-works" class="lp-nav-link">How It Works</a>
                <a href="#security" class="lp-nav-link">Security</a>
                <a href="#pricing" class="lp-nav-link">Pricing</a>
            </div>

            <div class="lp-nav-actions">
                <a href="/login" class="lp-nav-signin">Sign In</a>
                <a href="/onboarding/wizard" class="lp-nav-cta">Get Started</a>
            </div>
        </div>
    </nav>

    @* ══════════════════════════════════════════════════════════════
       HERO SECTION
       ══════════════════════════════════════════════════════════════ *@
    <section class="lp-hero" id="hero">
        <div class="lp-hero-content">
            <div class="lp-hero-lead">
                <div class="lp-hero-badge">
                    <span class="lp-hero-badge-dot" aria-hidden="true"></span>
                    Trusted by 500+ Nigerian financial institutions
                </div>

                <h1 class="lp-hero-title">
                    Regulatory reporting,<br/>
                    <span class="lp-hero-title-accent">reimagined.</span>
                </h1>

                <p class="lp-hero-subtitle">
                    RegOS transforms how financial institutions prepare, validate, and submit regulatory returns to the Central Bank of Nigeria — cutting compliance time by 80% with intelligent automation, real-time validation, and a workspace your team will actually enjoy using.
                </p>

                <div class="lp-hero-actions">
                    <a href="/onboarding/wizard" class="lp-btn lp-btn--primary lp-btn--lg">
                        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
                            <polyline points="10,3 10,13"/><polyline points="6,7 10,3 14,7"/>
                            <path d="M3 17h14"/>
                        </svg>
                        Start Onboarding
                        <span class="lp-btn-arrow" aria-hidden="true">&rarr;</span>
                    </a>
                    <a href="/login" class="lp-btn lp-btn--outline lp-btn--lg">
                        Sign In to Portal
                    </a>
                </div>

                <div class="lp-hero-proof">
                    <div class="lp-hero-proof-avatars" aria-hidden="true">
                        <span class="lp-proof-avatar" style="--avatar-hue:142">FBN</span>
                        <span class="lp-proof-avatar" style="--avatar-hue:210">GTB</span>
                        <span class="lp-proof-avatar" style="--avatar-hue:30">UBA</span>
                        <span class="lp-proof-avatar" style="--avatar-hue:270">ZEN</span>
                        <span class="lp-proof-avatar lp-proof-avatar--more">+496</span>
                    </div>
                    <span class="lp-hero-proof-text">Licensed institutions actively filing returns</span>
                </div>
            </div>

            <div class="lp-hero-visual">
                <div class="lp-hero-card lp-hero-card--dashboard">
                    <div class="lp-hero-card-topbar">
                        <span class="lp-hero-card-dot" style="background:#EF4444" aria-hidden="true"></span>
                        <span class="lp-hero-card-dot" style="background:#F59E0B" aria-hidden="true"></span>
                        <span class="lp-hero-card-dot" style="background:#22C55E" aria-hidden="true"></span>
                        <span class="lp-hero-card-title">RegOS Dashboard</span>
                    </div>
                    <div class="lp-hero-card-body">
                        <div class="lp-hero-mock-stats">
                            <div class="lp-hero-mock-stat">
                                <span>Submitted</span>
                                <strong>94.2%</strong>
                                <div class="lp-hero-mock-bar"><div class="lp-hero-mock-fill" style="--fill:94%"></div></div>
                            </div>
                            <div class="lp-hero-mock-stat">
                                <span>Validation</span>
                                <strong>98.7%</strong>
                                <div class="lp-hero-mock-bar"><div class="lp-hero-mock-fill lp-hero-mock-fill--gold" style="--fill:99%"></div></div>
                            </div>
                            <div class="lp-hero-mock-stat">
                                <span>On-Time</span>
                                <strong>100%</strong>
                                <div class="lp-hero-mock-bar"><div class="lp-hero-mock-fill lp-hero-mock-fill--emerald" style="--fill:100%"></div></div>
                            </div>
                        </div>
                        <div class="lp-hero-mock-modules">
                            <span class="lp-hero-mock-chip">CISS</span>
                            <span class="lp-hero-mock-chip">eFASS</span>
                            <span class="lp-hero-mock-chip">MDFR</span>
                            <span class="lp-hero-mock-chip lp-hero-mock-chip--active">FDR</span>
                            <span class="lp-hero-mock-chip">CCDR</span>
                        </div>
                    </div>
                </div>

                @* Floating accent cards *@
                <div class="lp-hero-float lp-hero-float--validation">
                    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" width="18" height="18" aria-hidden="true">
                        <circle cx="10" cy="10" r="8"/><polyline points="7,10 9,12.5 13.5,7.5"/>
                    </svg>
                    <div>
                        <strong>Validation passed</strong>
                        <span>0 errors, 0 warnings</span>
                    </div>
                </div>

                <div class="lp-hero-float lp-hero-float--deadline">
                    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" width="18" height="18" aria-hidden="true">
                        <rect x="3" y="4" width="14" height="14" rx="2"/><line x1="3" y1="8" x2="17" y2="8"/><line x1="7" y1="2" x2="7" y2="5"/><line x1="13" y1="2" x2="13" y2="5"/>
                    </svg>
                    <div>
                        <strong>Next deadline</strong>
                        <span>MDFR — 5 days left</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* ══════════════════════════════════════════════════════════════
       TRUST BAR
       ══════════════════════════════════════════════════════════════ *@
