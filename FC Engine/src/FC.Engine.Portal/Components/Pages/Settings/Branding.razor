@code {
    // ── Tabs ──────────────────────────────────────────────────────────
    private static readonly (string Key, string Label, string Icon)[] _tabs =
    [
        ("colors",  "Colors",  "🎨"),
        ("logos",   "Logos",   "🖼"),
        ("fonts",   "Fonts",   "Aa"),
        ("login",   "Login",   "🔐"),
        ("presets", "Presets", "✨"),
        ("advanced","Advanced","⚙"),
    ];

    private static readonly string[] ApprovedFonts =
    [
        "Inter", "Plus Jakarta Sans", "Source Sans 3", "Nunito",
        "Roboto", "Poppins", "Lato", "Open Sans",
    ];

    private static readonly string[] CssVarRef =
    [
        "--cbn-primary", "--cbn-accent", "--cbn-danger", "--cbn-success", "--cbn-warning",
        "--cbn-surface", "--cbn-sidebar", "--cbn-text", "--cbn-text-secondary", "--cbn-border",
        "--font-sans", "--font-heading",
        "--space-1", "--space-2", "--space-3", "--space-4", "--space-5",
        "--radius-sm", "--radius-md", "--radius-lg",
        "--motion-fast", "--motion-normal", "--motion-slow",
    ];

    private record BrandingPreset(string Name, string Description,
        string Primary, string Secondary, string Sidebar, string Background,
        string FontHeading, string FontBody);

    private static readonly BrandingPreset[] Presets =
    [
        new("Financial Green",  "CBN default — authoritative and trustworthy",         "#006B3F", "#C8A415", "#1A1F2B", "#F8F9FA", "Plus Jakarta Sans", "Inter"),
        new("Corporate Blue",   "Professional blue — familiar banking aesthetic",       "#0052CC", "#00B8D9", "#0747A6", "#F4F5F7", "Roboto",            "Source Sans 3"),
        new("Conservative Gray","Understated and neutral — maximum readability",        "#374151", "#6B7280", "#1F2937", "#F9FAFB", "Open Sans",         "Lato"),
        new("Bold Gold",        "Premium feel — leading with strong brand identity",    "#B8860B", "#006B3F", "#2D2106", "#FFFDF5", "Poppins",           "Nunito"),
    ];

    // ── State ─────────────────────────────────────────────────────────
    private BrandingConfig _config = BrandingConfig.WithDefaults();
    private BrandingConfig? _presetSnapshot;
    private bool _hasFeature;
    private bool _loading = true;
    private bool _saving;
    private string? _initError;
    private string? _saveError;
    private bool _saved;
    private string _tab = "colors";
    private string _previewMode = "portal";
    private bool _showResetConfirm;
    private string? _previewingPreset;
    private Guid _tenantId;

    // ── Derived ───────────────────────────────────────────────────────
    private string Initials
    {
        get
        {
            if (string.IsNullOrWhiteSpace(_config.CompanyName)) return "?";
            var words = _config.CompanyName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            return string.Concat(words.Take(2).Select(w => char.ToUpperInvariant(w[0])));
        }
    }

    // ── Init ──────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        if (!TenantContext.CurrentTenantId.HasValue)
        {
            _initError = "Tenant context is not available.";
            _loading = false;
            return;
        }

        _tenantId = TenantContext.CurrentTenantId.Value;

        try
        {
            _config = await BrandingService.GetBrandingConfig(_tenantId);

            var hasCustomBranding = await SubscriptionService.HasFeature(_tenantId, "custom_branding");
            var hasWhiteLabel     = await SubscriptionService.HasFeature(_tenantId, "white_label");
            var hasCustomDomain   = await SubscriptionService.HasFeature(_tenantId, "custom_domain");
            _hasFeature = hasCustomBranding || hasWhiteLabel || hasCustomDomain;
        }
        catch (Exception ex)
        {
            _initError = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_loading && _initError == null)
        {
            // Pre-load currently selected fonts so preview renders correctly
            await JS.InvokeVoidAsync("portalBranding.loadGoogleFont", _config.FontHeading);
            await JS.InvokeVoidAsync("portalBranding.loadGoogleFont", _config.FontBody);
        }
    }

    // ── Save ──────────────────────────────────────────────────────────
    private async Task SaveBranding()
    {
        _saveError = null;
        _saved = false;
        _saving = true;
        try
        {
            await BrandingService.UpdateBrandingConfig(_tenantId, _config);
            await BrandingService.InvalidateCache(_tenantId);
            _saved = true;
            _previewingPreset = null;
            _presetSnapshot = null;
        }
        catch (Exception ex)
        {
            _saveError = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    // ── Font Change ───────────────────────────────────────────────────
    private async Task OnHeadingFontChange(string? fontName)
    {
        _config.FontHeading = fontName;
        if (!string.IsNullOrWhiteSpace(fontName))
            await JS.InvokeVoidAsync("portalBranding.loadGoogleFont", fontName);
    }

    private async Task OnBodyFontChange(string? fontName)
    {
        _config.FontBody = fontName;
        if (!string.IsNullOrWhiteSpace(fontName))
            await JS.InvokeVoidAsync("portalBranding.loadGoogleFont", fontName);
    }

    // ── Logo Upload ───────────────────────────────────────────────────
    private async Task HandleLogoUpload(InputFileChangeEventArgs args)
    {
        if (args.File is null) return;
        _saveError = null;
        try
        {
            await using var stream = args.File.OpenReadStream(maxAllowedSize: 2 * 1024 * 1024);
            _config.LogoUrl = await BrandingService.UploadLogo(_tenantId, stream, args.File.Name, args.File.ContentType);
        }
        catch (Exception ex) { _saveError = "Logo upload failed: " + ex.Message; }
    }

    private async Task HandleCompactLogoUpload(InputFileChangeEventArgs args)
    {
        if (args.File is null) return;
        _saveError = null;
        try
        {
            await using var stream = args.File.OpenReadStream(maxAllowedSize: 2 * 1024 * 1024);
            _config.LogoSmallUrl = await BrandingService.UploadCompactLogo(_tenantId, stream, args.File.Name, args.File.ContentType);
        }
        catch (Exception ex) { _saveError = "Logo upload failed: " + ex.Message; }
    }

    private async Task HandleFaviconUpload(InputFileChangeEventArgs args)
    {
        if (args.File is null) return;
        _saveError = null;
        try
        {
            await using var stream = args.File.OpenReadStream(maxAllowedSize: 2 * 1024 * 1024);
            _config.FaviconUrl = await BrandingService.UploadFavicon(_tenantId, stream, args.File.Name, args.File.ContentType);
        }
        catch (Exception ex) { _saveError = "Favicon upload failed: " + ex.Message; }
    }

    // ── Presets ───────────────────────────────────────────────────────
    private void PreviewPreset(BrandingPreset preset)
    {
        if (_previewingPreset != preset.Name)
        {
            // Save snapshot so Cancel can restore
            _presetSnapshot = CloneConfig(_config);
        }
        _previewingPreset = preset.Name;
        _config.PrimaryColor    = preset.Primary;
        _config.SecondaryColor  = preset.Secondary;
        _config.SidebarColor    = preset.Sidebar;
        _config.BackgroundColor = preset.Background;
        _config.FontHeading     = preset.FontHeading;
        _config.FontBody        = preset.FontBody;
    }

    private void ApplyPreset(BrandingPreset preset)
    {
        _config.ThemePresetName = preset.Name;
        _previewingPreset = null;
        _presetSnapshot = null;
    }

    private void CancelPresetPreview()
    {
        if (_presetSnapshot != null)
        {
            _config = _presetSnapshot;
            _presetSnapshot = null;
        }
        _previewingPreset = null;
    }

    // ── Reset ─────────────────────────────────────────────────────────
    private void ConfirmReset()
    {
        _config = BrandingConfig.WithDefaults();
        _showResetConfirm = false;
        _previewingPreset = null;
        _presetSnapshot = null;
        _saved = false;
        _saveError = null;
    }

    // ── CSS Export ────────────────────────────────────────────────────
    private async Task ExportCss()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine($"/* {_config.CompanyName ?? "Institution"} — Theme Export */");
        sb.AppendLine($"/* Generated: {DateTime.UtcNow:yyyy-MM-dd HH:mm} UTC */");
        sb.AppendLine($"/* Preset: {_config.ThemePresetName ?? "Custom"} */");
        sb.AppendLine();
        sb.AppendLine(":root {");
        sb.AppendLine($"  /* Brand Colors */");
        sb.AppendLine($"  --color-primary:    {_config.PrimaryColor};");
        sb.AppendLine($"  --color-secondary:  {_config.SecondaryColor};");
        sb.AppendLine($"  --color-accent:     {_config.AccentColor};");
        sb.AppendLine($"  --color-danger:     {_config.DangerColor};");
        sb.AppendLine($"  --color-success:    {_config.SuccessColor};");
        sb.AppendLine($"  --color-warning:    {_config.WarningColor};");
        sb.AppendLine($"  /* Layout Colors */");
        sb.AppendLine($"  --color-background: {_config.BackgroundColor};");
        sb.AppendLine($"  --color-sidebar:    {_config.SidebarColor};");
        sb.AppendLine($"  /* Typography */");
        sb.AppendLine($"  --font-heading: '{_config.FontHeading}';");
        sb.AppendLine($"  --font-body:    '{_config.FontBody}';");
        sb.AppendLine($"  /* CBN Token Bridge */");
        sb.AppendLine($"  --cbn-primary:       var(--color-primary);");
        sb.AppendLine($"  --cbn-accent:        var(--color-secondary);");
        sb.AppendLine($"  --cbn-danger:        var(--color-danger);");
        sb.AppendLine($"  --cbn-success:       var(--color-success);");
        sb.AppendLine($"  --cbn-warning:       var(--color-warning);");
        sb.AppendLine($"  --cbn-surface:       var(--color-background);");
        sb.AppendLine($"  --cbn-sidebar:       var(--color-sidebar);");
        sb.AppendLine($"  --font-sans:         var(--font-body), -apple-system, sans-serif;");
        sb.AppendLine("}");

        if (!string.IsNullOrWhiteSpace(_config.CustomCss))
        {
            sb.AppendLine();
            sb.AppendLine("/* Custom Overrides */");
            sb.AppendLine(_config.CustomCss);
        }

        await JS.InvokeVoidAsync("portalBranding.exportCss", sb.ToString(), "theme.css");
    }

    // ── WCAG Contrast ─────────────────────────────────────────────────
    private static double ComputeContrast(string? hex1, string? hex2)
    {
        var l1 = GetLuminance(hex1 ?? "#FFFFFF");
        var l2 = GetLuminance(hex2 ?? "#000000");
        var lighter = Math.Max(l1, l2);
        var darker  = Math.Min(l1, l2);
        return Math.Round((lighter + 0.05) / (darker + 0.05), 2);
    }

    private static double GetLuminance(string hex)
    {
        var (r, g, b) = ParseHex(hex);
        static double Lin(int c)
        {
            var s = c / 255.0;
            return s <= 0.04045 ? s / 12.92 : Math.Pow((s + 0.055) / 1.055, 2.4);
        }
        return 0.2126 * Lin(r) + 0.7152 * Lin(g) + 0.0722 * Lin(b);
    }

    private static string ContrastGrade(double ratio) => ratio switch
    {
        >= 7.0 => "AAA",
        >= 4.5 => "AA",
        >= 3.0 => "AA Large",
        _      => "Fail",
    };

    private static (int r, int g, int b) ParseHex(string hex)
    {
        var v = (hex ?? string.Empty).TrimStart('#');
        if (v.Length != 6) v = "006B3F";
        try
        {
            return (Convert.ToInt32(v[..2], 16),
                    Convert.ToInt32(v.Substring(2, 2), 16),
                    Convert.ToInt32(v.Substring(4, 2), 16));
        }
        catch { return (0, 107, 63); }
    }

    // ── Clone config for preset preview/cancel ────────────────────────
    private static BrandingConfig CloneConfig(BrandingConfig src) => new()
    {
        LogoUrl             = src.LogoUrl,
        LogoSmallUrl        = src.LogoSmallUrl,
        FaviconUrl          = src.FaviconUrl,
        PrimaryColor        = src.PrimaryColor,
