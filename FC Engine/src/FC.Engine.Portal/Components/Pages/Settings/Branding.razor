@page "/settings/branding"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject ITenantBrandingService BrandingService
@inject ITenantContext TenantContext
@inject ISubscriptionService SubscriptionService
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Branding & Identity</PageTitle>

@if (_loading)
{
    <div class="portal-be-skeleton">
        <div class="fc-skel" style="height:56px; border-radius:12px; margin-bottom:1rem;"></div>
        <div style="display:grid; grid-template-columns:1.1fr 0.9fr; gap:1rem;">
            <div class="fc-skel" style="height:560px; border-radius:12px;"></div>
            <div class="fc-skel" style="height:560px; border-radius:12px;"></div>
        </div>
    </div>
}
else if (_initError != null)
{
    <div class="portal-alert portal-alert-error" role="alert">@_initError</div>
}
else
{
    @if (!_hasFeature)
    {
        <div class="portal-be-upgrade-banner">
            <div class="portal-be-upgrade-icon">🎨</div>
            <div class="portal-be-upgrade-body">
                <strong>Custom Branding requires an Enterprise or White Label subscription.</strong>
                <p>Preview the controls below. Upgrade to save your brand identity to the portal.</p>
            </div>
            <a href="/subscription/my-plan" class="portal-btn portal-btn-primary portal-btn-sm">View Plans</a>
        </div>
    }

    @if (_saved)
    {
        <div class="portal-alert portal-alert-success" role="status">✓ Branding saved and applied successfully.</div>
    }
    @if (_saveError != null)
    {
        <div class="portal-alert portal-alert-error" role="alert">@_saveError</div>
    }

    <div class="portal-be-layout">

        <!-- ══════════════════════════════════════════════════════════
             LEFT: Editor Panel
             ══════════════════════════════════════════════════════════ -->
        <div class="portal-be-editor">

            <!-- Tab Navigation -->
            <nav class="portal-be-tabs" role="tablist" aria-label="Branding editor sections">
                @foreach (var tab in _tabs)
                {
                    <button class="portal-be-tab @(_tab == tab.Key ? "portal-be-tab--active" : "")"
                            role="tab" aria-selected="@(_tab == tab.Key)"
                            @onclick="() => _tab = tab.Key">
                        <span class="portal-be-tab-icon" aria-hidden="true">@tab.Icon</span>
                        <span class="portal-be-tab-label">@tab.Label</span>
                    </button>
                }
            </nav>

            <div class="portal-be-tab-panel" role="tabpanel">

                <!-- ── COLORS ───────────────────────────────────────── -->
                @if (_tab == "colors")
                {
                    <p class="portal-be-section-title">Brand Colors</p>

                    <div class="portal-be-color-row">
                        <span class="portal-be-color-row-label">Primary</span>
                        <input type="color" class="portal-be-color-swatch" @bind="_config.PrimaryColor" @bind:event="oninput" disabled="@(!_hasFeature)" />
                        <input type="text" class="portal-be-color-hex portal-form-input" @bind="_config.PrimaryColor" @bind:event="oninput" placeholder="#006B3F" maxlength="7" disabled="@(!_hasFeature)" />
                        @{ var cr1 = ComputeContrast(_config.PrimaryColor, "#FFFFFF"); }
                        <span class="portal-be-contrast-badge @(cr1 >= 4.5 ? "portal-be-contrast--pass" : cr1 >= 3.0 ? "portal-be-contrast--warn" : "portal-be-contrast--fail")" title="Primary on white background">@($"{cr1:F1}:1 {ContrastGrade(cr1)}")</span>
                    </div>

                    <div class="portal-be-color-row">
                        <span class="portal-be-color-row-label">Secondary</span>
                        <input type="color" class="portal-be-color-swatch" @bind="_config.SecondaryColor" @bind:event="oninput" disabled="@(!_hasFeature)" />
                        <input type="text" class="portal-be-color-hex portal-form-input" @bind="_config.SecondaryColor" @bind:event="oninput" placeholder="#C8A415" maxlength="7" disabled="@(!_hasFeature)" />
                        @{ var cr2 = ComputeContrast(_config.SecondaryColor, "#FFFFFF"); }
                        <span class="portal-be-contrast-badge @(cr2 >= 4.5 ? "portal-be-contrast--pass" : cr2 >= 3.0 ? "portal-be-contrast--warn" : "portal-be-contrast--fail")" title="Secondary on white background">@($"{cr2:F1}:1 {ContrastGrade(cr2)}")</span>
                    </div>

                    <div class="portal-be-color-row">
                        <span class="portal-be-color-row-label">Danger</span>
                        <input type="color" class="portal-be-color-swatch" @bind="_config.DangerColor" @bind:event="oninput" disabled="@(!_hasFeature)" />
                        <input type="text" class="portal-be-color-hex portal-form-input" @bind="_config.DangerColor" @bind:event="oninput" placeholder="#DC3545" maxlength="7" disabled="@(!_hasFeature)" />
                        @{ var cr3 = ComputeContrast(_config.DangerColor, "#FFFFFF"); }
                        <span class="portal-be-contrast-badge @(cr3 >= 4.5 ? "portal-be-contrast--pass" : cr3 >= 3.0 ? "portal-be-contrast--warn" : "portal-be-contrast--fail")" title="Danger on white background">@($"{cr3:F1}:1 {ContrastGrade(cr3)}")</span>
                    </div>

                    <p class="portal-be-section-title portal-be-section-title--mt">Layout Colors</p>

                    <div class="portal-be-color-row">
                        <span class="portal-be-color-row-label">Background</span>
                        <input type="color" class="portal-be-color-swatch" @bind="_config.BackgroundColor" @bind:event="oninput" disabled="@(!_hasFeature)" />
                        <input type="text" class="portal-be-color-hex portal-form-input" @bind="_config.BackgroundColor" @bind:event="oninput" placeholder="#F8F9FA" maxlength="7" disabled="@(!_hasFeature)" />
                        @{ var cr4 = ComputeContrast("#1F2937", _config.BackgroundColor); }
                        <span class="portal-be-contrast-badge @(cr4 >= 4.5 ? "portal-be-contrast--pass" : cr4 >= 3.0 ? "portal-be-contrast--warn" : "portal-be-contrast--fail")" title="Dark text on background">@($"{cr4:F1}:1 {ContrastGrade(cr4)}")</span>
                    </div>

                    <div class="portal-be-color-row">
                        <span class="portal-be-color-row-label">Sidebar</span>
                        <input type="color" class="portal-be-color-swatch" @bind="_config.SidebarColor" @bind:event="oninput" disabled="@(!_hasFeature)" />
                        <input type="text" class="portal-be-color-hex portal-form-input" @bind="_config.SidebarColor" @bind:event="oninput" placeholder="#1A1F2B" maxlength="7" disabled="@(!_hasFeature)" />
                        @{ var cr5 = ComputeContrast("#FFFFFF", _config.SidebarColor); }
                        <span class="portal-be-contrast-badge @(cr5 >= 4.5 ? "portal-be-contrast--pass" : cr5 >= 3.0 ? "portal-be-contrast--warn" : "portal-be-contrast--fail")" title="White text on sidebar">@($"{cr5:F1}:1 {ContrastGrade(cr5)}")</span>
                    </div>

                    <div class="portal-be-contrast-summary">
                        <div class="portal-be-contrast-summary-title">WCAG 2.1 Accessibility Summary</div>
                        <div class="portal-be-contrast-grid">
                            @{ var s1 = ComputeContrast(_config.PrimaryColor, "#FFFFFF"); }
                            <div class="portal-be-contrast-card @(s1 >= 4.5 ? "portal-be-contrast-card--pass" : "portal-be-contrast-card--fail")">
                                <span class="portal-be-contrast-card-label">Primary on White</span>
                                <span class="portal-be-contrast-card-ratio">@($"{s1:F1}:1")</span>
                                <span class="portal-be-contrast-card-grade">@ContrastGrade(s1)</span>
                            </div>
                            @{ var s2 = ComputeContrast("#FFFFFF", _config.PrimaryColor); }
                            <div class="portal-be-contrast-card @(s2 >= 4.5 ? "portal-be-contrast-card--pass" : "portal-be-contrast-card--fail")">
                                <span class="portal-be-contrast-card-label">White on Primary</span>
                                <span class="portal-be-contrast-card-ratio">@($"{s2:F1}:1")</span>
                                <span class="portal-be-contrast-card-grade">@ContrastGrade(s2)</span>
                            </div>
                            @{ var s3 = ComputeContrast(_config.SecondaryColor, "#FFFFFF"); }
                            <div class="portal-be-contrast-card @(s3 >= 4.5 ? "portal-be-contrast-card--pass" : "portal-be-contrast-card--fail")">
                                <span class="portal-be-contrast-card-label">Secondary on White</span>
                                <span class="portal-be-contrast-card-ratio">@($"{s3:F1}:1")</span>
                                <span class="portal-be-contrast-card-grade">@ContrastGrade(s3)</span>
                            </div>
                            @{ var s4 = ComputeContrast("#FFFFFF", _config.SidebarColor); }
                            <div class="portal-be-contrast-card @(s4 >= 4.5 ? "portal-be-contrast-card--pass" : "portal-be-contrast-card--fail")">
                                <span class="portal-be-contrast-card-label">White on Sidebar</span>
                                <span class="portal-be-contrast-card-ratio">@($"{s4:F1}:1")</span>
                                <span class="portal-be-contrast-card-grade">@ContrastGrade(s4)</span>
                            </div>
                        </div>
                    </div>
                }

                <!-- ── LOGOS ─────────────────────────────────────────── -->
                else if (_tab == "logos")
                {
                    <p class="portal-be-section-title">Logo & Favicon</p>

                    <div class="portal-be-logo-grid">

                        <!-- Primary Logo -->
                        <div class="portal-be-logo-item">
                            <div class="portal-be-logo-item-label">Primary Logo</div>
                            <div class="portal-be-logo-item-hint">Full-width logo for login page and expanded sidebar. SVG or PNG, ~300×80px.</div>
                            <label class="portal-be-logo-zone" for="be-logo-primary">
                                <InputFile OnChange="HandleLogoUpload" accept=".png,.svg,.jpg,.jpeg"
                                           id="be-logo-primary" class="portal-be-file-input" disabled="@(!_hasFeature)" />
                                <div class="portal-be-logo-zone-body">
                                    @if (!string.IsNullOrWhiteSpace(_config.LogoUrl))
                                    {
                                        <img src="@_config.LogoUrl" alt="Logo" class="portal-be-logo-thumb portal-be-logo-thumb--wide" />
                                        <span class="portal-be-logo-replace-hint">Click or drag to replace</span>
                                    }
                                    else
                                    {
                                        <span class="portal-be-logo-zone-icon" aria-hidden="true">🖼</span>
                                        <span class="portal-be-logo-zone-text">Drop logo here or click to browse</span>
                                        <span class="portal-be-logo-zone-hint">PNG, SVG, JPG · max 2 MB</span>
                                    }
                                </div>
                            </label>
                            <div class="portal-be-logo-context-label">In sidebar:</div>
                            <div class="portal-be-logo-ctx-sidebar" style="background: @(_config.SidebarColor ?? "#1A1F2B");">
                                @if (!string.IsNullOrWhiteSpace(_config.LogoUrl))
                                {
                                    <img src="@_config.LogoUrl" alt="Logo" class="portal-be-logo-ctx-sidebar-img" />
                                }
                                else
                                {
                                    <span class="portal-be-logo-ctx-sidebar-initials">@Initials</span>
                                }
                                <span class="portal-be-logo-ctx-sidebar-name">@(_config.CompanyName ?? "Institution")</span>
                            </div>
                        </div>

                        <!-- Compact Logo -->
                        <div class="portal-be-logo-item">
                            <div class="portal-be-logo-item-label">Compact Logo</div>
                            <div class="portal-be-logo-item-hint">Square icon for collapsed sidebar. 48×48px recommended.</div>
                            <label class="portal-be-logo-zone portal-be-logo-zone--square" for="be-logo-compact">
                                <InputFile OnChange="HandleCompactLogoUpload" accept=".png,.svg,.jpg,.jpeg"
                                           id="be-logo-compact" class="portal-be-file-input" disabled="@(!_hasFeature)" />
                                <div class="portal-be-logo-zone-body">
                                    @if (!string.IsNullOrWhiteSpace(_config.LogoSmallUrl))
                                    {
                                        <img src="@_config.LogoSmallUrl" alt="Compact logo" class="portal-be-logo-thumb portal-be-logo-thumb--square" />
                                        <span class="portal-be-logo-replace-hint">Click to replace</span>
                                    }
                                    else
                                    {
                                        <span class="portal-be-logo-zone-icon" aria-hidden="true">📐</span>
                                        <span class="portal-be-logo-zone-text">Drop square logo</span>
                                        <span class="portal-be-logo-zone-hint">Square PNG/SVG · max 2 MB</span>
                                    }
                                </div>
                            </label>
                            <div class="portal-be-logo-context-label">Collapsed sidebar:</div>
                            <div class="portal-be-logo-ctx-collapsed" style="background: @(_config.SidebarColor ?? "#1A1F2B");">
                                @if (!string.IsNullOrWhiteSpace(_config.LogoSmallUrl))
                                {
                                    <img src="@_config.LogoSmallUrl" alt="Icon" class="portal-be-logo-ctx-collapsed-img" />
                                }
                                else
                                {
                                    <div class="portal-be-logo-ctx-collapsed-placeholder">@(Initials.Length > 0 ? Initials[0].ToString() : "?")</div>
                                }
                            </div>
                        </div>

                        <!-- Favicon -->
                        <div class="portal-be-logo-item">
                            <div class="portal-be-logo-item-label">Favicon</div>
                            <div class="portal-be-logo-item-hint">Browser tab icon. ICO, PNG, or SVG · 32×32px.</div>
                            <label class="portal-be-logo-zone portal-be-logo-zone--square" for="be-logo-favicon">
                                <InputFile OnChange="HandleFaviconUpload" accept=".png,.svg,.ico"
                                           id="be-logo-favicon" class="portal-be-file-input" disabled="@(!_hasFeature)" />
                                <div class="portal-be-logo-zone-body">
                                    @if (!string.IsNullOrWhiteSpace(_config.FaviconUrl))
                                    {
                                        <img src="@_config.FaviconUrl" alt="Favicon" class="portal-be-logo-thumb portal-be-logo-thumb--favicon" />
                                        <span class="portal-be-logo-replace-hint">Click to replace</span>
                                    }
                                    else
                                    {
                                        <span class="portal-be-logo-zone-icon" aria-hidden="true">🌐</span>
                                        <span class="portal-be-logo-zone-text">Drop favicon</span>
                                        <span class="portal-be-logo-zone-hint">ICO, PNG, SVG · 32×32px</span>
                                    }
                                </div>
                            </label>
                            <div class="portal-be-logo-context-label">Browser tab:</div>
                            <div class="portal-be-logo-ctx-tab">
                                <div class="portal-be-logo-ctx-tab-chrome">
                                    @if (!string.IsNullOrWhiteSpace(_config.FaviconUrl))
                                    {
                                        <img src="@_config.FaviconUrl" alt="fav" class="portal-be-logo-ctx-tab-fav" />
                                    }
                                    else
                                    {
                                        <div class="portal-be-logo-ctx-tab-fav-placeholder">?</div>
                                    }
                                    <span class="portal-be-logo-ctx-tab-title">@(_config.CompanyName ?? "Portal") — Returns</span>
                                    <span class="portal-be-logo-ctx-tab-close" aria-hidden="true">✕</span>
                                </div>
                            </div>
                        </div>

                    </div>
                }

                <!-- ── FONTS ─────────────────────────────────────────── -->
                else if (_tab == "fonts")
                {
                    <p class="portal-be-section-title">Typography</p>

                    <div class="portal-be-font-pair">

                        <div class="portal-be-font-group">
                            <label class="portal-be-font-label" for="be-font-heading">Heading Font</label>
                            <select id="be-font-heading" class="portal-form-select"
                                    value="@_config.FontHeading"
                                    @onchange="e => OnHeadingFontChange(e.Value?.ToString())">
                                @foreach (var f in ApprovedFonts)
                                {
                                    <option value="@f" selected="@(f == _config.FontHeading)">@f</option>
                                }
                            </select>
                            <div class="portal-be-font-preview-wrap">
                                <p class="portal-be-font-preview portal-be-font-preview--h1"
                                   style="font-family: '@(_config.FontHeading ?? "Plus Jakarta Sans")', sans-serif;">
                                    Financial Returns System
                                </p>
                                <p class="portal-be-font-preview portal-be-font-preview--h3"
                                   style="font-family: '@(_config.FontHeading ?? "Plus Jakarta Sans")', sans-serif;">
                                    Quarterly Compliance Report
                                </p>
                                <p class="portal-be-font-preview portal-be-font-preview--abc"
                                   style="font-family: '@(_config.FontHeading ?? "Plus Jakarta Sans")', sans-serif;">
                                    Aa Bb Cc Dd Ee 0123456789
                                </p>
                            </div>
                        </div>

                        <div class="portal-be-font-group">
                            <label class="portal-be-font-label" for="be-font-body">Body Font</label>
                            <select id="be-font-body" class="portal-form-select"
                                    value="@_config.FontBody"
                                    @onchange="e => OnBodyFontChange(e.Value?.ToString())">
                                @foreach (var f in ApprovedFonts)
                                {
                                    <option value="@f" selected="@(f == _config.FontBody)">@f</option>
                                }
                            </select>
                            <div class="portal-be-font-preview-wrap">
                                <p class="portal-be-font-preview portal-be-font-preview--body"
                                   style="font-family: '@(_config.FontBody ?? "Inter")', sans-serif;">
                                    Submit your quarterly regulatory return by the specified deadline. Review all figures carefully before final submission to ensure compliance.
                                </p>
                                <p class="portal-be-font-preview portal-be-font-preview--body-sm"
                                   style="font-family: '@(_config.FontBody ?? "Inter")', sans-serif;">
                                    Reference no. 2025-Q1-00142 · Status: Pending Review
                                </p>
                                <p class="portal-be-font-preview portal-be-font-preview--abc"
                                   style="font-family: '@(_config.FontBody ?? "Inter")', sans-serif;">
                                    Aa Bb Cc Dd Ee 0123456789
                                </p>
                            </div>
                        </div>

                    </div>
                }

                <!-- ── LOGIN PAGE ─────────────────────────────────────── -->
                else if (_tab == "login")
                {
                    <p class="portal-be-section-title">Login Page Content</p>

                    <div class="portal-form-group">
                        <label class="portal-form-label" for="be-tagline">Tagline</label>
                        <input id="be-tagline" class="portal-form-input"
                               placeholder="Financial Returns Collection & Analysis System"
                               @bind="_config.LoginTagline" @bind:event="oninput"
                               disabled="@(!_hasFeature)" />
                        <span class="portal-form-hint">Shown below the company name on the login brand panel.</span>
                    </div>

                    <div class="portal-form-group">
                        <label class="portal-form-label" for="be-login-bg">Login Background Image URL</label>
                        <input id="be-login-bg" class="portal-form-input"
                               placeholder="https://…/background.jpg"
                               @bind="_config.LoginBackgroundUrl" @bind:event="oninput"
                               disabled="@(!_hasFeature)" />
                        <span class="portal-form-hint">Leave blank for the default gradient. Must be a publicly accessible image URL.</span>
                    </div>

                    <p class="portal-be-section-title portal-be-section-title--sm">Trust Badges</p>
                    <p class="portal-be-section-hint">Three short phrases displayed as security/trust indicators on the login panel.</p>

                    <div class="portal-be-trust-row">
                        <div class="portal-form-group">
                            <label class="portal-form-label">Badge 1</label>
                            <input class="portal-form-input" placeholder="Role-Based Access"
                                   @bind="_config.TrustBadge1" @bind:event="oninput" disabled="@(!_hasFeature)" />
                        </div>
                        <div class="portal-form-group">
                            <label class="portal-form-label">Badge 2</label>
                            <input class="portal-form-input" placeholder="Audit Logging"
                                   @bind="_config.TrustBadge2" @bind:event="oninput" disabled="@(!_hasFeature)" />
                        </div>
                        <div class="portal-form-group">
                            <label class="portal-form-label">Badge 3</label>
                            <input class="portal-form-input" placeholder="Encrypted Sessions"
                                   @bind="_config.TrustBadge3" @bind:event="oninput" disabled="@(!_hasFeature)" />
                        </div>
                    </div>

                    <div class="portal-be-login-tip">
                        <span aria-hidden="true">👉</span> Switch the preview panel to <strong>Login</strong> to see how your users will see the login page.
                    </div>
                }

                <!-- ── PRESETS ─────────────────────────────────────────── -->
                else if (_tab == "presets")
                {
                    <p class="portal-be-section-title">Preset Themes</p>
                    <p class="portal-be-section-hint">Click a preset to preview it instantly in the right panel. Use "Apply" to adopt it — you can still fine-tune colors and fonts afterward.</p>

                    <div class="portal-be-preset-grid">
                        @foreach (var preset in Presets)
                        {
                            var isActive = _config.ThemePresetName == preset.Name && _previewingPreset == null;
                            var isPreviewing = _previewingPreset == preset.Name;
                            <div class="portal-be-preset-card @(isActive ? "portal-be-preset-card--active" : "") @(isPreviewing ? "portal-be-preset-card--previewing" : "")"
                                 @onclick="() => PreviewPreset(preset)"
                                 role="button" tabindex="0"
                                 aria-pressed="@(isActive || isPreviewing)">
                                <div class="portal-be-preset-swatches">
                                    <div class="portal-be-preset-swatch" style="background:@preset.Primary;" title="Primary"></div>
                                    <div class="portal-be-preset-swatch" style="background:@preset.Secondary;" title="Secondary"></div>
                                    <div class="portal-be-preset-swatch" style="background:@preset.Sidebar;" title="Sidebar"></div>
                                    <div class="portal-be-preset-swatch portal-be-preset-swatch--bg" style="background:@preset.Background; border:1px solid rgba(0,0,0,.12);" title="Background"></div>
                                </div>
                                <div class="portal-be-preset-name">@preset.Name</div>
                                <div class="portal-be-preset-desc">@preset.Description</div>
                                <div class="portal-be-preset-footer">
                                    @if (isActive)
                                    {
                                        <span class="portal-be-preset-active-badge">✓ Currently Applied</span>
                                    }
                                    else if (isPreviewing)
                                    {
                                        <button class="portal-btn portal-btn-primary portal-btn-sm"
                                                @onclick:stopPropagation @onclick="() => ApplyPreset(preset)">Apply Theme</button>
                                        <button class="portal-btn portal-btn-ghost portal-btn-sm"
                                                @onclick:stopPropagation @onclick="CancelPresetPreview">Cancel</button>
                                    }
                                    else
                                    {
                                        <span class="portal-be-preset-tap-hint">Click to preview →</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }

                <!-- ── ADVANCED ──────────────────────────────────────── -->
                else if (_tab == "advanced")
                {
                    <p class="portal-be-section-title">Company Information</p>

                    <div class="portal-be-two-col">
                        <div class="portal-form-group">
                            <label class="portal-form-label" for="be-company">Company Name</label>
                            <input id="be-company" class="portal-form-input"
                                   @bind="_config.CompanyName" @bind:event="oninput"
                                   disabled="@(!_hasFeature)" />
                        </div>
                        <div class="portal-form-group">
                            <label class="portal-form-label" for="be-copyright">Copyright Text</label>
                            <input id="be-copyright" class="portal-form-input"
                                   placeholder="© 2025 Your Company. All rights reserved."
                                   @bind="_config.CopyrightText"
                                   disabled="@(!_hasFeature)" />
                        </div>
                        <div class="portal-form-group">
                            <label class="portal-form-label" for="be-email">Support Email</label>
                            <input id="be-email" class="portal-form-input" type="email"
                                   @bind="_config.SupportEmail"
                                   disabled="@(!_hasFeature)" />
                        </div>
                        <div class="portal-form-group">
                            <label class="portal-form-label" for="be-phone">Support Phone</label>
                            <input id="be-phone" class="portal-form-input" type="tel"
                                   @bind="_config.SupportPhone"
                                   disabled="@(!_hasFeature)" />
                        </div>
                        <div class="portal-form-group">
                            <label class="portal-form-label" for="be-watermark">Watermark Text</label>
                            <input id="be-watermark" class="portal-form-input"
                                   placeholder="CONFIDENTIAL"
                                   @bind="_config.WatermarkText"
                                   disabled="@(!_hasFeature)" />
                        </div>
                    </div>

                    <div class="portal-form-group portal-be-mt">
