@page "/help/getting-started"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "InstitutionUser")]
@inject IJSRuntime JS

<PageTitle>Getting Started — Help Center — FC Engine Portal</PageTitle>

<HelpLayout>
    <div class="help-article">
        <!-- Article meta -->
        <div class="fc-ha-meta">
            <span class="fc-ha-meta-item">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                2 min read
            </span>
            <span class="fc-ha-meta-item">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                Updated March 2026
            </span>
            <span class="fc-ha-meta-item fc-ha-progress-badge @(_completedCount == _totalSteps ? "fc-ha-progress-badge--done" : "")">
                @_completedCount / @_totalSteps steps complete
            </span>
        </div>

        <h2 class="help-article-title">Getting Started with FC Engine Portal</h2>
        <p class="help-article-intro">
            Welcome to the FC Engine FI Portal. This guide walks you through everything you need to know
            to start submitting your regulatory returns to the Central Bank of Nigeria.
        </p>

        <!-- Step progress indicator -->
        <div class="fc-gp-progress" role="progressbar" aria-valuenow="@_completedCount" aria-valuemin="0" aria-valuemax="@_totalSteps" aria-label="Guide progress">
            <div class="fc-gp-progress-track">
                @for (int si = 0; si < _totalSteps; si++)
                {
                    int idx = si;
                    <button class="fc-gp-step-dot @(_completedSteps.Contains(idx) ? "fc-gp-step-dot--done" : "") @(_currentHighlight == idx ? "fc-gp-step-dot--active" : "")"
                            @onclick="() => ScrollToStep(idx)"
                            aria-label="Step @(idx + 1)@(_completedSteps.Contains(idx) ? " (completed)" : "")"
                            type="button">
                        @if (_completedSteps.Contains(idx))
                        {
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                        }
                        else
                        {
                            <span>@(idx + 1)</span>
                        }
                    </button>
                    @if (idx < _totalSteps - 1)
                    {
                        <div class="fc-gp-step-line @(_completedSteps.Contains(idx) ? "fc-gp-step-line--done" : "")"></div>
                    }
                }
            </div>
            <div class="fc-gp-progress-fill" style="width: @((_completedCount * 100 / _totalSteps))%"></div>
        </div>

        @if (_completedCount == _totalSteps)
        {
            <div class="fc-gp-all-done">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                <div>
                    <strong>Guide complete!</strong> You're ready to submit your first return.
                    <a href="/submit" style="margin-left: 0.5rem">Submit a Return →</a>
                </div>
            </div>
        }

        <!-- Video: portal overview -->
        <div class="fc-hv-container" id="vid-overview">
            <div class="fc-hv-poster" id="vid-overview-poster">
                <div class="fc-hv-poster-bg" style="background: linear-gradient(135deg, #006B3F 0%, #004D2C 100%)"></div>
                <div class="fc-hv-poster-content">
                    <button class="fc-hv-play-btn" @onclick='() => PlayVideo("vid-overview")' aria-label="Play portal overview video" type="button">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                    </button>
                    <p class="fc-hv-caption">FC Engine Portal — 3-min overview</p>
                </div>
            </div>
            <iframe id="vid-overview-frame" class="fc-hv-frame" style="display:none"
                    data-src="https://www.youtube.com/embed/placeholder?enablejsapi=1"
                    title="FC Engine Portal Overview" frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen></iframe>
        </div>

        <!-- Step-by-step guide -->
        <div class="help-steps">
            @for (int si = 0; si < _steps.Count; si++)
            {
                int stepIdx = si;
                var step = _steps[si];
                bool done = _completedSteps.Contains(stepIdx);
                <div id="@step.Id" class="help-step fc-gs-step @(done ? "fc-gs-step--done" : "")">
                    <div class="fc-gs-step-left">
                        <div class="help-step-number fc-gs-step-num @(done ? "fc-gs-step-num--done" : "")" aria-hidden="true">
                            @if (done)
                            {
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                            }
                            else
                            {
                                @(stepIdx + 1)
                            }
                        </div>
                        @if (stepIdx < _steps.Count - 1)
                        {
                            <div class="fc-gs-connector @(done ? "fc-gs-connector--done" : "")"></div>
                        }
                    </div>
                    <div class="help-step-content">
                        <div class="fc-gs-step-header">
                            <h3 class="help-step-title">@step.Title</h3>
                            <button class="fc-gs-check-btn @(done ? "fc-gs-check-btn--done" : "")"
                                    @onclick="() => ToggleStep(stepIdx)"
                                    aria-label="@(done ? "Mark step " + (stepIdx + 1) + " as incomplete" : "Mark step " + (stepIdx + 1) + " as complete")"
                                    type="button">
                                @if (done)
                                {
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                                    <span>Done</span>
                                }
                                else
                                {
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/></svg>
                                    <span>Mark complete</span>
                                }
                            </button>
                        </div>
                        @step.Content
                    </div>
                </div>
            }
        </div>

        <div class="help-next-links">
            <h3>Next Steps</h3>
            <ul>
                <li><a href="/help/submission-guide">Detailed Submission Guide</a></li>
                <li><a href="/help/validation-errors">Understanding Validation Errors</a></li>
                <li><a href="/help/faq">Frequently Asked Questions</a></li>
            </ul>
        </div>

        <!-- Helpfulness rating -->
        <HelpRating ArticleId="getting-started" />
    </div>
</HelpLayout>

@code {
    private const string GuideId = "getting-started";
    private int _totalSteps = 6;
    private HashSet<int> _completedSteps = new();
    private int _completedCount => _completedSteps.Count;
    private int _currentHighlight = -1;

    private record StepDef(string Id, string Title, RenderFragment Content);
    private List<StepDef> _steps = new();

    protected override void OnInitialized()
    {
        _steps = new List<StepDef>
        {
            new("step-account", "Set Up Your Account", @<text>
                <p>Your institution administrator will create your user account and assign you a role. There are four roles in the portal:</p>
                <ul>
                    <li><strong>Admin</strong> — Full access including user management and institution settings</li>
                    <li><strong>Maker</strong> — Can prepare and submit returns for approval</li>
                    <li><strong>Checker</strong> — Reviews and approves/rejects submitted returns</li>
                    <li><strong>Viewer</strong> — Read-only access to submissions and reports</li>
                </ul>
                <p>On first login, you'll be prompted to change your temporary password. Choose a strong password with at least 8 characters including uppercase, lowercase, numbers, and symbols.</p>
            </text>),
            new("step-schema", "Download the XML Schema", @<text>
                <p>Before preparing your return data, download the XSD schema for the return template you need to submit.</p>
                <ol>
                    <li>Navigate to <a href="/schemas">Download Schemas</a> from the sidebar</li>
                    <li>Find the return template (e.g., MFCR 300 — Statement of Assets and Liabilities)</li>
                    <li>Click <strong>Download XSD</strong> to get the schema file</li>
                    <li>Use this schema to validate your XML before submission</li>
                </ol>
                <div class="help-tip">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                    <span><strong>Tip:</strong> Browse template structures in the <a href="/templates">Template Browser</a> to understand the required fields and data types.</span>
                </div>
            </text>),
            new("step-prepare", "Prepare Your XML File", @<text>
                <p>Your return data must be formatted as an XML file that conforms to the template's XSD schema. The XML structure depends on the return's structural category:</p>
                <div class="help-code-block">
                    <div class="help-code-header">FixedRow Template — Single row of data</div>
                    <pre><code>&lt;Return xmlns="urn:cbn:dfis:fc:MFCR300"&gt;
  &lt;Row&gt;
    &lt;CashInHand&gt;1500000.00&lt;/CashInHand&gt;
    &lt;BalWithCBN&gt;3200000.00&lt;/BalWithCBN&gt;
  &lt;/Row&gt;
&lt;/Return&gt;</code></pre>
                </div>
                <div class="help-code-block">
                    <div class="help-code-header">MultiRow Template — Multiple rows with serial numbers</div>
                    <pre><code>&lt;Return xmlns="urn:cbn:dfis:fc:MFCR900"&gt;
  &lt;Row&gt;
    &lt;SerialNo&gt;1&lt;/SerialNo&gt;
    &lt;BorrowerName&gt;Example Corp&lt;/BorrowerName&gt;
    &lt;LoanAmount&gt;5000000.00&lt;/LoanAmount&gt;
  &lt;/Row&gt;
&lt;/Return&gt;</code></pre>
                </div>
                <p>See the <a href="/help/submission-guide">Submission Guide</a> for detailed format requirements.</p>
            </text>),
            new("step-upload", "Upload Your Return", @<text>
                <ol>
                    <li>Go to <a href="/submit">Submit Return</a></li>
                    <li>Select the return template from the list</li>
                    <li>Choose the reporting period</li>
                    <li>Upload your XML file or fill in the online form</li>
                    <li>Review the pre-submission preview</li>
                    <li>Click <strong>Submit</strong></li>
                </ol>
            </text>),
            new("step-validate", "Review Validation Results", @<text>
                <p>After submission, the system automatically validates your data through multiple stages:</p>
                <ol>
                    <li><strong>Schema Validation</strong> — Checks XML structure against the XSD</li>
                    <li><strong>Type &amp; Range Checks</strong> — Verifies data types and value ranges</li>
                    <li><strong>Intra-Sheet Formulas</strong> — Validates arithmetic relationships within the return</li>
                    <li><strong>Cross-Sheet Rules</strong> — Checks consistency across related returns</li>
                    <li><strong>Business Rules</strong> — Applies regulatory business logic</li>
                </ol>
                <p>If validation passes (no errors), your return is accepted. Warnings don't prevent acceptance but should be reviewed. If there are errors, you'll need to correct and re-submit.</p>
                <p>See <a href="/help/validation-errors">Validation Error Guide</a> for details on each error type.</p>
            </text>),
            new("step-approve", "Approval Process (if applicable)", @<text>
                <p>If your institution has <strong>Maker-Checker</strong> enabled, submitted returns require approval from a Checker or Admin before being finalized.</p>
                <ul>
                    <li>After submission, the return enters <strong>Pending Approval</strong> status</li>
                    <li>Checkers receive a notification and can review the submission</li>
                    <li>The Checker can <strong>Approve</strong> (finalizes) or <strong>Reject</strong> (with comments)</li>
                    <li>If rejected, you can correct and re-submit as a linked re-submission</li>
                </ul>
                <div class="help-tip">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                    <span><strong>Note:</strong> A user cannot approve their own submission. The Maker and Checker must be different people.</span>
                </div>
            </text>),
        };
        _totalSteps = _steps.Count;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var completed = await JS.InvokeAsync<int[]>("fcHelp.getCompletedSteps", GuideId);
                _completedSteps = new HashSet<int>(completed);
                StateHasChanged();
            }
            catch { }
        }
    }

    private async Task ToggleStep(int stepIndex)
    {
        try
        {
            var result = await JS.InvokeAsync<System.Text.Json.JsonElement>("fcHelp.toggleStepComplete", GuideId, stepIndex);
            // Rebuild from JS result
            _completedSteps = new HashSet<int>();
            foreach (var prop in result.EnumerateObject())
            {
                if (int.TryParse(prop.Name, out var i) && prop.Value.GetBoolean())
                    _completedSteps.Add(i);
            }
        }
        catch
        {
            // Toggle locally on JS failure
            if (!_completedSteps.Remove(stepIndex)) _completedSteps.Add(stepIndex);
        }
    }

    private async Task ScrollToStep(int stepIndex)
    {
        _currentHighlight = stepIndex;
        var stepId = _steps[stepIndex].Id;
        try { await JS.InvokeVoidAsync("portalScrollToSection", stepId); } catch { }
        StateHasChanged();
    }

    private async Task PlayVideo(string id)
    {
        try { await JS.InvokeVoidAsync("fcHelp.playVideo", id); } catch { }
    }
}
