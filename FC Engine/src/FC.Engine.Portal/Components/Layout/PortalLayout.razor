@inherits LayoutComponentBase
@using System.Security.Claims
@using FC.Engine.Domain.Abstractions
@using FC.Engine.Domain.ValueObjects
@inject NavigationManager Navigation
@inject ITenantBrandingService BrandingService
@inject ITenantContext TenantContext
@inject SandboxService SandboxService
@inject TourStateService TourState
@implements IDisposable

<TenantThemeProvider />

<!-- Skip to content link for accessibility -->
<a href="#main-content" class="portal-skip-link">Skip to main content</a>

<!-- Global progress bar -->
<div class="portal-progress @(_navigating ? "is-loading" : (_progressComplete ? "is-complete" : ""))" aria-hidden="true">
    <div class="portal-progress-bar"></div>
</div>

<div class="portal-shell @(_sidebarOpen ? "sidebar-open" : "")">
    <!-- Sidebar -->
    <aside class="portal-sidebar" aria-label="Main navigation" @onkeydown="HandleSidebarKeyDown">
        <div class="portal-sidebar-brand">
            <img src="@_branding.LogoSmallUrl" alt="@_branding.CompanyName" class="portal-sidebar-logo" width="40" height="33" />
            <div class="portal-sidebar-brand-text">
                <span class="portal-sidebar-brand-name">@_branding.CompanyName</span>
                <span class="portal-sidebar-brand-sub">FI Portal</span>
            </div>
        </div>

        <!-- Institution context -->
        <AuthorizeView>
            <Authorized Context="instAuth">
                @{
                    var instName = instAuth.User.FindFirst("InstitutionName")?.Value ?? "Institution";
                    var instCode = instAuth.User.FindFirst("InstitutionId")?.Value ?? "";
                }
                <div class="portal-sidebar-institution">
                    <span class="portal-sidebar-inst-name">@instName</span>
                    @if (!string.IsNullOrEmpty(instCode))
                    {
                        <span class="portal-sidebar-inst-code">Code: @instCode</span>
                    }
                </div>
            </Authorized>
        </AuthorizeView>

        <NavMenu />

        <div class="portal-sidebar-user">
            <AuthorizeView>
                <Authorized Context="authState">
                    @{
                        var displayName = authState.User.FindFirst("DisplayName")?.Value
                            ?? authState.User.Identity?.Name
                            ?? "User";
                        var userRole = authState.User.FindFirst(ClaimTypes.Role)?.Value ?? "Viewer";
                        var initials = GetInitials(displayName);
                    }
                    <div class="portal-sidebar-user-info">
                        <div class="portal-sidebar-avatar" aria-hidden="true">
                            <span>@initials</span>
                        </div>
                        <div class="portal-sidebar-user-details">
                            <span class="portal-sidebar-user-name">@displayName</span>
                            <span class="portal-sidebar-user-role">@userRole</span>
                        </div>
                    </div>
                    <a href="/account/logout" class="portal-sidebar-signout" aria-label="Sign out">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true">
                            <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
                            <polyline points="16 17 21 12 16 7"/>
                            <line x1="21" y1="12" x2="9" y2="12"/>
                        </svg>
                        <span>Sign Out</span>
                    </a>
                </Authorized>
            </AuthorizeView>
        </div>
    </aside>

    <!-- Sidebar overlay for mobile -->
    <div class="portal-sidebar-overlay" @onclick="CloseSidebar" role="presentation" aria-hidden="true"></div>

    <!-- Main Area -->
    <div class="portal-main">
        <header class="portal-topbar" role="banner">
            <div class="portal-topbar-left">
                <button class="portal-topbar-toggle" @onclick="ToggleSidebar" aria-label="@(_sidebarOpen ? "Close navigation" : "Open navigation")" aria-expanded="@_sidebarOpen">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" aria-hidden="true">
                        @if (_sidebarOpen)
                        {
                            <line x1="18" y1="6" x2="6" y2="18"/>
                            <line x1="6" y1="6" x2="18" y2="18"/>
                        }
                        else
                        {
                            <line x1="3" y1="12" x2="21" y2="12"/>
                            <line x1="3" y1="6" x2="21" y2="6"/>
                            <line x1="3" y1="18" x2="21" y2="18"/>
                        }
                    </svg>
                </button>
                <nav class="portal-topbar-breadcrumb" aria-label="Breadcrumb">
                    <ol>
                        <li><a href="/">Home</a></li>
                        @if (_currentPageName != "Dashboard")
                        {
                            <li aria-current="page">@_currentPageName</li>
                        }
                    </ol>
                </nav>
            </div>

            <div class="portal-topbar-right">
                <button class="portal-tour-help-btn"
                        @onclick="TriggerPageTour"
                        title="Start page tour"
                        aria-label="Start guided page tour"
                        type="button">?</button>
                <NotificationBell />
            </div>
        </header>

        <main id="main-content" class="portal-content" role="main">
            @if (_sandboxContext?.IsSandbox == true)
            {
                <div class="portal-sandbox-banner">
                    <span>
                        TRAINING MODE: This is a sandbox environment. Data here does not affect production.
                    </span>
                    <div class="portal-sandbox-actions">
                        <button class="portal-btn portal-btn-sm portal-btn-outline" @onclick="SwitchToProduction" type="button">Switch to Production</button>
                        <button class="portal-btn portal-btn-sm portal-btn-outline" @onclick="ResetSandboxData" disabled="@_sandboxBusy" type="button">Reset Sandbox Data</button>
                    </div>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(_sandboxMessage))
            {
                <div class="portal-alert portal-alert-info">@_sandboxMessage</div>
            }
            @Body
        </main>
    </div>
</div>

<!-- Mobile bottom navigation bar -->
<nav class="portal-mobile-nav" aria-label="Mobile navigation">
    <NavLink href="/" Match="NavLinkMatch.All" class="portal-mobile-nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" aria-hidden="true">
            <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        <span>Home</span>
    </NavLink>
    <NavLink href="/submit" class="portal-mobile-nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" aria-hidden="true">
            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
            <polyline points="17 8 12 3 7 8"/>
            <line x1="12" y1="3" x2="12" y2="15"/>
        </svg>
        <span>Submit</span>
    </NavLink>
    <NavLink href="/submissions" class="portal-mobile-nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" aria-hidden="true">
            <polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/>
            <path d="M5.45 5.11L2 12v6a2 2 0 002 2h16a2 2 0 002-2v-6l-3.45-6.89A2 2 0 0016.76 4H7.24a2 2 0 00-1.79 1.11z"/>
        </svg>
        <span>Submissions</span>
    </NavLink>
    <NavLink href="/calendar" class="portal-mobile-nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        <span>Calendar</span>
    </NavLink>
    <button class="portal-mobile-nav-item portal-mobile-nav-more" @onclick="ToggleSidebar" aria-label="Open navigation menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" aria-hidden="true">
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <span>More</span>
    </button>
</nav>

<!-- Global notification overlays -->
<ToastContainer />
<ConfirmDialog />

<!-- Command palette (Ctrl+K / Cmd+K) and keyboard shortcuts overlay (?) -->
<CommandPalette />
<ShortcutsOverlay />

<!-- ARIA live region for screen reader announcements (page transitions) -->
<div class="portal-live-region" aria-live="polite" aria-atomic="true" role="status">
    @_liveAnnouncement
</div>

@code {
    private bool _sidebarOpen;
    private bool _navigating;
    private bool _progressComplete;
    private string _currentPageName = "Dashboard";
    private string _liveAnnouncement = "";
    private BrandingConfig _branding = BrandingConfig.WithDefaults();
    private SandboxContext? _sandboxContext;
    private bool _sandboxBusy;
    private string? _sandboxMessage;

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
        UpdatePageName(Navigation.Uri);
    }

    protected override async Task OnInitializedAsync()
    {
        if (TenantContext.CurrentTenantId.HasValue)
        {
            _branding = await BrandingService.GetBrandingConfig(TenantContext.CurrentTenantId.Value);
            _sandboxContext = await SandboxService.GetContext(TenantContext.CurrentTenantId.Value);
        }
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _navigating = true;
        _progressComplete = false;
        UpdatePageName(e.Location);
        _sidebarOpen = false;
        _liveAnnouncement = $"Navigated to {_currentPageName}";
        StateHasChanged();

        await Task.Delay(300);
        _navigating = false;
        _progressComplete = true;
        StateHasChanged();

        await Task.Delay(500);
        _progressComplete = false;
        StateHasChanged();
    }

    private void UpdatePageName(string uri)
    {
        var path = new Uri(uri).AbsolutePath.TrimStart('/').ToLowerInvariant();
        _currentPageName = path switch
        {
            "" or "/" => "Dashboard",
            "dashboard/compliance" => "Compliance Summary",
            "dashboard/admin" => "Admin Dashboard",
            var p when p.StartsWith("dashboard/module/") => "Module Dashboard",
            "submit" => "Submit Return",
            "submit/bulk" => "Bulk Upload",
            "submissions" => "My Submissions",
            var p when p.StartsWith("submissions/") => "Submission Detail",
            "calendar" => "Reporting Calendar",
            "templates" => "Template Browser",
            "schemas" => "Download Schemas",
            "help" => "Help Center",
            "help/getting-started" => "Getting Started",
            "help/submission-guide" => "Submission Guide",
            "help/validation-errors" => "Validation Errors",
            "help/faq" => "FAQ",
            "help/support" => "Contact Support",
            "help/knowledge-base" => "Knowledge Base",
            "onboarding/wizard" => "Onboarding Wizard",
            var p when p.StartsWith("onboarding/checklist/") => "Onboarding Checklist",
            "onboarding/sandbox" => "Training Sandbox",
            var p when p.StartsWith("onboarding/tour/") => "Guided Tour",
            "institution" => "My Institution",
            "institution/team" => "Team Members",
            "institution/settings" => "Settings",
            "validation/cross-sheet" => "Cross-Sheet Validation",
            "validate" => "Quick Validate",
            "reports/compliance" => "Compliance Report",
            "reports/audit" => "Audit Trail",
            "notifications" => "Notifications",
            "approvals" => "Pending Approvals",
            "settings" => "User Settings",
            "settings/notifications" => "Notification Preferences",
            _ => "Page"
        };
    }

    private void TriggerPageTour() => TourState.TriggerHelpButton();

    private void ToggleSidebar() => _sidebarOpen = !_sidebarOpen;
    private void CloseSidebar() => _sidebarOpen = false;

    private void HandleSidebarKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape" && _sidebarOpen)
            _sidebarOpen = false;
    }

    private void SwitchToProduction()
    {
        var target = _sandboxContext?.ProductionLoginUrl;
        if (string.IsNullOrWhiteSpace(target))
        {
            target = "/login";
        }

        Navigation.NavigateTo(target, forceLoad: true);
    }

    private async Task ResetSandboxData()
    {
        if (_sandboxContext is null || !_sandboxContext.IsSandbox || _sandboxBusy)
        {
            return;
        }

        _sandboxBusy = true;
        _sandboxMessage = null;
        try
        {
            await SandboxService.ResetSandbox(_sandboxContext.CurrentTenantId);
            _sandboxMessage = "Sandbox data reset and sample data reloaded.";
        }
        catch (Exception ex)
        {
            _sandboxMessage = ex.Message;
        }
        finally
        {
            _sandboxBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant();
        return name[..Math.Min(2, name.Length)].ToUpperInvariant();
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
