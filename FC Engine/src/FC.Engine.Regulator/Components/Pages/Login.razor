@page "/login"

<PageTitle>Regulator Login</PageTitle>

<div class="rg-login">
    <div class="rg-login-card">
        <h1 class="rg-page-title" style="margin-top:0;">Regulator Portal Login</h1>
        <p class="rg-muted">Sign in with your regulator examiner account.</p>

        @if (!string.IsNullOrWhiteSpace(Error))
        {
            <p class="rg-danger-text">@MapError(Error)</p>
        }

        <form method="post" action="/account/login">
            <div class="rg-grid" style="gap:0.55rem;">
                <label>
                    Username
                    <input name="username" autocomplete="username" required />
                </label>
                <label>
                    Password
                    <input type="password" name="password" autocomplete="current-password" required />
                </label>
                <button class="rg-btn primary" type="submit">Sign in</button>
            </div>
        </form>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    private static string MapError(string? code)
    {
        return code switch
        {
            "invalid" => "Invalid username or password.",
            "inactive" => "Your account is inactive.",
            "not-regulator" => "This account is not linked to a regulator tenant.",
            "tenant-missing" => "No tenant is linked to this account.",
            _ => "Unable to sign in."
        };
    }
}
